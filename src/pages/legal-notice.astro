---
import MainLayout from "../layouts/MainLayout.astro";

const title = "Legal Notice";
const description = "Minimal legal notice for OPDeckGuide.";
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">Legal</span>
			<h1>Legal Notice</h1>
			<p>
				Basic legal information for OPDeckGuide.
			</p>
		</div>
	</section>

	<section class="list-section">
		<div class="container legal-copy">
			<h2>Publisher</h2>
			<p>Site name: OPDeckGuide</p>
			<p>Publisher contact: opdeckguide@gmail.com</p>

			<h2>Hosting</h2>
			<p>Hosted on Cloudflare Pages.</p>
			<p>Hosting provider: Cloudflare, Inc.</p>

			<h2>Content</h2>
			<p>
				The site publishes editorial content and strategy guides about the One Piece Card Game.
			</p>

			<h2>Affiliate Disclosure</h2>
			<p>
				Some links published on OPDeckGuide are affiliate links. If a visitor clicks one of these links and
				completes an eligible purchase, OPDeckGuide may earn a commission at no additional cost to the user.
			</p>
			<p>
				Affiliate links may appear on tournament decklist pages and other editorial content when a relevant
				product page is available.
			</p>

			<h2>Analytics</h2>
			<p>
				The site may use Google Analytics 4 for basic audience measurement.
			</p>

			<h2>Contact</h2>
			<p>
				If you need to reach the site owner about the content of the site, use the publisher contact once it has
				been completed.
			</p>
		</div>
	</section>
</MainLayout>

<style>
	.legal-copy {
		max-width: 760px;
	}

	.legal-copy h2 {
		margin: 2rem 0 0.75rem;
		font-size: 1.5rem;
	}

	.legal-copy p {
		margin: 0.75rem 0;
		color: var(--text-200);
	}
</style>
