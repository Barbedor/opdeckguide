---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Lucy OP15 Stats in OP15 Format";
const description =
	"Red/Blue Lucy OP15 format stats article covering turn-order win rates in the OP15 format.";

const deckGuideHref = "/deck-guides/lucy-op15/";
const getRateTone = (value: string) => {
	const numeric = Number.parseFloat(value.replace("%", "").trim());
	if (numeric < 50) return "turn-rate-negative";
	if (numeric > 50) return "turn-rate-positive";
	return "turn-rate-neutral";
};

const summary = {
	totalGames: "14133",
	winRate: "53.1%",
	wins: "7498",
	losses: "6635",
};

const leaderHeroArt = "/assets/leader-art/lucy-op15-art.png";

const featuredTurnOrderStats = [
	{ label: "Lucy", code: "OP15-002", art: "/assets/leader-art/lucy-op15-art.png", first: "49.1%", second: "50.9%" },
	{ label: "Nami", code: "OP11-041", art: "/assets/leader-art/nami-op11-art.png", first: "60.4%", second: "60.2%" },
	{ label: "Enel", code: "OP15-058", art: "/assets/leader-art/enel-op15-art.png", first: "52.6%", second: "38.3%" },
	{ label: "Portgas D. Ace", code: "OP13-002", art: "/assets/leader-art/ace-op13-art.png", first: "48.9%", second: "58.1%" },
	{ label: "Monkey D. Luffy", code: "OP15-098", art: "/assets/leader-art/luffy-op15-art.png", first: "36.3%", second: "37.8%" },
	{ label: "Dracule Mihawk", code: "OP14-020", art: "/assets/leader-art/mihawk-op14-art.png", first: "67.6%", second: "67.8%" },
	{ label: "Boa Hancock", code: "OP14-041", art: "/assets/leader-art/hancock-op14-art.png", first: "51.8%", second: "44.6%" },
	{ label: "Imu", code: "OP13-079", art: "/assets/leader-art/imu-op13-art.png", first: "56.3%", second: "61.3%" },
	{ label: "Crocodile", code: "OP14-079", art: "/assets/leader-art/crocodile-op14-art.png", first: "65.4%", second: "68%" },
	{ label: "Donquixote Doflamingo", code: "OP14-060", art: "/assets/leader-art/doflamingo-op14-art.png", first: "55.8%", second: "60.8%" },
	{ label: "Gol.D.Roger", code: "OP13-003", art: "/assets/leader-art/roger-op13-art.png", first: "55.1%", second: "61.4%" },
	{ label: "Donquixote Rosinante", code: "OP12-061", art: "/assets/leader-art/rosinante-op12-art.png", first: "55.4%", second: "48.8%" },
	{ label: "Jewelry Bonney", code: "EB04-001", art: "/assets/leader-art/eb04-001-art.png", first: "70.6%", second: "56.4%" },
	{ label: "Gecko Moria", code: "OP14-080", art: "/assets/leader-art/moria-op14-art.png", first: "41%", second: "55.4%" },
	{ label: "Monkey D. Luffy", code: "OP11 Luffy", art: "/assets/guides/luffy op11.png", first: "65.9%", second: "64.9%" },
	{ label: "Marshall D. Teach", code: "OP09-081", art: "/assets/leader-art/teach-op09-art.png", first: "44.1%", second: "46.9%" },
	{ label: "Monkey D. Luffy", code: "ST29-001", art: "/assets/leader-art/luffy-st29-art.png", first: "60.7%", second: "55.9%" },
	{ label: "Kalgara", code: "OP08-098", art: "/assets/leader-art/kalgara-op08-art.png", first: "41.9%", second: "28.3%" },
	{ label: "Enel", code: "OP05-098", art: "/assets/leader-art/enel-op05-art.png", first: "50.6%", second: "63.3%" },
	{ label: "Monkey D. Luffy", code: "ST13 Luffy", art: "/assets/guides/luffy st13.png", first: "60.3%", second: "48.2%" },
	{ label: "Roronoa Zoro", code: "OP12-020", art: "/assets/leader-art/zoro-op12-art.png", first: "38.7%", second: "33.9%" },
	{ label: "Brook", code: "OP15-022", art: "/assets/leader-art/op15-022-art.png", first: "72.5%", second: "69.4%" },
	{ label: "Monkey D. Luffy", code: "OP13-001", art: "/assets/leader-art/luffy-op13-art.png", first: "54.3%", second: "50%" },
	{ label: "Jewelry Bonney", code: "OP07-019", art: "/assets/leader-art/bonney-op07-art.png", first: "47.8%", second: "42.9%" },
	{ label: "Koby", code: "OP11-001", art: "/assets/leader-art/koby-op11-art.png", first: "46.4%", second: "39.5%" },
	{ label: "Nefeltari Vivi", code: "EB03-001", art: "/assets/leader-art/eb03-001-art.png", first: "55.7%", second: "47.1%" },
	{ label: "Sanji", code: "OP12-063", art: "/assets/guides/sanji-op12.png", first: "66.7%", second: "53.8%" },
	{ label: "Jinbe", code: "OP14-040", art: "/assets/leader-art/jinbe-op14-art.png", first: "19.3%", second: "26.7%" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero meta-article-hero">
		<div class="container article-hero-grid">
			<div>
				<span class="hero-badge">Meta Article</span>
				<h1>Lucy OP15 Stats in OP15 Format</h1>
				<div class="article-leader-hero">
					<img src={leaderHeroArt} alt="Lucy OP15 leader art" loading="eager" />
				</div>
				<p class="article-kicker">
					This page focuses on Red/Blue Lucy stats in the OP15 format. If you want the full list, curve, and matchup plan, the <a href={deckGuideHref}>Lucy deck guide</a> is available separately.
				</p>
				<p>
					If you’re looking for a deck that turns Events into powerful tempo swings, Lucy is a great choice. Built around Dressrosa Events and [On Play] synergy, the deck lets you play effects for free, refill your hand, and control the board—all while maintaining strong defensive options.
				</p>
			</div>
			<div class="article-hero-side">
				<div class="hero-summary-card">
					<div class="hero-summary-label">Format</div>
					<strong>OP15</strong>
					<div class="hero-summary-divider"></div>
					<div class="hero-summary-label">Source Sample</div>
					<strong>{summary.totalGames} Games</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container stats-stack">
			<article class="stats-panel">
				<div class="section-header">
					<div>
						<h2>1st / 2nd Win Rate Stats</h2>
						<p>
							How does Red/Blue Lucy perform going 1st vs. 2nd? These win rate stats break down how turn order affects Red/Blue Lucy's gameplay—crucial insight for deciding how to approach specific matchups.
						</p>
					</div>
				</div>

				<div class="summary-metrics">
					<div class="summary-metric">
						<span class="summary-label">Total Games</span>
						<strong>{summary.totalGames}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">Winrate</span>
						<strong>{summary.winRate}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">W / L</span>
						<strong class="wl-stat">
							<span class="wl-win">{summary.wins}</span>/<span class="wl-loss">{summary.losses}</span>
						</strong>
					</div>
				</div>

				<div class="turn-order-grid">
					{featuredTurnOrderStats.map((entry) => (
						<div class="turn-order-card">
							<div class="leader-art-frame">
								<img src={entry.art} alt={`${entry.label} leader art`} loading="lazy" />
							</div>
							<div class="turn-order-meta">
								<div class="turn-order-name">{entry.label}</div>
								<div class="turn-order-code">{entry.code}</div>
							</div>
							<div class="turn-order-split">
								<div class={`turn-rate ${getRateTone(entry.first)}`}>
									<span class="turn-label">1st</span>
									<strong>{entry.first}</strong>
								</div>
								<div class={`turn-rate ${getRateTone(entry.second)}`}>
									<span class="turn-label">2nd</span>
									<strong>{entry.second}</strong>
								</div>
							</div>
						</div>
					))}
				</div>
			</article>
		</div>
	</section>
</MainLayout>

<style>
	.meta-article-hero {
		padding-bottom: 34px;
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) 260px;
		gap: 1.5rem;
		align-items: start;
	}

	.article-kicker {
		color: var(--text-200);
		font-weight: 600;
	}

	.article-kicker a {
		color: var(--accent);
	}

	.article-leader-hero {
		margin: 1.15rem 0 1.1rem;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at left, rgba(255, 107, 61, 0.2), transparent 36%),
			radial-gradient(circle at right, rgba(255, 159, 26, 0.16), transparent 38%),
			rgba(8, 11, 19, 0.96);
		box-shadow: var(--shadow);
	}

	.article-leader-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 3.2 / 1;
		object-fit: cover;
		object-position: 50% 18%;
	}

	.hero-summary-card {
		background:
			radial-gradient(circle at top left, rgba(239, 68, 68, 0.28), transparent 48%),
			radial-gradient(circle at top right, rgba(59, 130, 246, 0.24), transparent 46%),
			linear-gradient(135deg, rgba(239, 68, 68, 0.12), rgba(59, 130, 246, 0.1) 58%, rgba(12, 17, 30, 0.94));
		border: 1px solid rgba(255, 120, 40, 0.22);
		border-radius: 20px;
		padding: 1rem 1.1rem;
		display: grid;
		gap: 0.45rem;
		box-shadow: var(--shadow);
	}

	.hero-summary-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.hero-summary-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.08);
		margin: 0.2rem 0 0.15rem;
	}

	.stats-section {
		padding: 0 0 56px;
	}

	.stats-stack {
		display: grid;
		gap: 1.25rem;
	}

	.stats-panel {
		background: rgba(10, 13, 24, 0.88);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 1.5rem;
		box-shadow: var(--shadow);
	}

	.summary-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
		margin-bottom: 1.25rem;
	}

	.summary-metric {
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 0.85rem 0.9rem;
		background: rgba(6, 9, 17, 0.84);
	}

	.summary-label {
		display: block;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		margin-bottom: 0.35rem;
	}

	.summary-metric strong {
		font-size: 1.15rem;
		color: var(--text-100);
	}

	.wl-stat {
		font-variant-numeric: tabular-nums;
	}

	.wl-win {
		color: #7ff5a3;
	}

	.wl-loss {
		color: #ff9f9f;
	}

	.turn-order-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}

	.turn-order-card {
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: 0.8rem;
		background: rgba(7, 10, 18, 0.92);
		display: grid;
		gap: 0.7rem;
	}

	.leader-art-frame img {
		width: 100%;
		aspect-ratio: 1.75 / 1;
		object-fit: cover;
		object-position: center top;
		border-radius: 14px;
		display: block;
	}

	.turn-order-meta {
		display: grid;
		gap: 0.12rem;
	}

	.turn-order-name {
		font-weight: 700;
		font-size: 0.98rem;
		color: var(--text-100);
	}

	.turn-order-code {
		font-size: 0.82rem;
		color: var(--accent);
	}

	.turn-order-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.turn-rate {
		border-radius: 14px;
		padding: 0.55rem 0.45rem;
		display: grid;
		justify-items: center;
		gap: 0.2rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.02);
	}

	.turn-rate-positive {
		background: rgba(19, 76, 52, 0.36);
		border-color: rgba(70, 200, 128, 0.28);
	}

	.turn-rate-negative {
		background: rgba(82, 28, 38, 0.32);
		border-color: rgba(215, 92, 122, 0.24);
	}

	.turn-rate-neutral {
		background: rgba(55, 68, 95, 0.3);
		border-color: rgba(149, 165, 195, 0.18);
	}

	.turn-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-300);
	}

	.turn-rate strong {
		font-size: 0.94rem;
		color: var(--text-100);
	}

	@media (max-width: 1100px) {
		.turn-order-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 900px) {
		.article-hero-grid {
			grid-template-columns: 1fr;
		}

		.summary-metrics {
			grid-template-columns: 1fr;
		}

		.turn-order-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.article-leader-hero {
			margin: 0.95rem 0 1rem;
			border-radius: 16px;
		}

		.article-leader-hero img {
			aspect-ratio: 1.85 / 1;
			object-position: 50% 18%;
		}

		.stats-panel {
			padding: 1rem;
		}

		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.8rem;
		}

		.turn-order-card {
			padding: 0.7rem;
		}
	}
</style>
