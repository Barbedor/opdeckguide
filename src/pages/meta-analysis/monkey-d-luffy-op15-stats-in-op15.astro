---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Monkey.D.Luffy OP15 Stats in OP15 Format";
const description =
	"Yellow Monkey.D.Luffy OP15 format stats article covering turn-order win rates.";
const deckGuideHref = "/deck-guides/monkey-d-luffy-op15/";

const getRateTone = (value: string) => {
	const numeric = Number.parseFloat(value.replace("%", "").trim());
	if (numeric < 50) return "turn-rate-negative";
	if (numeric > 50) return "turn-rate-positive";
	return "turn-rate-neutral";
};

const summary = {
	totalGames: "25274",
	winRate: "51.1%",
	wins: "12920",
	losses: "12354",
};

const leaderHeroArt = "/assets/leader-art/luffy-op15-art.png";

const featuredTurnOrderStats = [
	{ label: "Enel", code: "OP15-058", art: "/assets/leader-art/enel-op15-art.png", first: "66.9%", second: "48.8%" },
	{ label: "Lucy", code: "OP15-002", art: "/assets/leader-art/lucy-op15-art.png", first: "68%", second: "67.5%" },
	{ label: "Nami", code: "OP11-041", art: "/assets/leader-art/nami-op11-art.png", first: "31.4%", second: "30.1%" },
	{ label: "Monkey D. Luffy", code: "OP15-098", art: "/assets/leader-art/luffy-op15-art.png", first: "49.2%", second: "50.8%" },
	{ label: "Portgas D. Ace", code: "OP13-002", art: "/assets/leader-art/ace-op13-art.png", first: "39%", second: "51%" },
	{ label: "Monkey D. Luffy", code: "EB02-010", art: "/assets/leader-art/luffy-eb02-art.png", first: "31.6%", second: "45.3%" },
	{ label: "Gecko Moria", code: "OP14-080", art: "/assets/leader-art/moria-op14-art.png", first: "37.6%", second: "54.7%" },
	{ label: "Dracule Mihawk", code: "OP14-020", art: "/assets/leader-art/mihawk-op14-art.png", first: "53.1%", second: "49.5%" },
	{ label: "Monkey D. Luffy", code: "OP13-001", art: "/assets/leader-art/luffy-op13-art.png", first: "28%", second: "32%" },
	{ label: "Crocodile", code: "OP14-079", art: "/assets/leader-art/crocodile-op14-art.png", first: "57.7%", second: "52.7%" },
	{ label: "Jewelry Bonney", code: "EB04-001", art: "/assets/leader-art/eb04-001-art.png", first: "43%", second: "42.2%" },
	{ label: "Marshall D. Teach", code: "OP09-081", art: "/assets/leader-art/teach-op09-art.png", first: "63.5%", second: "73.8%" },
	{ label: "Roronoa Zoro", code: "OP12-020", art: "/assets/leader-art/zoro-op12-art.png", first: "51.1%", second: "48%" },
	{ label: "Brook", code: "OP15-022", art: "/assets/leader-art/op15-022-art.png", first: "50.8%", second: "41.9%" },
	{ label: "Donquixote Doflamingo", code: "OP14-060", art: "/assets/leader-art/doflamingo-op14-art.png", first: "59.8%", second: "48.1%" },
	{ label: "Jinbe", code: "OP14-040", art: "/assets/leader-art/jinbe-op14-art.png", first: "52.6%", second: "67.7%" },
	{ label: "Kalgara", code: "OP08-098", art: "/assets/leader-art/kalgara-op08-art.png", first: "47.2%", second: "31.6%" },
	{ label: "Koby", code: "OP11-001", art: "/assets/leader-art/koby-op11-art.png", first: "58.6%", second: "54.3%" },
	{ label: "Enel", code: "OP05-098", art: "/assets/leader-art/enel-op05-art.png", first: "66.4%", second: "72.8%" },
	{ label: "Jewelry Bonney", code: "OP07-019", art: "/assets/leader-art/bonney-op07-art.png", first: "42.9%", second: "43.2%" },
	{ label: "Gol.D.Roger", code: "OP13-003", art: "/assets/leader-art/roger-op13-art.png", first: "38.5%", second: "41%" },
	{ label: "Boa Hancock", code: "OP14-041", art: "/assets/leader-art/hancock-op14-art.png", first: "48.6%", second: "50%" },
	{ label: "Imu", code: "OP13-079", art: "/assets/leader-art/imu-op13-art.png", first: "42.9%", second: "79.6%" },
	{ label: "Sabo", code: "OP13-004", art: "/assets/leader-art/sabo-op13-art.png", first: "48.1%", second: "69%" },
	{ label: "Krieg", code: "OP15-001", art: "/assets/leader-art/op15-001-art.png", first: "41.3%", second: "50.8%" },
	{ label: "Monkey D. Luffy", code: "ST29-001", art: "/assets/leader-art/luffy-st29-art.png", first: "48.3%", second: "53%" },
	{ label: "Shanks", code: "OP09-001", art: "/assets/leader-art/shanks-op09-art.png", first: "75%", second: "68.2%" },
	{ label: "Nefeltari Vivi", code: "EB03-001", art: "/assets/leader-art/eb03-001-art.png", first: "57%", second: "56.1%" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero meta-article-hero">
		<div class="container article-hero-grid">
			<div>
				<span class="hero-badge">Meta Article</span>
				<h1>Monkey.D.Luffy OP15 Stats in OP15 Format</h1>
				<div class="article-leader-hero">
					<img src={leaderHeroArt} alt="Monkey.D.Luffy OP15 leader art" loading="eager" />
				</div>
				<p class="article-kicker">
					This page focuses on Yellow Monkey D. Luffy stats in the OP15 format.
				</p>
				<p>
					If you're looking for a leader who can protect its board while steadily recovering life through card
					effects, OP15 Yellow Luffy is a strong contender. Built around board protection, life gain, and
					explosive finishing potential, the deck leverages its leader ability to keep key characters in play
					while setting up for powerful late-game swings through high-impact threats.
				</p>
				<p>
					For the full list, mulligan plan, curve reference, and matchup notes, see the
					<a href={deckGuideHref}> Monkey.D.Luffy OP15 deck guide</a>.
				</p>
			</div>
			<div class="article-hero-side">
				<div class="hero-summary-card">
					<div class="hero-summary-label">Format</div>
					<strong>OP15</strong>
					<div class="hero-summary-divider"></div>
					<div class="hero-summary-label">Source Sample</div>
					<strong>{summary.totalGames} Games</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container stats-stack">
			<article class="stats-panel">
				<div class="section-header">
					<div>
						<h2>1st / 2nd Win Rate Stats</h2>
						<p>
							How does OP15 Yellow Luffy perform going 1st vs. 2nd? These win rate stats break down how turn
							order affects Luffy's gameplay, which is crucial when you're deciding how to approach specific
							matchups.
						</p>
					</div>
				</div>

				<div class="summary-metrics">
					<div class="summary-metric">
						<span class="summary-label">Total Games</span>
						<strong>{summary.totalGames}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">Winrate</span>
						<strong>{summary.winRate}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">W / L</span>
						<strong class="wl-stat">
							<span class="wl-win">{summary.wins}</span>/<span class="wl-loss">{summary.losses}</span>
						</strong>
					</div>
				</div>

				<div class="turn-order-grid">
					{featuredTurnOrderStats.map((entry) => (
						<div class="turn-order-card">
							<div class="leader-art-frame">
								<img src={entry.art} alt={`${entry.label} leader art`} loading="lazy" />
							</div>
							<div class="turn-order-meta">
								<div class="turn-order-name">{entry.label}</div>
								<div class="turn-order-code">{entry.code}</div>
							</div>
							<div class="turn-order-split">
								<div class={`turn-rate ${getRateTone(entry.first)}`}>
									<span class="turn-label">1st</span>
									<strong>{entry.first}</strong>
								</div>
								<div class={`turn-rate ${getRateTone(entry.second)}`}>
									<span class="turn-label">2nd</span>
									<strong>{entry.second}</strong>
								</div>
							</div>
						</div>
					))}
				</div>
			</article>
		</div>
	</section>
</MainLayout>

<style>
	.meta-article-hero {
		padding-bottom: 34px;
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) 260px;
		gap: 1.5rem;
		align-items: start;
	}

	.article-kicker {
		color: var(--text-200);
		font-weight: 600;
	}

	.article-kicker a {
		color: var(--accent);
	}

	.meta-article-hero p a {
		color: var(--accent);
	}

	.article-leader-hero {
		margin: 1.15rem 0 1.1rem;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at left, rgba(255, 107, 61, 0.2), transparent 36%),
			radial-gradient(circle at right, rgba(255, 159, 26, 0.16), transparent 38%),
			rgba(8, 11, 19, 0.96);
		box-shadow: var(--shadow);
	}

	.article-leader-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 3.2 / 1;
		object-fit: cover;
		object-position: 76% 72%;
	}

	.hero-summary-card {
		background:
			radial-gradient(circle at top left, rgba(250, 204, 21, 0.24), transparent 46%),
			radial-gradient(circle at top right, rgba(255, 120, 52, 0.24), transparent 44%),
			linear-gradient(135deg, rgba(250, 204, 21, 0.12), rgba(255, 120, 52, 0.1) 58%, rgba(12, 17, 30, 0.94));
		border: 1px solid rgba(255, 208, 84, 0.2);
		border-radius: 20px;
		padding: 1rem 1.1rem;
		display: grid;
		gap: 0.45rem;
		box-shadow: var(--shadow);
	}

	.hero-summary-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.hero-summary-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.08);
		margin: 0.2rem 0 0.15rem;
	}

	.stats-section {
		padding: 0 0 56px;
	}

	.stats-stack {
		display: grid;
		gap: 1.2rem;
	}

	.stats-panel {
		background: rgba(10, 14, 24, 0.82);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 22px;
		padding: 1.25rem;
		display: grid;
		gap: 1rem;
	}

	.section-header h2 {
		margin-bottom: 0.55rem;
	}

	.section-header p {
		margin: 0;
		max-width: 640px;
		color: var(--text-200);
	}

	.summary-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.summary-metric {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.95rem 0.9rem;
		display: grid;
		gap: 0.3rem;
	}

	.summary-label {
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #8fb3ff;
	}

	.summary-metric strong {
		font-size: 1rem;
	}

	.wl-stat {
		display: inline-flex;
		gap: 0;
		align-items: baseline;
	}

	.wl-win {
		color: #86efac;
	}

	.wl-loss {
		color: #fca5a5;
	}

	.turn-order-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.85rem;
	}

	.turn-order-card {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.85rem;
		display: grid;
		gap: 0.7rem;
	}

	.leader-art-frame img {
		width: 100%;
		aspect-ratio: 1.75 / 1;
		object-fit: cover;
		object-position: center top;
		border-radius: 14px;
		display: block;
	}

	.turn-order-meta {
		display: grid;
		gap: 0.18rem;
	}

	.turn-order-name {
		font-weight: 700;
		line-height: 1.15;
	}

	.turn-order-code {
		font-size: 0.82rem;
		color: #facc15;
	}

	.turn-order-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.turn-rate {
		border-radius: 14px;
		padding: 0.75rem 0.6rem;
		display: grid;
		gap: 0.2rem;
		text-align: center;
	}

	.turn-rate strong {
		font-size: 1.04rem;
	}

	.turn-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.turn-rate-negative {
		background: linear-gradient(180deg, rgba(239, 68, 68, 0.18), rgba(239, 68, 68, 0.05));
		border: 1px solid rgba(239, 68, 68, 0.24);
	}

	.turn-rate-positive {
		background: linear-gradient(180deg, rgba(34, 197, 94, 0.18), rgba(34, 197, 94, 0.05));
		border: 1px solid rgba(34, 197, 94, 0.24);
	}

	.turn-rate-neutral {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	@media (max-width: 900px) {
		.article-hero-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.article-leader-hero {
			margin: 0.95rem 0 1rem;
			border-radius: 16px;
		}

		.article-leader-hero img {
			aspect-ratio: 1.85 / 1;
			object-position: 50% 18%;
		}

		.summary-metrics {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.summary-metric {
			padding: 0.8rem 0.65rem;
		}

		.summary-label {
			font-size: 0.62rem;
		}

		.summary-metric strong {
			font-size: 0.88rem;
			line-height: 1.15;
		}

		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
