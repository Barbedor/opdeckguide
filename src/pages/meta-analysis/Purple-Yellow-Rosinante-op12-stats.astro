---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "OP12 Purple/Yellow Rosinante stats in OP16 Format";
const description =
	"Turn-order win rate article for Purple/Yellow Rosinante in the OP16 format, with a visual breakdown of first and second player performance.";

const summary = {
	totalGames: "17937",
	winRate: "52.1%",
	wins: "9343",
	losses: "8594",
};

const leaderHeroArt = "/assets/guides/rosinante-op12.png";
const getRateTone = (value: string) => {
	const numeric = Number.parseFloat(value.replace("%", "").trim());
	if (numeric < 50) return "turn-rate-negative";
	if (numeric > 50) return "turn-rate-positive";
	return "turn-rate-neutral";
};

const featuredTurnOrderStats = [
	{ label: "Marshall D. Teach", code: "OP16-080", art: "/assets/guides/Teach-op16.png", first: "47.3%", second: "56.3%" },
	{ label: "Yamato", code: "OP16-079", art: "/assets/guides/yamato-op16.png", first: "60.7%", second: "57.7%" },
	{ label: "Monkey D. Luffy", code: "OP16-022", art: "/assets/guides/Luffy op16.png", first: "57.9%", second: "46%" },
	{ label: "Donquixote Rosinante", code: "OP12-061", art: "/assets/leader-art/rosinante-op12-art.png", first: "60.4%", second: "39.6%" },
	{ label: "Shanks", code: "OP09-001", art: "/assets/leader-art/shanks-op09-art.png", first: "57.6%", second: "59.2%" },
	{ label: "Nami", code: "OP11-041", art: "/assets/leader-art/nami-op11-art.png", first: "48.9%", second: "35.3%" },
	{ label: "Enel", code: "OP15-058", art: "/assets/leader-art/enel-op15-art.png", first: "38.6%", second: "26.7%" },
	{ label: "Portgas D. Ace", code: "OP13-002", art: "/assets/leader-art/ace-op13-art.png", first: "37.1%", second: "37.8%" },
	{ label: "Sengoku", code: "OP16-060", art: "/assets/guides/Sengoku-op16.png", first: "60.1%", second: "32.1%" },
	{ label: "Boa Hancock", code: "OP14-041", art: "/assets/leader-art/hancock-op14-art.png", first: "47.3%", second: "52.7%" },
	{ label: "Lucy", code: "OP15-002", art: "/assets/leader-art/lucy-op15-art.png", first: "65.1%", second: "51.7%" },
	{ label: "Buggy", code: "OP16-041", art: "/assets/guides/Buggy op16.png", first: "61.7%", second: "55.9%" },
	{ label: "Portgas D. Ace", code: "OP16-001", art: "/assets/guides/Ace-op16.png", first: "63.4%", second: "43.1%" },
	{ label: "Dracule Mihawk", code: "OP14-020", art: "/assets/leader-art/mihawk-op14-art.png", first: "62.9%", second: "48.5%" },
	{ label: "Marshall D. Teach", code: "OP09-081", art: "/assets/leader-art/teach-op09-art.png", first: "67.9%", second: "54.2%" },
	{ label: "Monkey D. Luffy", code: "ST30-001", art: "/assets/guides/Luffy-st30.png", first: "44.8%", second: "42.9%" },
	{ label: "Crocodile", code: "OP14-079", art: "/assets/guides/crocodile-op14.png", first: "75.9%", second: "73.2%" },
	{ label: "Monkey D. Luffy", code: "OP13-001", art: "/assets/leader-art/luffy-op13-art.png", first: "50%", second: "50%" },
	{ label: "Monkey D. Luffy", code: "OP15-098", art: "/assets/leader-art/luffy-op15-art.png", first: "67.3%", second: "46.3%" },
	{ label: "Roronoa Zoro", code: "OP12-020", art: "/assets/leader-art/zoro-op12-art.png", first: "68.4%", second: "38.8%" },
	{ label: "Gol.D.Roger", code: "OP13-003", art: "/assets/leader-art/roger-op13-art.png", first: "57.4%", second: "65.4%" },
	{ label: "Jewelry Bonney", code: "OP07-019", art: "/assets/leader-art/bonney-op07-art.png", first: "60%", second: "36.4%" },
	{ label: "Krieg", code: "OP15-001", art: "/assets/leader-art/op15-001-art.png", first: "44.8%", second: "21.4%" },
	{ label: "Jewelry Bonney", code: "EB04-001", art: "/assets/leader-art/eb04-001-art.png", first: "61.8%", second: "57.7%" },
	{ label: "Koby", code: "OP11-001", art: "/assets/leader-art/koby-op11-art.png", first: "62.9%", second: "46.2%" },
	{ label: "Enel", code: "OP05-098", art: "/assets/leader-art/enel-op05-art.png", first: "62.2%", second: "58.8%" },
	{ label: "Monkey D. Luffy", code: "ST29-001", art: "/assets/leader-art/luffy-st29-art.png", first: "42.9%", second: "37%" },
	{ label: "Sabo", code: "OP13-004", art: "/assets/leader-art/sabo-op13-art.png", first: "58.1%", second: "50%" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero meta-article-hero">
		<div class="container article-hero-grid">
			<div>
				<span class="hero-badge">Meta Article</span>
				<h1>OP12 Purple/Yellow Rosinante stats in OP16 Format</h1>
				<div class="article-leader-hero">
					<img src={leaderHeroArt} alt="Purple and Yellow Rosinante leader art" loading="eager" />
				</div>
				<p class="article-kicker">Turn-order stats for Purple/Yellow Rosinante in the OP16 format.</p>
				<p>
					Purple/Yellow Rosinante is a flexible tempo deck that combines steady board development with a
					defensive posture that keeps key turns alive. The list is built around Trafalgar Law Characters and
					rewards clean sequencing, protected pressure, and careful resource management.
				</p>
				<p>
					This article presents a turn-order snapshot for the OP16 format so you can see how Rosinante performs
					when going first or second across the visible matchups. Use it as a fast reference before deciding
					how to approach a specific round.
				</p>
				<p class="deck-guide-link-copy">
					Need the full list and matchup notes? Read the
					<a class="deck-guide-link" href="/deck-guides/rosinante-op12/">Donquixote Rosinante OP12 Deck Guide</a>.
				</p>
			</div>
			<div class="article-hero-side">
				<div class="hero-summary-card">
					<div class="hero-summary-label">Format</div>
					<strong>OP16</strong>
					<div class="hero-summary-divider"></div>
					<div class="hero-summary-label">Source Sample</div>
					<strong>{summary.totalGames} Games</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container stats-stack">
			<article class="stats-panel">
				<div class="section-header">
					<div>
						<h2>1st / 2nd Win Rate Stats</h2>
						<p>
							How does Purple/Yellow Rosinante perform going 1st vs. 2nd? These stats break down how turn order
							affects the deck&apos;s game plan and help frame the matchup data shown in the chart below.
						</p>
					</div>
				</div>

				<div class="summary-metrics">
					<div class="summary-metric">
						<span class="summary-label">Total Games</span>
						<strong>{summary.totalGames}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">Winrate</span>
						<strong>{summary.winRate}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">W / L</span>
						<strong class="wl-stat">
							<span class="wl-win">{summary.wins}</span>/<span class="wl-loss">{summary.losses}</span>
						</strong>
					</div>
				</div>

				<div class="turn-order-grid">
					{featuredTurnOrderStats.map((entry) => (
						<div class="turn-order-card">
							<div class="leader-art-frame">
								{entry.art ? (
									<img src={entry.art} alt={`${entry.label} leader art`} loading="lazy" />
								) : (
									<div class="leader-art-placeholder">{entry.code}</div>
								)}
							</div>
							<div class="turn-order-meta">
								<div class="turn-order-name">{entry.label}</div>
								<div class="turn-order-code">{entry.code}</div>
							</div>
							<div class="turn-order-split">
								<div class={`turn-rate ${getRateTone(entry.first)}`}>
									<span class="turn-label">1st</span>
									<strong>{entry.first}</strong>
								</div>
								<div class={`turn-rate ${getRateTone(entry.second)}`}>
									<span class="turn-label">2nd</span>
									<strong>{entry.second}</strong>
								</div>
							</div>
						</div>
					))}
				</div>

				<div class="analysis-grid">
					<div class="analysis-card">
						<h3>What this chart is for</h3>
						<p>
							This snapshot helps you compare turn order at a glance. When a Rosinante list gets to sequence its
							plays without falling behind, the deck can convert those protected turns into lasting pressure.
						</p>
					</div>
					<div class="analysis-card">
						<h3>How to read it</h3>
						<p>
							Look at the first and second player results together, then use the matchup board to see where the
							deck appears more comfortable and where it needs cleaner navigation.
						</p>
					</div>
				</div>
			</article>
		</div>
	</section>
</MainLayout>

<style>
	.meta-article-hero {
		padding-bottom: 34px;
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) 260px;
		gap: 1.5rem;
		align-items: start;
	}

	.article-kicker {
		color: var(--text-200);
		font-weight: 600;
	}

	.article-leader-hero {
		margin: 1.15rem 0 1.1rem;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at left, rgba(126, 57, 180, 0.24), transparent 36%),
			radial-gradient(circle at right, rgba(255, 211, 87, 0.2), transparent 40%),
			rgba(8, 11, 19, 0.96);
		box-shadow: var(--shadow);
	}

	.article-leader-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 3.2 / 1;
		object-fit: cover;
		object-position: center 28%;
	}

	.hero-summary-card {
		background:
			radial-gradient(circle at top left, rgba(126, 57, 180, 0.36), transparent 46%),
			radial-gradient(circle at top right, rgba(255, 211, 87, 0.28), transparent 44%),
			linear-gradient(135deg, rgba(94, 37, 137, 0.2), rgba(255, 211, 87, 0.12) 58%, rgba(12, 17, 30, 0.94));
		border: 1px solid rgba(255, 211, 87, 0.24);
		border-radius: 20px;
		padding: 1rem 1.1rem;
		display: grid;
		gap: 0.45rem;
		box-shadow: var(--shadow);
	}

	.hero-summary-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.hero-summary-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.08);
		margin: 0.2rem 0 0.15rem;
	}

	.stats-section {
		padding: 0 0 56px;
	}

	.stats-stack {
		display: grid;
		gap: 1.2rem;
	}

	.stats-panel {
		background: rgba(10, 14, 24, 0.82);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 22px;
		padding: 1.25rem;
		display: grid;
		gap: 1rem;
	}

	.section-header h2 {
		margin-bottom: 0.55rem;
	}

	.section-header p {
		margin: 0;
		max-width: 760px;
		color: var(--text-200);
	}

	.summary-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.summary-metric {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.95rem 0.9rem;
		display: grid;
		gap: 0.3rem;
	}

	.summary-label {
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #8fb3ff;
	}

	.summary-metric strong {
		font-size: 1rem;
	}

	.wl-stat {
		display: inline-flex;
		gap: 0.05rem;
		align-items: baseline;
	}

	.wl-win {
		color: #57d18b;
	}

	.wl-loss {
		color: #ff8d6f;
	}

	.turn-order-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}

	.turn-order-card {
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: 0.8rem;
		background: rgba(7, 10, 18, 0.92);
		display: grid;
		gap: 0.7rem;
	}

	.leader-art-frame img,
	.leader-art-placeholder {
		width: 100%;
		aspect-ratio: 1.75 / 1;
		border-radius: 14px;
		display: block;
	}

	.leader-art-frame img {
		object-fit: cover;
		object-position: center top;
	}

	.leader-art-placeholder {
		display: grid;
		place-items: center;
		background:
			radial-gradient(circle at top left, rgba(126, 57, 180, 0.32), transparent 45%),
			radial-gradient(circle at bottom right, rgba(255, 211, 87, 0.22), transparent 48%),
			rgba(12, 17, 30, 0.96);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-100);
		font-weight: 800;
	}

	.turn-order-meta {
		display: grid;
		gap: 0.18rem;
	}

	.turn-order-name {
		font-weight: 800;
		line-height: 1.2;
	}

	.turn-order-code {
		color: #9fb7ff;
		font-size: 0.82rem;
	}

	.turn-order-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.5rem;
	}

	.turn-rate {
		border-radius: 14px;
		padding: 0.55rem 0.45rem;
		display: grid;
		justify-items: center;
		gap: 0.2rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.02);
	}

	.turn-rate-positive {
		background: rgba(19, 76, 52, 0.36);
		border-color: rgba(70, 200, 128, 0.28);
	}

	.turn-rate-negative {
		background: rgba(82, 28, 38, 0.32);
		border-color: rgba(215, 92, 122, 0.24);
	}

	.turn-rate-neutral {
		background: rgba(55, 68, 95, 0.3);
		border-color: rgba(149, 165, 195, 0.18);
	}

	.turn-label {
		color: var(--text-300);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.turn-rate strong {
		color: var(--text-100);
		font-size: 0.94rem;
	}

	.analysis-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.analysis-card {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 1rem;
	}

	.analysis-card h3 {
		margin-bottom: 0.4rem;
		font-size: 1.05rem;
	}

	.analysis-card p {
		margin: 0;
		color: var(--text-200);
	}

	.deck-guide-link-copy {
		margin-top: 0.2rem;
	}

	.deck-guide-link {
		color: #ff8b3d;
		font-weight: 700;
	}

	.deck-guide-link:hover {
		color: #ffb06f;
	}

	@media (max-width: 900px) {
		.article-hero-grid {
			grid-template-columns: 1fr;
		}

		.summary-metrics,
		.analysis-grid {
			grid-template-columns: 1fr;
		}

		.turn-order-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.8rem;
		}

		.turn-order-card {
			padding: 0.7rem;
		}
	}
</style>
