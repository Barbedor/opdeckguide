---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Dracule Mihawk OP14 Stats in OP15 Format";
const description =
	"Green Dracule Mihawk OP15 format stats article covering turn-order win rates in the OP15 field.";

const deckGuideHref = "/deck-guides/dracule-mihawk-op14/";
const getRateTone = (value: string) => {
	const numeric = Number.parseFloat(value.replace("%", "").trim());
	if (numeric < 50) return "turn-rate-negative";
	if (numeric > 50) return "turn-rate-positive";
	return "turn-rate-neutral";
};

const summary = {
	totalGames: "14030",
	winRate: "50.9%",
	wins: "7143",
	losses: "6687",
};

const leaderHeroArt = "/assets/leader-art/mihawk-op14-art.png";

const featuredTurnOrderStats = [
	{ label: "Lucy", code: "OP15-002", art: "/assets/leader-art/lucy-op15-art.png", first: "31.7%", second: "36%" },
	{ label: "Enel", code: "OP15-058", art: "/assets/leader-art/enel-op15-art.png", first: "45.4%", second: "32.8%" },
	{ label: "Nami", code: "OP11-041", art: "/assets/leader-art/nami-op11-art.png", first: "65.6%", second: "51.1%" },
	{ label: "Portgas D. Ace", code: "OP13-002", art: "/assets/leader-art/ace-op13-art.png", first: "58%", second: "65.1%" },
	{ label: "Monkey D. Luffy", code: "OP15-098", art: "/assets/leader-art/luffy-op15-art.png", first: "50%", second: "42.7%" },
	{ label: "Crocodile", code: "OP14-079", art: "/assets/leader-art/crocodile-op14-art.png", first: "47.2%", second: "36.2%" },
	{ label: "Dracule Mihawk", code: "OP14-020", art: "/assets/leader-art/mihawk-op14-art.png", first: "58.3%", second: "41.7%" },
	{ label: "Boa Hancock", code: "OP14-041", art: "/assets/leader-art/hancock-op14-art.png", first: "53.4%", second: "40.9%" },
	{ label: "Gecko Moria", code: "OP14-080", art: "/assets/leader-art/moria-op14-art.png", first: "36.4%", second: "46.7%" },
	{ label: "Marshall D. Teach", code: "OP09-081", art: "/assets/leader-art/teach-op09-art.png", first: "66.2%", second: "54.3%" },
	{ label: "Gol.D.Roger", code: "OP13-003", art: "/assets/leader-art/roger-op13-art.png", first: "65.1%", second: "66.7%" },
	{ label: "Donquixote Doflamingo", code: "OP14-060", art: "/assets/leader-art/doflamingo-op14-art.png", first: "45.4%", second: "28.8%" },
	{ label: "Imu", code: "OP13-079", art: "/assets/leader-art/imu-op13-art.png", first: "68.3%", second: "66.5%" },
	{ label: "Jewelry Bonney", code: "EB04-001", art: "/assets/leader-art/eb04-001-art.png", first: "57.7%", second: "57.5%" },
	{ label: "Kalgara", code: "OP08-098", art: "/assets/leader-art/kalgara-op08-art.png", first: "75.7%", second: "52.9%" },
	{ label: "Monkey D. Luffy", code: "OP13-001", art: "/assets/leader-art/luffy-op13-art.png", first: "66.9%", second: "46.2%" },
	{ label: "Roronoa Zoro", code: "OP12-020", art: "/assets/leader-art/zoro-op12-art.png", first: "62.2%", second: "50.4%" },
	{ label: "Brook", code: "OP15-022", art: "/assets/leader-art/op15-022-art.png", first: "85%", second: "68.8%" },
	{ label: "Donquixote Rosinante", code: "OP12-061", art: "/assets/leader-art/rosinante-op12-art.png", first: "63.2%", second: "30.1%" },
	{ label: "Enel", code: "OP05-098", art: "/assets/leader-art/enel-op05-art.png", first: "39.5%", second: "38.2%" },
	{ label: "Monkey D. Luffy", code: "ST13 Luffy", art: "/assets/guides/luffy st13.png", first: "70.7%", second: "70.3%" },
	{ label: "Monkey D. Luffy", code: "ST29-001", art: "/assets/leader-art/luffy-st29-art.png", first: "42.1%", second: "38.7%" },
	{ label: "Monkey D. Luffy", code: "OP11 Luffy", art: "/assets/guides/luffy op11.png", first: "55.3%", second: "55%" },
	{ label: "Sabo", code: "OP13-004", art: "/assets/leader-art/sabo-op13-art.png", first: "41.9%", second: "41.7%" },
	{ label: "Koby", code: "OP11-001", art: "/assets/leader-art/koby-op11-art.png", first: "35.3%", second: "24.4%" },
	{ label: "Jewelry Bonney", code: "OP07-019", art: "/assets/leader-art/bonney-op07-art.png", first: "58.8%", second: "51.3%" },
	{ label: "Krieg", code: "OP15-001", art: "/assets/leader-art/op15-001-art.png", first: "78.8%", second: "81%" },
	{ label: "Monkey D. Luffy", code: "EB02-010", art: "/assets/leader-art/luffy-eb02-art.png", first: "45.1%", second: "40.5%" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero meta-article-hero">
		<div class="container article-hero-grid">
			<div>
				<span class="hero-badge">Meta Article</span>
				<h1>Dracule Mihawk OP14 Stats in OP15 Format</h1>
				<div class="article-leader-hero">
					<img src={leaderHeroArt} alt="Dracule Mihawk OP14 leader art" loading="eager" />
				</div>
				<p class="article-kicker">
					This page focuses on Green Dracule Mihawk stats in the OP15 format. If you want the full list,
					curve, and matchup plan, the <a href={deckGuideHref}>Dracule Mihawk deck guide</a> is available
					separately.
				</p>
				<p>
					This week, we’re taking a closer look at OP14 Mihawk in the OP15 meta, where the deck has
					started to establish itself as a consistent contender. With a larger sample size from ranked play,
					we now have a more reliable view of how Green Mihawk performs in the current metagame.
				</p>
				<p>
					Green Mihawk continues to shine as a durable and adaptable leader, beginning the game with 5 life
					cards and maintaining pressure through its built-in +1000 power bonus against Slash-attribute
					leaders. What makes the deck especially threatening right now is the consistency of its core engine,
					enabling smooth transitions from early defensive setups into impactful, tempo-swinging turns.
				</p>
				<p>
					In the OP15 environment, Mihawk has proven it’s more than just a fringe option—it’s a
					legitimately competitive choice. The deck rewards players who can think ahead, sequence cleanly, and
					identify the right windows to pivot from control into aggression. Once it finds its footing, Mihawk
					can quickly seize control of the game and punish opponents who fall behind on board or resources.
				</p>
				<p>
					As the meta continues to develop, Green Mihawk is emerging as a leader that commands respect in both
					deckbuilding and in-game decision-making.
				</p>
			</div>
			<div class="article-hero-side">
				<div class="hero-summary-card">
					<div class="hero-summary-label">Format</div>
					<strong>OP15</strong>
					<div class="hero-summary-divider"></div>
					<div class="hero-summary-label">Source Sample</div>
					<strong>{summary.totalGames} Games</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container stats-stack">
			<article class="stats-panel">
				<div class="section-header">
					<div>
						<h2>1st / 2nd Win Rate Stats</h2>
						<p>
							How does Green Mihawk perform going 1st vs. 2nd? These win rate stats break down how turn
							order impacts his tempo-focused game plan—crucial info for matchup prep and sequencing.
						</p>
					</div>
				</div>

				<div class="summary-metrics">
					<div class="summary-metric">
						<span class="summary-label">Total Games</span>
						<strong>{summary.totalGames}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">Winrate</span>
						<strong>{summary.winRate}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">W / L</span>
						<strong class="wl-stat">
							<span class="wl-win">{summary.wins}</span>/<span class="wl-loss">{summary.losses}</span>
						</strong>
					</div>
				</div>

				<div class="turn-order-grid">
					{featuredTurnOrderStats.map((entry) => (
						<div class="turn-order-card">
							<div class="leader-art-frame">
								<img src={entry.art} alt={`${entry.label} leader art`} loading="lazy" />
							</div>
							<div class="turn-order-meta">
								<div class="turn-order-name">{entry.label}</div>
								<div class="turn-order-code">{entry.code}</div>
							</div>
							<div class="turn-order-split">
								<div class={`turn-rate ${getRateTone(entry.first)}`}>
									<span class="turn-label">1st</span>
									<strong>{entry.first}</strong>
								</div>
								<div class={`turn-rate ${getRateTone(entry.second)}`}>
									<span class="turn-label">2nd</span>
									<strong>{entry.second}</strong>
								</div>
							</div>
						</div>
					))}
				</div>
			</article>
		</div>
	</section>
</MainLayout>

<style>
	.meta-article-hero {
		padding-bottom: 34px;
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) 260px;
		gap: 1.5rem;
		align-items: start;
	}

	.article-kicker {
		color: var(--text-200);
		font-weight: 600;
	}

	.article-kicker a {
		color: var(--accent);
	}

	.article-leader-hero {
		margin: 1.15rem 0 1.1rem;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at left, rgba(255, 107, 61, 0.2), transparent 36%),
			radial-gradient(circle at right, rgba(255, 159, 26, 0.16), transparent 38%),
			rgba(8, 11, 19, 0.96);
		box-shadow: var(--shadow);
	}

	.article-leader-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 3.2 / 1;
		object-fit: cover;
		object-position: 52% 44%;
	}

	.hero-summary-card {
		background:
			radial-gradient(circle at top left, rgba(74, 222, 128, 0.18), transparent 44%),
			radial-gradient(circle at top right, rgba(34, 197, 94, 0.16), transparent 42%),
			linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(15, 23, 42, 0.9) 58%, rgba(10, 14, 24, 0.95));
		border: 1px solid rgba(74, 222, 128, 0.18);
		border-radius: 20px;
		padding: 1rem 1.1rem;
		display: grid;
		gap: 0.45rem;
		box-shadow: var(--shadow);
	}

	.hero-summary-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.hero-summary-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.08);
		margin: 0.2rem 0 0.15rem;
	}

	.stats-section {
		padding: 0 0 56px;
	}

	.stats-stack {
		display: grid;
		gap: 1.2rem;
	}

	.stats-panel {
		background: rgba(10, 14, 24, 0.82);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 22px;
		padding: 1.25rem;
		display: grid;
		gap: 1rem;
	}

	.section-header h2 {
		margin-bottom: 0.55rem;
	}

	.section-header p {
		margin: 0;
		max-width: 640px;
		color: var(--text-200);
	}

	.summary-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.summary-metric {
		background: rgba(8, 12, 21, 0.8);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.95rem 1rem;
		display: grid;
		gap: 0.25rem;
	}

	.summary-label {
		font-size: 0.76rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		font-weight: 700;
	}

	.summary-metric strong {
		font-size: 1.08rem;
	}

	.wl-stat {
		display: inline-flex;
		gap: 0;
		align-items: baseline;
	}

	.wl-win {
		color: #86efac;
	}

	.wl-loss {
		color: #fca5a5;
	}

	.turn-order-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
		gap: 1rem;
	}

	.turn-order-card {
		background: linear-gradient(180deg, rgba(17, 24, 39, 0.9), rgba(10, 14, 24, 0.95));
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.8rem;
		display: grid;
		gap: 0.75rem;
	}

	.leader-art-frame img {
		width: 100%;
		aspect-ratio: 1.75 / 1;
		object-fit: cover;
		object-position: center top;
		border-radius: 14px;
		display: block;
	}

	.turn-order-meta {
		display: grid;
		gap: 0.15rem;
	}

	.turn-order-name {
		font-weight: 700;
		font-size: 1rem;
	}

	.turn-order-code {
		font-size: 0.82rem;
		color: var(--accent);
	}

	.turn-order-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.turn-rate {
		border-radius: 14px;
		padding: 0.65rem 0.55rem;
		display: grid;
		gap: 0.2rem;
		text-align: center;
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.turn-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.turn-rate strong {
		font-size: 0.95rem;
	}

	.turn-rate-positive {
		background: linear-gradient(180deg, rgba(20, 83, 45, 0.34), rgba(11, 28, 20, 0.86));
		border-color: rgba(74, 222, 128, 0.2);
	}

	.turn-rate-negative {
		background: linear-gradient(180deg, rgba(88, 28, 43, 0.38), rgba(37, 14, 22, 0.9));
		border-color: rgba(248, 113, 113, 0.18);
	}

	.turn-rate-neutral {
		background: linear-gradient(180deg, rgba(75, 85, 99, 0.35), rgba(17, 24, 39, 0.92));
		border-color: rgba(148, 163, 184, 0.16);
	}

	@media (max-width: 900px) {
		.article-hero-grid {
			grid-template-columns: 1fr;
		}

		.summary-metrics {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.article-leader-hero {
			margin: 0.95rem 0 1rem;
			border-radius: 16px;
		}

		.article-leader-hero img {
			aspect-ratio: 1.85 / 1;
			object-position: 50% 18%;
		}

		.stats-panel {
			padding: 1rem;
		}

		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.75rem;
		}

		.turn-order-card {
			padding: 0.7rem;
			gap: 0.6rem;
		}
	}
</style>
