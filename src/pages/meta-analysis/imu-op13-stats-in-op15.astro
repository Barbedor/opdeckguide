---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Imu OP13 Stats in OP15 Format";
const description = "Black Imu OP15 format stats article covering turn-order win rates.";

const getRateTone = (value: string) => {
	const numeric = Number.parseFloat(value.replace("%", "").trim());
	if (numeric < 50) return "turn-rate-negative";
	if (numeric > 50) return "turn-rate-positive";
	return "turn-rate-neutral";
};

const summary = {
	totalGames: "7073",
	winRate: "52.2%",
	wins: "3695",
	losses: "3378",
};

const leaderHeroArt = "/assets/leader-art/imu-op13-art.png";

const featuredTurnOrderStats = [
	{ label: "Enel", code: "OP15-058", art: "/assets/leader-art/enel-op15-art.png", first: "33.1%", second: "51.3%" },
	{ label: "Nami", code: "OP11-041", art: "/assets/leader-art/nami-op11-art.png", first: "49.4%", second: "63.6%" },
	{ label: "Lucy", code: "OP15-002", art: "/assets/leader-art/lucy-op15-art.png", first: "26%", second: "32.5%" },
	{ label: "Portgas D. Ace", code: "OP13-002", art: "/assets/leader-art/ace-op13-art.png", first: "32.1%", second: "100%" },
	{ label: "Monkey D. Luffy", code: "OP15-098", art: "/assets/leader-art/luffy-op15-art.png", first: "20.4%", second: "47.8%" },
	{ label: "Dracule Mihawk", code: "OP14-020", art: "/assets/leader-art/mihawk-op14-art.png", first: "41.5%", second: "74.2%" },
	{ label: "Gecko Moria", code: "OP14-080", art: "/assets/leader-art/moria-op14-art.png", first: "65.6%", second: "66.7%" },
	{ label: "Monkey D. Luffy", code: "OP13-001", art: "/assets/leader-art/luffy-op13-art.png", first: "48.5%", second: "72.2%" },
	{ label: "Gol.D.Roger", code: "OP13-003", art: "/assets/leader-art/roger-op13-art.png", first: "31.3%", second: "63.6%" },
	{ label: "Enel", code: "OP05-098", art: "/assets/leader-art/enel-op05-art.png", first: "65.9%", second: "N/A" },
	{ label: "Marshall D. Teach", code: "OP09-081", art: "/assets/leader-art/teach-op09-art.png", first: "51.2%", second: "100%" },
	{ label: "Roronoa Zoro", code: "OP12-020", art: "/assets/leader-art/zoro-op12-art.png", first: "45%", second: "71.4%" },
	{ label: "Jewelry Bonney", code: "EB04-001", art: "/assets/leader-art/eb04-001-art.png", first: "60%", second: "57.1%" },
	{ label: "Boa Hancock", code: "OP14-041", art: "/assets/leader-art/hancock-op14-art.png", first: "44.2%", second: "100%" },
	{ label: "Monkey D. Luffy", code: "ST29-001", art: "/assets/leader-art/luffy-st29-art.png", first: "55%", second: "72.7%" },
	{ label: "Donquixote Rosinante", code: "OP12-061", art: "/assets/leader-art/rosinante-op12-art.png", first: "23.1%", second: "37.5%" },
	{ label: "Jinbe", code: "OP14-040", art: "/assets/leader-art/jinbe-op14-art.png", first: "36.8%", second: "0%" },
	{ label: "Crocodile", code: "OP14-079", art: "/assets/leader-art/crocodile-op14-art.png", first: "18.2%", second: "0%" },
	{ label: "Jewelry Bonney", code: "OP07-019", art: "/assets/leader-art/bonney-op07-art.png", first: "64.7%", second: "100%" },
	{ label: "Sabo", code: "OP13-004", art: "/assets/leader-art/sabo-op13-art.png", first: "31.8%", second: "N/A" },
	{ label: "Nefeltari Vivi", code: "EB03-001", art: "/assets/leader-art/eb03-001-art.png", first: "50%", second: "57.1%" },
	{ label: "Nico Robin", code: "P-009", art: "/assets/guides/Nico-Robin-op09.png", first: "55.6%", second: "100%" },
	{ label: "Brook", code: "OP15-022", art: "/assets/leader-art/op15-022-art.png", first: "18.2%", second: "100%" },
	{ label: "Krieg", code: "OP15-001", art: "/assets/leader-art/op15-001-art.png", first: "40%", second: "50%" },
	{ label: "Kalgara", code: "OP08-098", art: "/assets/leader-art/kalgara-op08-art.png", first: "28.6%", second: "50%" },
	{ label: "Monkey D. Luffy", code: "EB02-010", art: "/assets/leader-art/luffy-eb02-art.png", first: "57.1%", second: "100%" },
	{ label: "Shanks", code: "OP09-001", art: "/assets/leader-art/shanks-op09-art.png", first: "71.4%", second: "66.7%" },
	{ label: "Sabo", code: "ST13-001", art: "/assets/guides/Sabo-st13.png", first: "22.2%", second: "100%" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero meta-article-hero">
		<div class="container article-hero-grid">
			<div>
				<span class="hero-badge">Meta Article</span>
				<h1>Imu OP13 Stats in OP15 Format</h1>
				<div class="article-leader-hero">
					<img src={leaderHeroArt} alt="Imu OP13 leader art" loading="eager" />
				</div>
				<p class="article-kicker">This page focuses on Black Imu stats in the OP15 format.</p>
				<p>
					Black Imu is a control-focused powerhouse built around suffocating board control and steady value
					generation. Imu excels through calculated removal, smart resource cycling, and the ability to reset
					tempo whenever needed.
				</p>
				<p>
					With a leader skill that transforms discarded cards into meaningful advantages, this deck rewards
					patience and precision, slowly grinding opponents down before closing the game with crushing late-game
					pressure.
				</p>
			</div>
			<div class="article-hero-side">
				<div class="hero-summary-card">
					<div class="hero-summary-label">Format</div>
					<strong>OP15</strong>
					<div class="hero-summary-divider"></div>
					<div class="hero-summary-label">Source Sample</div>
					<strong>{summary.totalGames} Games</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-section">
		<div class="container stats-stack">
			<article class="stats-panel">
				<div class="section-header">
					<div>
						<h2>1st / 2nd Win Rate Stats</h2>
						<p>
							How does Imu perform going 1st vs. 2nd? These win rate stats break down how turn order affects
							Imu&apos;s gameplay, crucial insight for deciding how to approach specific matchups.
						</p>
					</div>
				</div>

				<div class="summary-metrics">
					<div class="summary-metric">
						<span class="summary-label">Total Games</span>
						<strong>{summary.totalGames}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">Winrate</span>
						<strong>{summary.winRate}</strong>
					</div>
					<div class="summary-metric">
						<span class="summary-label">W / L</span>
						<strong class="wl-stat">
							<span class="wl-win">{summary.wins}</span>/<span class="wl-loss">{summary.losses}</span>
						</strong>
					</div>
				</div>

				<div class="turn-order-grid">
					{featuredTurnOrderStats.map((entry) => (
						<div class="turn-order-card">
							<div class="leader-art-frame">
								<img src={entry.art} alt={`${entry.label} leader art`} loading="lazy" />
							</div>
							<div class="turn-order-meta">
								<div class="turn-order-name">{entry.label}</div>
								<div class="turn-order-code">{entry.code}</div>
							</div>
							<div class="turn-order-split">
								<div class={`turn-rate ${getRateTone(entry.first)}`}>
									<span class="turn-label">1st</span>
									<strong>{entry.first}</strong>
								</div>
								<div class={`turn-rate ${getRateTone(entry.second)}`}>
									<span class="turn-label">2nd</span>
									<strong>{entry.second}</strong>
								</div>
							</div>
						</div>
					))}
				</div>
			</article>
		</div>
	</section>
</MainLayout>

<style>
	.meta-article-hero {
		padding-bottom: 34px;
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) 260px;
		gap: 1.5rem;
		align-items: start;
	}

	.article-kicker {
		color: var(--text-200);
		font-weight: 600;
	}

	.article-leader-hero {
		margin: 1.15rem 0 1.1rem;
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at left, rgba(255, 232, 87, 0.18), transparent 36%),
			radial-gradient(circle at right, rgba(255, 199, 0, 0.18), transparent 40%),
			rgba(8, 11, 19, 0.96);
		box-shadow: var(--shadow);
	}

	.article-leader-hero img {
		display: block;
		width: 100%;
		aspect-ratio: 3.2 / 1;
		object-fit: cover;
		object-position: center 28%;
	}

	.hero-summary-card {
		background:
			radial-gradient(circle at top left, rgba(255, 224, 102, 0.18), transparent 48%),
			radial-gradient(circle at top right, rgba(255, 197, 61, 0.16), transparent 46%),
			linear-gradient(135deg, rgba(255, 223, 93, 0.08), rgba(255, 189, 46, 0.08) 58%, rgba(12, 17, 30, 0.94));
		border: 1px solid rgba(255, 209, 92, 0.18);
		border-radius: 20px;
		padding: 1rem 1.1rem;
		display: grid;
		gap: 0.45rem;
		box-shadow: var(--shadow);
	}

	.hero-summary-label {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-300);
	}

	.hero-summary-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.08);
		margin: 0.2rem 0 0.15rem;
	}

	.stats-section {
		padding: 0 0 56px;
	}

	.stats-stack {
		display: grid;
		gap: 1.2rem;
	}

	.stats-panel {
		background: rgba(10, 14, 24, 0.82);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 22px;
		padding: 1.25rem;
		display: grid;
		gap: 1rem;
	}

	.section-header h2 {
		margin-bottom: 0.55rem;
	}

	.section-header p {
		margin: 0;
		max-width: 640px;
		color: var(--text-200);
	}

	.summary-metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.summary-metric {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.95rem 0.9rem;
		display: grid;
		gap: 0.3rem;
	}

	.summary-label {
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #8fb3ff;
	}

	.summary-metric strong {
		font-size: 1rem;
	}

	.wl-stat {
		display: inline-flex;
		gap: 0;
		align-items: baseline;
	}

	.wl-win {
		color: #86efac;
	}

	.wl-loss {
		color: #fca5a5;
	}

	.turn-order-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.85rem;
	}

	.turn-order-card {
		background: rgba(8, 11, 19, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		padding: 0.85rem;
		display: grid;
		gap: 0.7rem;
	}

	.leader-art-frame img {
		width: 100%;
		aspect-ratio: 1.75 / 1;
		object-fit: cover;
		object-position: center top;
		border-radius: 14px;
		display: block;
	}

	.turn-order-meta {
		display: grid;
		gap: 0.18rem;
	}

	.turn-order-name {
		font-weight: 700;
		line-height: 1.15;
	}

	.turn-order-code {
		font-size: 0.82rem;
		color: #8fb3ff;
	}

	.turn-order-split {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.turn-rate {
		border-radius: 14px;
		padding: 0.7rem 0.65rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		display: grid;
		gap: 0.2rem;
	}

	.turn-rate-positive {
		background: rgba(34, 197, 94, 0.12);
	}

	.turn-rate-negative {
		background: rgba(239, 68, 68, 0.12);
	}

	.turn-rate-neutral {
		background: rgba(148, 163, 184, 0.12);
	}

	.turn-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(234, 238, 255, 0.7);
	}

	.turn-rate strong {
		font-size: 1rem;
	}

	@media (max-width: 900px) {
		.article-hero-grid {
			grid-template-columns: 1fr;
		}

		.article-hero-side {
			order: -1;
		}
	}

	@media (max-width: 720px) {
		.meta-article-hero {
			padding-bottom: 22px;
		}

		.stats-panel {
			padding: 1rem;
			border-radius: 18px;
		}

		.summary-metrics {
			grid-template-columns: 1fr;
		}

		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.75rem;
		}

		.turn-order-card {
			padding: 0.75rem;
			border-radius: 16px;
		}

		.leader-art-frame img {
			border-radius: 12px;
		}
	}

	@media (max-width: 520px) {
		.turn-order-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
