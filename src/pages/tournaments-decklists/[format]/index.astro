---
import MainLayout from "../../../layouts/MainLayout.astro";
import TournamentDecklistsView from "../../../components/TournamentDecklistsView.astro";
import {
	getTournamentEntriesByFormat,
	tournamentFormats,
} from "../../../lib/tournamentDecklists";

export const getStaticPaths = () =>
	tournamentFormats
		.filter((format) => format.slug !== "op16-east")
		.map((format) => ({
		params: { format: format.slug },
		props: { format },
	}));

const { format } = Astro.props;
const entries = getTournamentEntriesByFormat(format.slug);
const title = "One Piece TCG Tournament Decklists OP16 | East and West Winners";
const description =
	"Browse winning One Piece TCG tournament decklists for OP16 across East and West formats. Track top leaders, recent results, and the latest competitive builds.";
---

<MainLayout title={title} description={description}>
	<TournamentDecklistsView
		currentFormat={format.slug}
		entries={entries}
		formatConfig={format}
		heroTitle="One Piece TCG OP16 Tournament Decklists"
		heroIntro="Track winning One Piece TCG tournament decklists for the OP16 format across East and West. Browse recent results, top-performing leaders, and the competitive builds shaping the current meta."
		showSeoContent={true}
	/>
</MainLayout>
