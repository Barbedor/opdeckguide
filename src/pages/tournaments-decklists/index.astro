---
import MainLayout from "../../layouts/MainLayout.astro";
import TournamentDecklistsView from "../../components/TournamentDecklistsView.astro";
import {
	getTournamentEntriesByFormat,
	tournamentFormats,
} from "../../lib/tournamentDecklists";

const defaultFormat = "op16-east";
const formatConfig = tournamentFormats.find((format) => format.slug === defaultFormat);

const title = "One Piece TCG Tournament Decklists | Winning Decks by Eastern (OP16) and Western (OP16)";
const description =
	"Updated OPTCG meta decklists and winning tournament decklists for Eastern (OP16) and Western (OP16) formats.";
---

<MainLayout title={title} description={description}>
	<TournamentDecklistsView
		currentFormat={defaultFormat}
		entries={getTournamentEntriesByFormat(defaultFormat)}
		formatConfig={formatConfig}
		heroTitle="One Piece TCG Tournament Decklists OP16"
		heroIntro="Recent tournament-winning decklists for Eastern (OP16) and Western (OP16) formats."
		showSeoContent={true}
	/>
</MainLayout>
