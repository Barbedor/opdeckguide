---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import { visibleDeckGuides } from "../lib/guides";

const title = "One Piece Card Game Deck Guides & Meta Analysis";
const description = "OPDeckGuide delivers competitive One Piece Card Game deck guides, matchup breakdowns, and meta analysis with a strong focus on the OP16 format, current tournament trends, and practical strategy insights.";
const latestDeckGuide = visibleDeckGuides[0];
const featuredDeckGuides = visibleDeckGuides.slice(0, 3);
---

<MainLayout title={title} description={description}>
	<Hero
		title="One Piece Card Game Deck Guides & Meta Analysis"
		description="Build smarter lists, understand the field, and sharpen your matchup plans with focused, English-language strategy content for the One Piece Card Game."
		primaryHref="/deck-guides/"
		primaryLabel="Explore Deck Guides"
		secondaryHref="/meta-analysis/"
		secondaryLabel="See Meta Analysis"
		newsHref={latestDeckGuide.href}
		newsLabel="New"
		newsTitle={latestDeckGuide.title}
		newsImageSrc={latestDeckGuide.imageSrc}
		newsImageAlt={latestDeckGuide.imageAlt}
	/>

	<section class="list-section">
		<div class="container">
			<h2>Welcome to OPDeckGuide</h2>
			<p>
				Your hub for One Piece Card Game deck guides, matchup plans, and meta updates. Start with the newest
				content below, then dive deeper with the sections you need most.
			</p>
		</div>
	</section>

	<Section
		title="Deck Guides"
		description="Leader-specific game plans, sample lists, upgrade paths, and play patterns for the most relevant archetypes."
		linkHref="/deck-guides/"
		linkLabel="Browse all deck guides"
		gridClass="grid-3 mobile-double-grid"
	>
		{
			featuredDeckGuides.map((guide) => (
				<Card
					eyebrow={guide.formatLabel}
					title={guide.title}
					description={guide.summary}
					imageSrc={guide.imageSrc}
					imageAlt={guide.imageAlt}
					href={guide.href}
				/>
			))
		}
	</Section>

	<Section
		title="Beginner Guides"
		description="Start strong with clear learning paths, essential rules knowledge, and smart first upgrades."
		linkHref="/beginner-guides/"
		linkLabel="Start learning"
		gridClass="grid-3 mobile-beginner-double-grid"
	>
		<Card
			eyebrow="Playstyle"
			title="How to Choose a Deck?"
			description="A quick guide to the main color identities so you can find the deck style that fits you."
			imageSrc="/assets/beginner-guides/how-to-choose-a-deck.svg"
			imageAlt="How to choose a deck guide cover"
			href="/beginner-guides/how-to-choose-a-deck/"
		/>
		<Card
			eyebrow="Rules"
			title="Complete One Piece TCG Rules"
			description="The full, official rule reference for every action, phase, and timing window."
			imageSrc="/assets/beginner-guides/complete-rules.png"
			imageAlt="Complete rules guide cover"
			href="/beginner-guides/complete-rules/"
		/>
		<Card
			eyebrow="Rules"
			title="Simplified Rules Overview"
			description="A clear, beginner-friendly summary of the rules to get you playing fast."
			imageSrc="/assets/beginner-guides/simplified-rules.png"
			imageAlt="Simplified rules guide cover"
			href="/beginner-guides/simplified-rules/"
		/>
	</Section>

	<section class="seo-block">
		<div class="container">
			<h2>About OPDeckGuide</h2>
			<p>
				OPDeckGuide is a strategy hub for competitive and aspiring One Piece Card Game players who want clear
				answers about what wins, why it wins, and how to pilot it. Every guide is written to help you make
				confident decisions at locals, online events, and major tournaments. We focus on deck structure, tempo
				planning, and sequencing so you can translate theory into clean gameplay.
			</p>
			<p>
				Use the <a href="/deck-guides/">Deck Guides</a> area to find leader-specific plans, mulligan priorities,
				and upgrade paths. Visit <a href="/meta-analysis/">Meta Analysis</a> for weekly trends, format shifts,
				and counterplay concepts. New to the game? Start with
				<a href="/beginner-guides/">Beginner Guides</a> for product advice, learning paths, and budget builds.
			</p>
			<p>
				This homepage is designed to grow with future articles and deck techs. Expect clean summaries, sharp
				recommendations, and performance-first pages that load fast on mobile. The goal is simple: help you
				read the room, build the right list, and play with purpose.
			</p>
		</div>
	</section>
</MainLayout>

<style>
	@media (max-width: 640px) {
		:global(.card-grid.mobile-double-grid) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.65rem;
		}

		:global(.card-grid.mobile-double-grid .card) {
			padding: 0.8rem 0.55rem;
			gap: 0.55rem;
			min-height: 0;
		}

		:global(.card-grid.mobile-double-grid .card-eyebrow) {
			font-size: 0.62rem;
			letter-spacing: 0.04em;
		}

		:global(.card-grid.mobile-double-grid .card-icon img) {
			width: min(84px, 78%);
			border-radius: 10px;
		}

		:global(.card-grid.mobile-double-grid .card h3) {
			font-size: 0.92rem;
			line-height: 1.2;
		}

		:global(.card-grid.mobile-double-grid .card p) {
			font-size: 0.75rem;
			line-height: 1.4;
		}

		:global(.card-grid.mobile-double-grid .card:nth-child(n + 3)) {
			display: none;
		}

		:global(.card-grid.mobile-beginner-double-grid) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 0.55rem;
		}

		:global(.card-grid.mobile-beginner-double-grid .card) {
			padding: 0.8rem 0.5rem;
			gap: 0.55rem;
			min-height: 0;
		}

		:global(.card-grid.mobile-beginner-double-grid .card-eyebrow) {
			font-size: 0.62rem;
			letter-spacing: 0.04em;
		}

		:global(.card-grid.mobile-beginner-double-grid .card-icon img) {
			width: min(78px, 80%);
			border-radius: 10px;
		}

		:global(.card-grid.mobile-beginner-double-grid .card h3) {
			font-size: 0.9rem;
			line-height: 1.2;
		}

		:global(.card-grid.mobile-beginner-double-grid .card p) {
			font-size: 0.74rem;
			line-height: 1.35;
		}

		:global(.card-grid.mobile-beginner-double-grid .card:nth-child(n + 3)) {
			display: none;
		}

		:global(.card-grid.mobile-triple-grid) {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.45rem;
		}

		:global(.card-grid.mobile-triple-grid .card) {
			padding: 0.75rem 0.45rem;
			gap: 0.5rem;
			min-height: 0;
		}

		:global(.card-grid.mobile-triple-grid .card-eyebrow) {
			font-size: 0.58rem;
			letter-spacing: 0.04em;
		}

		:global(.card-grid.mobile-triple-grid .card-icon img) {
			width: min(72px, 82%);
			border-radius: 10px;
		}

		:global(.card-grid.mobile-triple-grid .card h3) {
			font-size: 0.85rem;
			line-height: 1.2;
		}

		:global(.card-grid.mobile-triple-grid .card p) {
			font-size: 0.72rem;
			line-height: 1.35;
		}
	}
</style>
