---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";

const title = "One Piece Card Game Deck Guides & Meta Analysis";
const description = "OPDeckGuide delivers competitive One Piece Card Game deck guides, matchup breakdowns, and meta analysis with a focus on clean execution, reliable fundamentals, and tournament-ready insights.";
---

<MainLayout title={title} description={description}>
	<Hero
		title="One Piece Card Game Deck Guides & Meta Analysis"
		description="Build smarter lists, understand the field, and sharpen your matchup plans with focused, English-language strategy content for the One Piece Card Game."
		primaryHref="/deck-guides"
		primaryLabel="Explore Deck Guides"
		secondaryHref="/meta-analysis"
		secondaryLabel="See Meta Analysis"
	/>

	<section class="list-section">
		<div class="container">
			<h2>Welcome to OPDeckGuide</h2>
			<p>
				Your hub for One Piece Card Game deck guides, matchup plans, and meta updates. Start with the newest
				content below, then dive deeper with the sections you need most.
			</p>
		</div>
	</section>

	<Section
		title="Deck Guides"
		description="Leader-specific game plans, sample lists, upgrade paths, and play patterns for the most relevant archetypes."
		linkHref="/deck-guides"
		linkLabel="Browse all deck guides"
	>
		<Card
			eyebrow="New"
			title="Latest Deck Guide"
			description="Freshly published leader guide focused on core plan, mulligan priorities, and upgrade options."
			href="/deck-guides"
		/>
		<Card
			eyebrow="New"
			title="Latest Strategy Breakdown"
			description="Newly added write-up with the essential plan, key turns, and matchup checkpoints."
			href="/deck-guides"
		/>
		<Card
			eyebrow="New"
			title="Latest Upgrade Path"
			description="The newest update on priority upgrades and flexible tech slots for competitive play."
			href="/deck-guides"
		/>
	</Section>

	<Section
		title="Meta Analysis"
		description="Snapshot the current field, identify climbing leaders, and find the answers that matter most."
		linkHref="/meta-analysis"
		linkLabel="View meta analysis"
	>
		<Card
			eyebrow="New"
			title="Latest Meta Snapshot"
			description="A quick read on what is winning now, why it matters, and how the field is shifting."
			href="/meta-analysis"
		/>
		<Card
			eyebrow="New"
			title="Latest Format Trend"
			description="New analysis on the most important trend impacting deckbuilding and tournament results."
			href="/meta-analysis"
		/>
		<Card
			eyebrow="New"
			title="Latest Tech Watch"
			description="Recently added notes on flexible inclusions and counterplay options for the current field."
			href="/meta-analysis"
		/>
	</Section>

	<Section
		title="Matchups"
		description="Understand win conditions, key turns, and pressure points for the matchups that decide events."
		linkHref="/matchups"
		linkLabel="Explore matchups"
	>
		<Card
			eyebrow="New"
			title="Latest Matchup Plan"
			description="A fresh guide that outlines win conditions, key turns, and swing points."
			href="/matchups"
		/>
		<Card
			eyebrow="New"
			title="Latest Decision Points"
			description="Newly posted breakdown of critical choices and timing windows."
			href="/matchups"
		/>
		<Card
			eyebrow="New"
			title="Latest Tech Guide"
			description="Updated notes on flexible tech options and how they affect key pairings."
			href="/matchups"
		/>
	</Section>

	<Section
		title="Beginner Guides"
		description="Start strong with clear learning paths, essential rules knowledge, and smart first upgrades."
		linkHref="/beginner-guides"
		linkLabel="Start learning"
	>
		<Card
			eyebrow="Rules"
			title="Complete One Piece TCG Rules"
			description="The full, official rule reference for every action, phase, and timing window."
			href="/beginner-guides/complete-rules"
		/>
		<Card
			eyebrow="Rules"
			title="Simplified Rules Overview"
			description="A clear, beginner-friendly summary of the rules to get you playing fast."
			href="/beginner-guides/simplified-rules"
		/>
	</Section>

	<section class="seo-block">
		<div class="container">
			<h2>About OPDeckGuide</h2>
			<p>
				OPDeckGuide is a strategy hub for competitive and aspiring One Piece Card Game players who want clear
				answers about what wins, why it wins, and how to pilot it. Every guide is written to help you make
				confident decisions at locals, online events, and major tournaments. We focus on deck structure, tempo
				planning, and sequencing so you can translate theory into clean gameplay.
			</p>
			<p>
				Use the <a href="/deck-guides">Deck Guides</a> area to find leader-specific plans, mulligan priorities,
				and upgrade paths. Visit <a href="/meta-analysis">Meta Analysis</a> for weekly trends, format shifts,
				and counterplay concepts. If you are tightening your execution, <a href="/matchups">Matchups</a> breaks
				down win conditions and sideboarding-style tech choices. New to the game? Start with
				<a href="/beginner-guides">Beginner Guides</a> for product advice, learning paths, and budget builds.
			</p>
			<p>
				This homepage is designed to grow with future articles and deck techs. Expect clean summaries, sharp
				recommendations, and performance-first pages that load fast on mobile. The goal is simple: help you
				read the room, build the right list, and play with purpose.
			</p>
		</div>
	</section>
</MainLayout>
