---
import MainLayout from "../../layouts/MainLayout.astro";
import { getExtensions, getCardsForExtension } from "../../lib/cards";

export const getStaticPaths = () => {
	const extensions = getExtensions();
	return extensions.map((extension) => ({
		params: { extension },
	}));
};

const { extension } = Astro.params;
const cards = getCardsForExtension(extension);
const initialBatch = 96;
const initialCards = cards.slice(0, initialBatch);
const remainingCards = cards.slice(initialBatch);
const extensionLabel = extension === "P" ? "Promo" : extension;

const title = `${extensionLabel} Card List | One Piece Card Game`;
const description = `Browse the full ${extensionLabel} card list, search exact card numbers, and open full-size One Piece Card Game previews instantly.`;
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">{extensionLabel}</span>
			<h1>{extensionLabel} Card List</h1>
			<p>
				Every {extensionLabel} card is listed on this page. Open any card for the full-size image, or
				use search if you want to jump straight to an exact card number.
			</p>
			<p class="hero-links">
				Need deck context? Head back to <a href="/deck-guides/">Deck Guides</a>.
			</p>
		</div>
	</section>

	<section class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>{extensionLabel} Cards</h2>
					<p>{cards.length} cards available in this extension.</p>
				</div>
				<a href="/cards-list/">Back to all extensions</a>
			</div>
			<div class="cards-grid" data-card-grid>
				{initialCards.map((card) => (
					<button
						class="card-thumb"
						type="button"
						data-card
						data-full={card.fullUrl}
						data-name={card.code}
					>
						<img loading="lazy" src={card.smallUrl} alt={`${card.code} card`} />
					</button>
				))}
			</div>
			{remainingCards.length > 0 && (
				<div class="load-more">
					<button type="button" class="btn btn-secondary" data-load-more>Load more cards</button>
					<p>{remainingCards.length} more cards available</p>
				</div>
			)}
		</div>
	</section>

	<section class="faq-section">
		<div class="container">
			<div class="section-header faq-header">
				<div>
					<h2>{extensionLabel} FAQ</h2>
					<p>Quick answers for the most common card list questions.</p>
				</div>
			</div>
			<div class="faq-grid">
				<article class="faq-card">
					<h3>Can I browse every {extensionLabel} card here?</h3>
					<p>Yes. This page lists the full {extensionLabel} card pool in one place.</p>
				</article>
				<article class="faq-card">
					<h3>Can I search by exact card number?</h3>
					<p>Yes. Use the global search bar under the menu to jump straight to a code.</p>
				</article>
				<article class="faq-card">
					<h3>Where can I find deck context?</h3>
					<p>Use <a href="/deck-guides/">Deck Guides</a> to see how cards show up in real lists.</p>
				</article>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script define:vars={{ remainingCards }}>
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	const grid = document.querySelector("[data-card-grid]");
	const loadMoreButton = document.querySelector("[data-load-more]");
	let remaining = remainingCards ?? [];
	const batchSize = 96;

	const openModal = (fullUrl, name) => {
		if (!modal || !modalImage) return;
		modalImage.setAttribute("src", fullUrl);
		modalImage.setAttribute("alt", `${name} card`);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	document.addEventListener("click", (event) => {
		const cardButton = event.target.closest("[data-card]");
		if (cardButton) {
			const fullUrl = cardButton.getAttribute("data-full");
			const name = cardButton.getAttribute("data-name");
			if (!fullUrl) return;
			openModal(fullUrl, name);
			return;
		}

		if (event.target === modal) {
			closeModal();
		}
	});

	closeButton?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeModal();
		}
	});

	const appendBatch = () => {
		if (!grid || remaining.length === 0) return;
		const batch = remaining.splice(0, batchSize);
		batch.forEach((card) => {
			const button = document.createElement("button");
			button.type = "button";
			button.className = "card-thumb";
			button.setAttribute("data-card", "");
			button.setAttribute("data-full", card.fullUrl);
			button.setAttribute("data-name", card.code);
			button.addEventListener("click", () => openModal(card.fullUrl, card.code));
			const img = document.createElement("img");
			img.loading = "lazy";
			img.src = card.smallUrl;
			img.alt = `${card.code} card`;
			button.appendChild(img);
			grid.appendChild(button);
		});
		if (remaining.length === 0 && loadMoreButton) {
			loadMoreButton.closest(".load-more")?.remove();
		} else if (loadMoreButton) {
			const note = loadMoreButton.nextElementSibling;
			if (note) {
				note.textContent = `${remaining.length} more cards available`;
			}
		}
	};

	loadMoreButton?.addEventListener("click", appendBatch);
</script>

<style>
	.hero-links {
		margin-top: 1rem;
	}

	.hero-links a {
		color: var(--accent) !important;
		font-weight: 600;
		text-decoration: none;
	}

	.cards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(120px, 120px));
		gap: 0.8rem;
		justify-content: start;
	}

	:global(.card-thumb) {
		padding: 0;
		border-radius: 12px;
		border: none;
		background: transparent;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		cursor: pointer;
		width: 120px;
		max-width: 120px;
	}

	:global(.card-thumb img) {
		width: 100%;
		border-radius: 8px;
	}

	:global(.card-thumb:hover),
	:global(.card-thumb:focus-visible) {
		transform: translateY(-4px);
		box-shadow: var(--shadow);
		outline: none;
	}

	.card-modal {
		position: fixed;
		inset: 0;
		background: rgba(6, 8, 14, 0.85);
		display: none;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		z-index: 40;
	}

	.card-modal.is-open {
		display: flex;
	}

	.card-modal-inner {
		max-width: min(520px, 90vw);
		max-height: 90vh;
		background: rgba(10, 14, 24, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 1rem 1rem 1.5rem;
		position: relative;
		box-shadow: var(--shadow);
	}

	.card-modal-inner img {
		width: 100%;
		max-height: 80vh;
		object-fit: contain;
	}

	.modal-close {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--border);
		color: var(--text-100);
		border-radius: 999px;
		padding: 0.35rem 0.8rem;
		cursor: pointer;
		font-size: 0.85rem;
	}

	.load-more {
		margin-top: 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
		color: var(--text-300);
		font-size: 0.9rem;
	}

	.faq-section {
		padding: 0 0 3.5rem;
	}

	.faq-header {
		margin-bottom: 1rem;
	}

	.faq-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.faq-card {
		padding: 1.1rem 1.15rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.02);
	}

	.faq-card h3 {
		font-size: 1rem;
		margin-bottom: 0.5rem;
	}

	.faq-card p {
		margin: 0;
		color: var(--text-300);
		font-size: 0.96rem;
	}

	@media (max-width: 600px) {
		.hero {
			padding-bottom: 1.5rem;
		}

		.list-section {
			padding-top: 0.75rem;
		}

		.faq-section {
			padding-top: 1.25rem;
			padding-bottom: 2.5rem;
		}

		.cards-grid {
			grid-template-columns: repeat(3, minmax(96px, 96px));
			justify-content: center;
			gap: 0.55rem;
		}

		:global(.card-thumb) {
			width: 96px;
			max-width: 96px;
		}

		.faq-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
