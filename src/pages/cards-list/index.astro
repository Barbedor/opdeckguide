---
import MainLayout from "../../layouts/MainLayout.astro";
import { affiliateCards } from "../../lib/affiliateCards";
import { getExtensionSummaries, hasMetadata } from "../../lib/cards";
import { guideSearchIndex } from "../../lib/guides";

const title = "One Piece Card List | One Piece Card Game";
const description =
	"Browse One Piece Card Game cards by extension, search exact card numbers, and jump from cards to related deck guides from one global hub.";

const metadataAvailable = hasMetadata();

const extensionSummaries = getExtensionSummaries();
const groupForExtension = (value) => {
	const upper = value.toUpperCase();
	if (upper.startsWith("OP")) return "OP";
	if (upper.startsWith("EB")) return "EB";
	if (upper.startsWith("PRB")) return "PRB";
	if (upper.startsWith("ST")) return "ST";
	if (upper === "P") return "Promo";
	return "Other";
};

const groupedExtensions = [];
let lastGroup = null;
for (const item of extensionSummaries) {
	const group = groupForExtension(item.extension);
	if (lastGroup && group !== lastGroup) {
		groupedExtensions.push({ type: "separator", group });
	}
	groupedExtensions.push({ type: "extension", item, group });
	lastGroup = group;
}

const extensionLabel = (value) => (value === "P" ? "Promo" : value);
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">Cards List</span>
			<h1>One Piece Card List</h1>
			<div class="search-results" data-search-results></div>
			<div class="hero-text" data-hero-text>
				<p>
					Browse every set from one hub, open the extension you want to see in full, and use the search
					bar only when you want to jump straight to an exact card number.
				</p>
				<p class="hero-links">
					Need deck context? Head back to <a class="internal-link" href="/deck-guides/">Deck Guides</a>.
				</p>
			</div>
		</div>
	</section>

	<section class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Extensions</h2>
					<p>Choose a set to browse all cards in that extension.</p>
				</div>
			</div>
			<div class="extensions-grid">
				{groupedExtensions.map((entry) =>
					entry.type === "separator" ? (
						<div class="extension-separator">
							<span>{entry.group}</span>
						</div>
					) : (
						<a class="extension-card" href={`/cards-list/${entry.item.extension}/`}>
							<div class="extension-card-header">
								<h3>{extensionLabel(entry.item.extension)}</h3>
								<span>{entry.item.count} cards</span>
							</div>
							<div class="extension-previews">
								{entry.item.previews.map((card) => (
									<img loading="lazy" src={card.smallUrl} alt={`${card.code} card`} />
								))}
							</div>
							<span class="extension-link">Browse extension</span>
						</a>
					)
				)}
			</div>
		</div>
	</section>

	<section class="seo-block">
		<div class="container">
			<h2>About the Cards List</h2>
			<p>
				This hub organizes every set by extension so you can open the exact card pool you want without
				guessing where to start. If you already know a card code, the search bar gets you there faster.
			</p>
			<p>
				Once you have the card or leader you want, <a class="internal-link" href="/deck-guides/">Deck Guides</a> helps you move
				from raw card lookup to actual competitive context.
			</p>
		</div>
	</section>

	<section class="faq-section">
		<div class="container">
			<div class="section-header faq-header">
				<div>
					<h2>Cards List FAQ</h2>
					<p>Quick answers for the most common card search questions.</p>
				</div>
			</div>
			<div class="faq-grid">
				<article class="faq-card">
					<h3>Can I search every set from one page?</h3>
					<p>Yes. Use the global search bar to look up cards, leaders, and guides from one place.</p>
				</article>
				<article class="faq-card">
					<h3>Can I search exact card numbers?</h3>
					<p>Yes. Type the exact code to jump straight to the matching result.</p>
				</article>
				<article class="faq-card">
					<h3>Where can I find deck context?</h3>
					<p>Open <a class="internal-link" href="/deck-guides/">Deck Guides</a> to see how those cards show up in real lists.</p>
				</article>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script define:vars={{ metadataAvailable, guideSearchIndex, affiliateCards }}>
	const searchInput = document.querySelector("[data-global-search]");
	const resultsContainer = document.querySelector("[data-search-results]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	const heroText = document.querySelector("[data-hero-text]");
	let cardIndex = null;
	let isLoadingIndex = false;
	const guideIndex = guideSearchIndex ?? [];

	const colorOrder = ["Red", "Green", "Blue", "Purple", "Yellow", "Black", "Don", "Other"];
	const guideIntentTokens = new Set(["guide", "guides", "deck", "decks", "leader", "leaders", "article", "articles"]);

	const normalize = (value) => value.trim().toLowerCase();
	const normalizeSearch = (value) =>
		value
			.toLowerCase()
			.normalize("NFD")
			.replace(/[\u0300-\u036f]/g, "")
			.replace(/[^a-z0-9]+/g, " ")
			.replace(/\s+/g, " ")
			.trim();
	const normalizeCode = (value) =>
		value
			.trim()
			.toUpperCase()
			.replace(/\s+/g, "")
			.replace(/_/g, "-");
	const isDigitsOnly = (value) => /^[0-9]+$/.test(value);
	const isCardCodeQuery = (value) => /^([A-Z]{1,3}\d{1,2})-?(\d{1,3})$/i.test(value.trim().replace(/\s+/g, ""));
	const formatOpCode = (value) => {
		const match = value.match(/^OP?(\d{1,2})-?(\d{1,3})$/i);
		if (!match) return null;
		const set = match[1].padStart(2, "0");
		const number = match[2].padStart(3, "0");
		return `OP${set}-${number}`;
	};
	const tokenize = (value) => normalizeSearch(value).split(" ").filter(Boolean);
	const tokenMatchesWord = (token, words) =>
		words.some((word) => word === token || word.startsWith(token));
	const tokenMatchesFuzzyWord = (token, words) =>
		token.length >= 5 &&
		words.some((word) => {
			const limit = token.length >= 7 ? 2 : 1;
			return Math.abs(word.length - token.length) <= 2 && levenshtein(word, token) <= limit;
		});
	const extractSetTokens = (value) => {
		const matches = [...normalizeSearch(value).matchAll(/\b(op|eb|st|prb)\s?(\d{1,2})\b/g)];
		return matches.map((match) => `${match[1].toUpperCase()}${match[2].padStart(2, "0")}`);
	};
	const levenshtein = (a, b) => {
		const rows = a.length + 1;
		const cols = b.length + 1;
		const matrix = Array.from({ length: rows }, () => Array(cols).fill(0));
		for (let i = 0; i < rows; i += 1) matrix[i][0] = i;
		for (let j = 0; j < cols; j += 1) matrix[0][j] = j;
		for (let i = 1; i < rows; i += 1) {
			for (let j = 1; j < cols; j += 1) {
				const cost = a[i - 1] === b[j - 1] ? 0 : 1;
				matrix[i][j] = Math.min(
					matrix[i - 1][j] + 1,
					matrix[i][j - 1] + 1,
					matrix[i - 1][j - 1] + cost,
				);
			}
		}
		return matrix[a.length][b.length];
	};

	const createResultsSection = (title, count) => {
		const section = document.createElement("section");
		section.className = "results-section";
		const heading = document.createElement("div");
		heading.className = "results-heading";
		const h2 = document.createElement("h2");
		h2.textContent = title;
		const meta = document.createElement("span");
		meta.textContent = `${count} result${count > 1 ? "s" : ""}`;
		heading.append(h2, meta);
		section.appendChild(heading);
		return section;
	};

	const openModal = (card) => {
		if (!modal || !modalImage) return;
		modalImage.setAttribute("src", card.fullUrl);
		modalImage.setAttribute("alt", `${card.code} card`);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	const renderGuideResults = (guides) => {
		if (!resultsContainer || guides.length === 0) return;
		const section = createResultsSection("Deck Guides", guides.length);
		const grid = document.createElement("div");
		grid.className = "guide-results-grid";
		guides.forEach((guide) => {
			const card = document.createElement("a");
			card.className = "guide-result-card";
			card.href = guide.href;

			const eyebrow = document.createElement("span");
			eyebrow.className = "guide-result-eyebrow";
			const formatLabel = guide.kind === "deck" ? `Format ${guide.code}` : guide.code;
			eyebrow.textContent = formatLabel;

			const media = document.createElement("div");
			media.className = "guide-result-media";
			const img = document.createElement("img");
			img.loading = "lazy";
			img.src = guide.imageSrc;
			img.alt = guide.imageAlt;
			media.appendChild(img);

			const title = document.createElement("h3");
			title.textContent = guide.title;

			const meta = document.createElement("p");
			meta.textContent = `${guide.leader} • ${guide.code}`;

			card.append(eyebrow, media, title, meta);
			grid.appendChild(card);
		});
		section.appendChild(grid);
		resultsContainer.appendChild(section);
	};

	const renderGroupedByColor = (cards) => {
		if (!resultsContainer || cards.length === 0) return;
		const wrapper = createResultsSection("Cards", cards.length);
		const groups = new Map();
		cards.forEach((card) => {
			const key = card.color || "Other";
			if (!groups.has(key)) groups.set(key, []);
			groups.get(key).push(card);
		});
		colorOrder.forEach((color) => {
			if (!groups.has(color)) return;
			const group = document.createElement("div");
			group.className = "color-group";
			const heading = document.createElement("h3");
			heading.textContent = color;
			group.appendChild(heading);
			const grid = document.createElement("div");
			grid.className = "cards-grid";
			groups.get(color).forEach((card) => {
				const shell = document.createElement("div");
				shell.className = "card-thumb-shell";
				const button = document.createElement("button");
				button.type = "button";
				button.className = "card-thumb";
				button.addEventListener("click", () => openModal(card));
				const img = document.createElement("img");
				img.loading = "lazy";
				img.src = card.smallUrl;
				img.alt = `${card.code} card`;
				button.appendChild(img);
				shell.appendChild(button);
				const affiliateCard = affiliateCards[card.code];
				if (affiliateCard) {
					const link = document.createElement("a");
					link.className = "card-affiliate-link";
					link.href = affiliateCard.affiliateUrl;
					link.target = "_blank";
					link.rel = "nofollow sponsored noopener";
					link.textContent = affiliateCard.price;
					shell.appendChild(link);
				}
				grid.appendChild(shell);
			});
			group.appendChild(grid);
			wrapper.appendChild(group);
		});
		resultsContainer.appendChild(wrapper);
	};

	const renderCards = (cards) => {
		if (!resultsContainer || cards.length === 0) return;
		const section = createResultsSection("Cards", cards.length);
		const grid = document.createElement("div");
		grid.className = "cards-grid";
		cards.forEach((card) => {
			const shell = document.createElement("div");
			shell.className = "card-thumb-shell";
			const button = document.createElement("button");
			button.type = "button";
			button.className = "card-thumb";
			button.addEventListener("click", () => openModal(card));
			const img = document.createElement("img");
			img.loading = "lazy";
			img.src = card.smallUrl;
			img.alt = `${card.code} card`;
			button.appendChild(img);
			shell.appendChild(button);
			const affiliateCard = affiliateCards[card.code];
			if (affiliateCard) {
				const link = document.createElement("a");
				link.className = "card-affiliate-link";
				link.href = affiliateCard.affiliateUrl;
				link.target = "_blank";
				link.rel = "nofollow sponsored noopener";
				link.textContent = affiliateCard.price;
				shell.appendChild(link);
			}
			grid.appendChild(shell);
		});
		section.appendChild(grid);
		resultsContainer.appendChild(section);
	};

	const loadIndex = async () => {
		if (cardIndex || isLoadingIndex) return;
		isLoadingIndex = true;
		try {
			const response = await fetch("/cards-index.json");
			if (!response.ok) throw new Error("Failed to load card index");
			cardIndex = await response.json();
		} catch (error) {
			cardIndex = [];
		} finally {
			isLoadingIndex = false;
		}
	};

	const searchGuides = (query) => {
		const normalizedQuery = normalizeSearch(query);
		if (!normalizedQuery) return [];
		const queryTokens = tokenize(query);
		const requestedSets = extractSetTokens(query);
		const hasGuideIntent = queryTokens.some((token) => guideIntentTokens.has(token));
		const meaningfulTokens = queryTokens.filter((token) => !guideIntentTokens.has(token));
		const genericGuideQuery =
			hasGuideIntent && (meaningfulTokens.length === 0 || meaningfulTokens.every((token) => extractSetTokens(token).length > 0));

		const results = guideIndex
			.map((guide, index) => {
				const primaryText = normalizeSearch(guide.primaryText ?? "");
				const secondaryText = normalizeSearch(guide.secondaryText ?? "");
				const searchText = normalizeSearch(guide.searchText ?? "");
				const title = normalizeSearch(guide.title);
				const leader = normalizeSearch(guide.leader);
				const primaryTokens = [...new Set(tokenize(primaryText))];
				const secondaryTokens = [...new Set(tokenize(secondaryText))];
				let score = 0;
				let matchedTokens = 0;
				let primaryMatchedTokens = 0;
				let weakSecondaryMatches = 0;
				let strongMatch = false;
				let matchTier = 0;

				if (genericGuideQuery) {
					score += 40;
				}

				if (title === normalizedQuery || leader === normalizedQuery) {
					score += 120;
					strongMatch = true;
					matchTier = 3;
				} else if (
					title.includes(normalizedQuery) ||
					leader.includes(normalizedQuery) ||
					primaryText.includes(normalizedQuery)
				) {
					score += 80;
					strongMatch = true;
					matchTier = 3;
				} else if (normalizedQuery.length >= 4 && searchText.includes(normalizedQuery)) {
					score += 65;
					matchTier = Math.max(matchTier, 1);
				}

				if (requestedSets.length > 0) {
					if (requestedSets.includes(guide.code.toUpperCase())) {
						score += 55;
					} else {
						return null;
					}
				}

				for (const token of meaningfulTokens) {
					if (!token) continue;
					let tokenMatched = false;
					let tokenPrimaryMatched = false;
					if (primaryTokens.includes(token)) {
						score += 34;
						tokenMatched = true;
						tokenPrimaryMatched = true;
					} else if (primaryTokens.some((candidate) => candidate.startsWith(token) || token.startsWith(candidate))) {
						score += 24;
						tokenMatched = true;
						tokenPrimaryMatched = true;
					} else if (
						token.length >= 4 &&
						primaryTokens.some((candidate) => {
							const limit = token.length >= 7 ? 2 : 1;
							return Math.abs(candidate.length - token.length) <= 2 && levenshtein(candidate, token) <= limit;
						})
					) {
						score += 18;
						tokenMatched = true;
						tokenPrimaryMatched = true;
					} else if (secondaryTokens.includes(token)) {
						score += 10;
						tokenMatched = true;
						weakSecondaryMatches += 1;
					} else if (
						secondaryTokens.some((candidate) => candidate === token || candidate.startsWith(token))
					) {
						score += 6;
						tokenMatched = true;
						weakSecondaryMatches += 1;
					}
					if (tokenMatched) matchedTokens += 1;
					if (tokenPrimaryMatched) primaryMatchedTokens += 1;
				}

				if (hasGuideIntent) score += 15;
				if (meaningfulTokens.length > 0 && matchedTokens === meaningfulTokens.length) score += 16;
				if (meaningfulTokens.length > 0 && primaryMatchedTokens === meaningfulTokens.length) {
					score += 22;
					strongMatch = true;
					matchTier = Math.max(matchTier, 2);
				} else if (meaningfulTokens.length > 0 && matchedTokens > 0) {
					matchTier = Math.max(matchTier, 1);
				}
				if (!genericGuideQuery && meaningfulTokens.length > 0 && matchedTokens !== meaningfulTokens.length) return null;
				if (!genericGuideQuery && meaningfulTokens.length > 0 && weakSecondaryMatches === meaningfulTokens.length && !strongMatch) {
					return null;
				}
				if (!genericGuideQuery && meaningfulTokens.length === 1 && primaryMatchedTokens === 0 && !strongMatch) return null;
				if (!genericGuideQuery && meaningfulTokens.length > 0 && matchedTokens === 0 && score < 65) return null;
				if (score < 25) return null;

				return { ...guide, score, index, strongMatch, matchTier };
			})
			.filter(Boolean)
			.sort((a, b) => {
				if (b.score !== a.score) return b.score - a.score;
				return a.index - b.index;
			});

		if (!genericGuideQuery) {
			const highestTier = Math.max(0, ...results.map((guide) => guide.matchTier ?? 0));
			if (highestTier >= 2) {
				return results.filter((guide) => (guide.matchTier ?? 0) === highestTier).slice(0, 8);
			}
		}

		return results.slice(0, genericGuideQuery ? 12 : 8);
	};

	const cardNameMatches = (card, query) => {
		const normalizedQuery = normalizeSearch(query);
		const queryTokens = tokenize(query);
		const name = normalizeSearch(card.name ?? "");
		const nameTokens = tokenize(card.name ?? "");
		if (!name || queryTokens.length === 0) return false;
		if (name === normalizedQuery) return true;
		if (queryTokens.length === 1) {
			return tokenMatchesWord(queryTokens[0], nameTokens) || tokenMatchesFuzzyWord(queryTokens[0], nameTokens);
		}
		return queryTokens.every((token) => tokenMatchesWord(token, nameTokens));
	};

	const runSearch = async (query) => {
		const raw = query.trim();
		if (!raw) {
			if (resultsContainer) resultsContainer.innerHTML = "";
			if (heroText) heroText.style.display = "";
			return;
		}
		if (heroText) heroText.style.display = "none";
		if (resultsContainer) resultsContainer.innerHTML = "";
		await loadIndex();
		if (!cardIndex) return;

		const normalized = normalizeCode(raw);
		const formatted = formatOpCode(normalized) ?? normalized;
		const digitsOnly = isDigitsOnly(raw);
		const hasLetters = /[a-z]/i.test(raw);
		const allowNameSearch = metadataAvailable && hasLetters;
		const rawLower = normalize(raw);
		const guideResults = searchGuides(raw);
		const hasGuideIntent = tokenize(raw).some((token) => guideIntentTokens.has(token));
		const requestedSets = extractSetTokens(raw);
		const specificCardQuery = digitsOnly || isCardCodeQuery(raw);

		const results = cardIndex.filter((card) => {
			const codeNormalized = card.code.toUpperCase();

			if (digitsOnly) {
				const padded = raw.padStart(3, "0");
				return codeNormalized.endsWith(`-${padded}`) || codeNormalized.endsWith(`-${raw}`);
			}

			const codeMatch = codeNormalized.includes(formatted);
			if (!allowNameSearch) return codeMatch;
			const nameMatch = cardNameMatches(card, raw);
			return nameMatch || codeMatch;
		});

		const shouldPrioritizeGuides = guideResults.length > 0 && !specificCardQuery;
		const shouldRenderCards =
			results.length > 0 &&
			(!shouldPrioritizeGuides ||
				(!hasGuideIntent && requestedSets.length === 0 && results.length <= 12));

		if (guideResults.length > 0) {
			renderGuideResults(guideResults);
		}

		if (shouldRenderCards) {
			if (allowNameSearch) {
				renderGroupedByColor(results);
			} else {
				renderCards(results);
			}
		}

		if (guideResults.length === 0 && results.length === 0 && resultsContainer) {
			resultsContainer.innerHTML = '<p class="muted">No cards or guides matched this search.</p>';
		}
	};

	const params = new URLSearchParams(window.location.search);
	const initialQuery = params.get("query") ?? "";
	if (searchInput && initialQuery) {
		searchInput.value = initialQuery;
		runSearch(initialQuery);
	}

	searchInput?.addEventListener("input", (event) => {
		runSearch(event.target.value);
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});
</script>

<style>
	.muted {
		color: var(--text-300);
	}

	.hero-links {
		margin-top: 1rem;
	}

	.internal-link,
	.hero-links a,
	.seo-block a,
	.faq-card a {
		color: var(--accent) !important;
		font-weight: 600;
		text-decoration: none;
	}

	.search-results {
		margin-top: 1.5rem;
		display: grid;
		gap: 1.5rem;
	}

	.hero-text {
		margin-top: 1.5rem;
	}

	:global(.results-section) {
		display: grid;
		gap: 1rem;
	}

	:global(.results-heading) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	:global(.results-heading h2) {
		margin: 0;
		font-size: 1.15rem;
	}

	:global(.results-heading span) {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	:global(.guide-results-grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	:global(.guide-result-card) {
		display: grid;
		gap: 0.7rem;
		padding: 1rem;
		border-radius: var(--radius-md);
		border: 1px solid var(--border);
		background: rgba(12, 17, 30, 0.9);
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
		min-width: 0;
		overflow: hidden;
	}

	:global(.guide-result-card:hover),
	:global(.guide-result-card:focus-visible) {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	:global(.guide-result-eyebrow) {
		color: var(--accent);
		font-size: 0.76rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	:global(.guide-result-media) {
		display: flex;
		justify-content: center;
	}

	:global(.guide-result-media img) {
