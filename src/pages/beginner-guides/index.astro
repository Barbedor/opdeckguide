---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";

const title = "Beginner Guides for One Piece Card Game";
const description = "Beginner-friendly One Piece Card Game guides covering rules, product advice, and first deck upgrades.";
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">Beginner Guides</span>
			<h1>Beginner Guides for One Piece Card Game</h1>
			<p>
				Start here if you are new. The guides below give you the rules and the fastest path to your first
				confident games.
			</p>
		</div>
	</section>

	<Section
		title="Start Here"
		description="Rules references and first deck orientation for new players."
		linkHref="/beginner-guides"
		linkLabel="All beginner guides"
	>
		<Card
			eyebrow="Playstyle"
			title="How to Choose a Deck?"
			description="A quick guide to the main color identities so you can find the deck style that fits you."
			imageSrc="/assets/beginner-guides/how-to-choose-a-deck.svg"
			imageAlt="How to choose a deck guide cover"
			href="/beginner-guides/how-to-choose-a-deck"
		/>
		<Card
			eyebrow="Rules"
			title="Complete One Piece TCG Rules"
			description="The full, official rule reference for every action, phase, and timing window."
			imageSrc="/assets/beginner-guides/complete-rules.png"
			imageAlt="Complete rules guide cover"
			href="/beginner-guides/complete-rules"
		/>
		<Card
			eyebrow="Rules"
			title="Simplified Rules Overview"
			description="A clear, beginner-friendly summary of the rules to get you playing fast."
			imageSrc="/assets/beginner-guides/simplified-rules.png"
			imageAlt="Simplified rules guide cover"
			href="/beginner-guides/simplified-rules"
		/>
	</Section>

	<section class="seo-block">
		<div class="container">
			<h2>About Beginner Guides</h2>
			<p>
				New to the One Piece Card Game? This section gives you a clear, step-by-step path to learn the rules,
				choose a starter leader, and upgrade your first list without wasting money. We focus on fundamentals
				that stay relevant even as the meta shifts, so your practice time always pays off.
			</p>
			<p>
				Learn core concepts like life management, counter timing, and sequencing your attacks for maximum
				value. Once you have the basics, you can move into leader-specific plans in the
				<a href="/deck-guides">Deck Guides</a> section. When you are ready to compete, the
				<a href="/meta-analysis">Meta Analysis</a> page will help you understand what you are up against.
			</p>
			<p>
				These guides are written for quick reading on mobile but include practical advice you can apply
				immediately. You will find realistic upgrade paths, priority lists for purchases, and drills that
				improve your gameplay. When official changes happen, check the <a href="/banlist">Banlist</a> to keep
				your deck legal and avoid wasted upgrades.
			</p>
		</div>
	</section>
</MainLayout>
