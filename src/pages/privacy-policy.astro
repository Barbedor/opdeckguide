---
import MainLayout from "../layouts/MainLayout.astro";

const title = "Privacy Policy";
const description =
	"Privacy policy for OPDeckGuide, including the use of Google Analytics for basic audience measurement.";
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">Privacy</span>
			<h1>Privacy Policy</h1>
			<p>
				This page explains what OPDeckGuide collects, why it is collected, and how it is used.
			</p>
		</div>
	</section>

	<section class="list-section">
		<div class="container legal-copy">
			<h2>What this site does</h2>
			<p>
				OPDeckGuide publishes English-language strategy content about the One Piece Card Game.
			</p>

			<h2>Analytics</h2>
			<p>
				This site uses Google Analytics 4 to measure traffic and understand which pages are viewed, how visitors
				reach the site, and which content is used the most.
			</p>
			<p>
				This analytics setup is used only for audience measurement and site improvement. It is not used to serve
				ads, sell profiles, or create user accounts on this site.
			</p>

			<h2>Data processed</h2>
			<p>
				Google Analytics may process technical usage data such as page views, approximate location, device or
				browser information, referring source, and on-site navigation events.
			</p>

			<h2>What this site does not offer</h2>
			<p>
				This site does not provide account registration, comments, checkout, or advertising features at this time.
			</p>

			<h2>Third-party service</h2>
			<p>
				Analytics data is processed through Google Analytics. You can learn more about how Google handles data on
				Google’s own privacy pages.
			</p>

			<h2>Your choices</h2>
			<p>
				You can limit analytics collection by using browser privacy settings, content blockers, or Google’s own
				privacy controls.
			</p>

			<h2>Updates</h2>
			<p>
				This page may be updated if the site’s analytics setup or site features change.
			</p>
		</div>
	</section>
</MainLayout>

<style>
	.legal-copy {
		max-width: 760px;
	}

	.legal-copy h2 {
		margin: 2rem 0 0.75rem;
		font-size: 1.5rem;
	}

	.legal-copy p {
		margin: 0.75rem 0;
		color: var(--text-200);
	}
</style>
