---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Boa Hancock OP14 Deck Guide";
const description =
	"Boa Hancock OP14 deck guide for One Piece Card Game with decklist, curve reference, mulligan targets, options, and matchup notes.";

const icon = "/assets/guides/boa-hancock-op14.png";

const decklist = [
	{ code: "OP14-041", name: "Boa Hancock", count: 1, img: "/Cards/OP14/OP14-041.jpg", role: "Leader" },
	{ code: "OP07-041", name: "Gloriosa (Grandma Nyon)", count: 4, img: "/Cards/OP07/OP07-041.png", role: "Character" },
	{ code: "OP06-106", name: "Kouzuki Hiyori", count: 4, img: "/Cards/OP06/OP06-106.png", role: "Character" },
	{ code: "OP14-113", name: "Marguerite", count: 3, img: "/Cards/OP14/OP14-113.jpg", role: "Character" },
	{ code: "ST17-004", name: "Boa Hancock", count: 4, img: "/Cards/ST17/ST17-004.png", role: "Character" },
	{ code: "OP06-047", name: "Pudding", count: 4, img: "/Cards/OP06/OP06-047.png", role: "Character" },
	{ code: "OP14-114", name: "Ran", count: 2, img: "/Cards/OP14/OP14-114.jpg", role: "Character" },
	{ code: "EB03-053", name: "Nami", count: 4, img: "/Cards/EB03/EB03-053.jpg", role: "Character" },
	{ code: "OP14-105", name: "Gorgon Sisters", count: 4, img: "/Cards/OP14/OP14-105.jpg", role: "Character" },
	{ code: "OP14-107", name: "Shakuyaku", count: 4, img: "/Cards/OP14/OP14-107.jpg", role: "Character" },
	{ code: "OP14-108", name: "Silvers Rayleigh", count: 3, img: "/Cards/OP14/OP14-108.jpg", role: "Character" },
	{ code: "OP12-119", name: "Bartholomew Kuma", count: 4, img: "/Cards/OP12/OP12-119.jpg", role: "Character" },
	{ code: "OP14-112", name: "Boa Hancock", count: 4, img: "/Cards/OP14/OP14-112.jpg", role: "Character" },
	{ code: "OP06-115", name: "You're the One Who Should Disappear.", count: 2, img: "/Cards/OP06/OP06-115.png", role: "Event" },
	{ code: "OP07-056", name: "Slave Arrow", count: 2, img: "/Cards/OP07/OP07-056.png", role: "Event" },
	{ code: "OP07-057", name: "Perfume Femur", count: 2, img: "/Cards/OP07/OP07-057.png", role: "Event" },
];

const options = [
	{ code: "OP07-046", name: "Sengoku", img: "/Cards/OP07/OP07-046.png" },
	{ code: "OP14-115", name: "Rindo", img: "/Cards/OP14/OP14-115.jpg" },
	{ code: "OP14-118", name: "You'll Frighten Me…", img: "/Cards/OP14/OP14-118.jpg" },
	{ code: "OP06-058", name: "Gravity Blade Raging Tiger", img: "/Cards/OP06/OP06-058.png" },
];

const optionsNote =
	"If you play the version with Kuma, you could consider Sengoku instead of Nyon so you can look for it. I do not recommend removing the searchers completely because you need consistency. Kuma is very expensive; the cheaper alternative is Rindo, which is archetype, but if you want to play the deck at maximum potential you need to invest a little. The spells are occasional: if your locals are aggro-heavy, the 1-cost spell helps; if there are many Boa, Gravity is the right choice. This ratio is fine.";

const mulliganCards = [
	{ code: "OP07-041", name: "Gloriosa (Grandma Nyon)", img: "/Cards/OP07/OP07-041.png" },
	{ code: "ST17-004", name: "Boa Hancock", img: "/Cards/ST17/ST17-004.png" },
	{ code: "OP06-106", name: "Kouzuki Hiyori", img: "/Cards/OP06/OP06-106.png" },
	{ code: "OP14-105", name: "Gorgon Sisters", img: "/Cards/OP14/OP14-105.jpg" },
];

const curveFirst = [
	{
		label: "1 DON",
		notes: "Search for missing character.",
		cards: [{ code: "OP07-041", name: "Gloriosa (Grandma Nyon)", img: "/Cards/OP07/OP07-041.png" }],
	},
	{
		label: "3 DON",
		notes: "Fix your lives and swing 6K vs leader 6K base power, or use another searcher vs 5K leader.",
		cards: [
			{ code: "OP06-106", name: "Kouzuki Hiyori", img: "/Cards/OP06/OP06-106.png" },
			{ code: "OP14-105", name: "Gorgon Sisters", img: "/Cards/OP14/OP14-105.jpg" },
		],
	},
	{
		label: "5 DON",
		notes:
			"Play Nami and burn opponent first life. The DON under the Leader helps activate the effect if they break the character who entered the turn before.",
		cards: [{ code: "EB03-053", name: "Nami", img: "/Cards/EB03/EB03-053.jpg" }],
	},
	{
		label: "7 DON",
		notes:
			"Ray is the only removal of the deck, strong against Jozu. Kuma is the best choice to gain time.",
		cards: [
			{ code: "OP14-108", name: "Silvers Rayleigh", img: "/Cards/OP14/OP14-108.jpg" },
			{ code: "OP12-119", name: "Bartholomew Kuma", img: "/Cards/OP12/OP12-119.jpg" },
		],
	},
	{
		label: "9 DON",
		notes: "Burn! Burn! Burn… and trigger!",
		cards: [{ code: "OP14-112", name: "Boa Hancock", img: "/Cards/OP14/OP14-112.jpg" }],
	},
	{
		label: "Late game",
		notes:
			"This is your best finisher. If you set up correctly, play it. Alternatively play boss monster and starve.",
		cards: [{ code: "OP07-057", name: "Perfume Femur", img: "/Cards/OP07/OP07-057.png" }],
	},
];

const curveSecond = [
	{
		label: "2 DON",
		notes: "Fix your lives for trigger, the first Character and draw.",
		cards: [
			{ code: "OP06-106", name: "Kouzuki Hiyori", img: "/Cards/OP06/OP06-106.png" },
			{ code: "OP14-105", name: "Gorgon Sisters", img: "/Cards/OP14/OP14-105.jpg" },
		],
	},
	{
		label: "4 DON",
		notes: "Play Boa and fix the top of your deck; it will be essential for the next turn.",
		cards: [{ code: "ST17-004", name: "Boa Hancock", img: "/Cards/ST17/ST17-004.png" }],
	},
	{
		label: "6 DON",
		notes:
			"If you played correctly, now playing Kuma you know exactly which life you're going to position. This is a very strong play, even if you don't have DON under the Leader.",
		cards: [{ code: "OP12-119", name: "Bartholomew Kuma", img: "/Cards/OP12/OP12-119.jpg" }],
	},
	{
		label: "8 DON",
		notes:
			"The deck doesn't have turns at 8 DON. This can be remedied by playing any cost 4 Boa to set up the arrival of the 9C (like 4/6 DON turn).",
		cards: [
			{ code: "OP06-047", name: "Pudding", img: "/Cards/OP06/OP06-047.png" },
			{ code: "ST17-004", name: "Boa Hancock", img: "/Cards/ST17/ST17-004.png" },
		],
	},
	{
		label: "10 DON",
		notes: "Burn! Burn! Burn… and trigger!",
		cards: [{ code: "OP14-112", name: "Boa Hancock", img: "/Cards/OP14/OP14-112.jpg" }],
	},
	{
		label: "Late game",
		notes:
			"This is your best finisher. If you set up correctly, play it. Alternatively play boss monster and starve.",
		cards: [{ code: "OP07-057", name: "Perfume Femur", img: "/Cards/OP07/OP07-057.png" }],
	},
];

const tips = [
	{
		title:
			"Against Ace, don't attack to take away the first life but starve. Use Nami to burn it so as not to make him draw for leader effect. It applies to all 3-life leaders.",
		cards: [{ code: "EB03-053", name: "Nami", img: "/Cards/EB03/EB03-053.jpg" }],
	},
	{
		title:
			"This is a very strong combo if the opponent is at 0 lives with many cards in hand. Pudding and Perfume on Boa 9C can ensure victory.",
		cards: [
			{ code: "OP06-047", name: "Pudding", img: "/Cards/OP06/OP06-047.png" },
			{ code: "OP07-057", name: "Perfume Femur", img: "/Cards/OP07/OP07-057.png" },
		],
	},
	{
		title:
			"If you are in a 2nd curve, being able to look at the top and fix it with Boa helps you put the right trigger in your lives with Kuma the next turn. Knowing that you have a Character who enters makes the difference, not to try your luck.",
		cards: [
			{ code: "ST17-004", name: "Boa Hancock", img: "/Cards/ST17/ST17-004.png" },
			{ code: "OP12-119", name: "Bartholomew Kuma", img: "/Cards/OP12/OP12-119.jpg" },
		],
	},
];

const matchups = [
	{
		label: "Even",
		icon: "≈",
		leader: { code: "OP14-041", name: "Boa Hancock", img: "/Cards/OP14/OP14-041.jpg" },
		notes: ["Start 2nd", "Manage your lives", "Polarized to trigger"],
	},
	{
		label: "Slight Adv.",
		icon: "↑",
		leader: { code: "OP13-079", name: "Imu", img: "/Cards/OP13/OP13-079.jpg" },
		notes: ["Start 2nd", "Manage your board", "Dice dependent"],
	},
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP14-020", name: "Dracule Mihawk", img: "/Cards/OP14/OP14-020.jpg" },
		notes: ["Start 1st", "Board control", "Chain 9C Boa"],
	},
	{
		label: "Slight Adv.",
		icon: "↑",
		leader: { code: "OP13-002", name: "Portgas D. Ace", img: "/Cards/OP13/OP13-002.jpg" },
		notes: ["Start 2nd", "Burn his lives", "Dice dependent"],
	},
	{
		label: "Even",
		icon: "≈",
		leader: { code: "OP14-060", name: "Donquixote Doflamingo", img: "/Cards/OP14/OP14-060.jpg" },
		notes: ["Start 1st", "Manage your board", "Remember leader effect"],
	},
	{
		label: "Negative MU",
		icon: "↓",
		leader: { code: "ST29-001", name: "Monkey D. Luffy", img: "/Cards/ST29/ST29-001.jpg" },
		notes: ["Start 2nd", "Go aggro", "6 lives is a problem"],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Boa Hancock OP14 Deck Guide</h1>
				<p>
					Complete reference guide for Boa Hancock OP14: decklist, curve checkpoints, mulligan priorities, tech
					options, and matchup notes. Built for fast reading between rounds.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Boa Hancock OP14 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Decklist</h2>
					<p>Main list for Boa Hancock OP14.</p>
				</div>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Flexible slots to adapt the list.</p>
				</div>
			</div>
			<div class="options-grid">
				{options.map((card) => (
					<button
						class="option-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="option-info">
							<div class="deck-name">{card.name}</div>
							<div class="deck-code">{card.code}</div>
						</div>
					</button>
				))}
			</div>
			<p class="section-note">{optionsNote}</p>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>Nyon + Boa to look for the missing curve, or Hiyori + Gorgon Sisters to fix your lives.</p>
				</div>
			</div>
			<div class="mulligan-grid">
				{mulliganCards.map((card) => (
					<button
						class="mini-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="mini-label">{card.name}</div>
					</button>
				))}
			</div>
			<p class="mulligan-text">If you don't see this combo, mulligan is the way.</p>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Turn-by-turn curve reminders for going first or second.</p>
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve 1st</h3>
				<div class="curve-rows">
					{curveFirst.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve 2nd</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Key reminders and timing notes.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class="tip-card">
						<div class="tip-cards">
							{tip.cards.map((card) => (
								<button
									class="mini-card"
									type="button"
									data-card-preview
									data-full={card.img}
									data-name={`${card.code} ${card.name}`}
								>
									<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
								</button>
							))}
						</div>
						<p>{tip.title}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>Quick matchup snapshot for the key leaders.</p>
				</div>
			</div>
			<div class="matchups-grid">
				{matchups.map((matchup) => (
					<div class="matchup-card">
						<div class={`matchup-badge ${matchup.label === "Negative MU" ? "badge-down" : matchup.label === "Slight Disadv." ? "badge-down" : matchup.label === "Even" ? "badge-even" : "badge-up"}`}>
							<span class="badge-icon">{matchup.icon}</span>
							<span>{matchup.label}</span>
						</div>
						<button
							class="mini-card"
							type="button"
							data-card-preview
							data-full={matchup.leader.img}
							data-name={`${matchup.leader.code} ${matchup.leader.name}`}
						>
							<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
						</button>
						<div class="matchup-name">{matchup.leader.name}</div>
						<ul>
							{matchup.notes.map((note) => (
								<li>{note}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});
</script>

<style>
	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 0.9rem;
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.options-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
	}

	.option-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 0.8rem;
		display: grid;
		gap: 0.6rem;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.option-card img {
		width: 100%;
		max-width: 220px;
		margin: 0 auto;
		border-radius: 10px;
	}

	.option-info {
		display: grid;
		gap: 0.2rem;
	}

	.option-note {
		margin: 0.4rem 0 0;
		color: var(--text-300);
		font-size: 0.9rem;
	}

	.note-block {
		background: rgba(14, 18, 30, 0.7);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1.2rem 1.4rem;
	}

	.mulligan-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
