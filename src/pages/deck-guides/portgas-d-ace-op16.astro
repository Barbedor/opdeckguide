---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Portgas.D.Ace OP16 Deck Guide";
const description =
	"Portgas.D.Ace OP16 deck guide for One Piece Card Game with decklist, mulligan priorities, curve guide, tech cards, matchup notes, and gameplay tips.";

const icon = "/assets/guides/Ace-op16.png";

const card = (code, name, img) => ({ code, name, img });
const aceLeader = card("OP16-001", "Portgas.D.Ace", "/Cards/OP16/OP16-001.jpg");
const asl = card("OP13-007", "Ace & Sabo & Luffy", "/Cards/OP13/OP13-007.jpg");
const garp = card("OP13-016", "Monkey.D.Garp", "/Cards/OP13/OP13-016.jpg");
const sanji = card("ST21-003", "Sanji", "/Cards/ST21/ST21-003.jpg");
const luffy = card("OP16-015", "Monkey.D.Luffy", "/Cards/OP16/OP16-015.jpg");
const oars = card("OP16-017", "LittleOars Jr.", "/Cards/OP16/OP16-017.jpg");
const ace118 = card("OP16-118", "Portgas.D.Ace", "/Cards/OP16/OP16-118.jpg");
const vista = card("OP16-011", "Vista", "/Cards/OP16/OP16-011.jpg");
const marco = card("OP16-014", "Marco", "/Cards/OP16/OP16-014.jpg");
const uta = card("ST23-001", "Uta", "/Cards/ST23/ST23-001.jpg");
const zoro = card("EB04-007", "Roronoa Zoro", "/Cards/EB04/EB04-007.jpg");
const curiel = card("OP16-004", "Curiel", "/Cards/OP16/OP16-004.jpg");
const newgate = card("OP16-003", "Edward Newgate", "/Cards/OP16/OP16-003.jpg");
const thatch = card("OP16-005", "Thatch", "/Cards/OP16/OP16-005.jpg");
const timeForCounterattack = card("OP14-018", "Time for the Counterattack", "/Cards/OP14/OP14-018.jpg");
const mobyDick = card("OP16-021", "Moby Dick", "/Cards/OP16/OP16-021.jpg");

const nami11 = card("OP11-041", "Nami", "/Cards/OP11/OP11-041.jpg");
const enel15 = card("OP15-058", "Enel", "/Cards/OP15/OP15-058.jpg");
const teach16 = card("OP16-080", "Marshall.D.Teach", "/Cards/OP16/OP16-080.jpg");
const gbLuffy16 = card("OP16-022", "Monkey.D.Luffy", "/Cards/OP16/OP16-022.jpg");
const lucy15 = card("OP15-002", "Lucy", "/Cards/OP15/OP15-002.jpg");
const sabo13 = card("OP13-004", "Sabo", "/Cards/OP13/OP13-004.jpg");
const blackYamato16 = card("OP16-079", "Yamato", "/Cards/OP16/OP16-079.jpg");
const rosinante12 = card("OP12-061", "Donquixote Rosinante", "/Cards/OP12/OP12-061.jpg");
const girl = card("P-096", "Girl", "/Cards/P/P-096.jpg");

const decklist = [
	{ ...aceLeader, count: 1, role: "Leader" },
	{ ...asl, count: 3, role: "Character" },
	{ ...garp, count: 4, role: "Character" },
	{ ...sanji, count: 3, role: "Character" },
	{ ...luffy, count: 4, role: "Character" },
	{ ...oars, count: 4, role: "Character" },
	{ ...ace118, count: 2, role: "Character" },
	{ ...vista, count: 4, role: "Character" },
	{ ...marco, count: 4, role: "Character" },
	{ ...uta, count: 2, role: "Character" },
	{ ...zoro, count: 3, role: "Character" },
	{ ...curiel, count: 4, role: "Character" },
	{ ...newgate, count: 4, role: "Character" },
	{ ...thatch, count: 3, role: "Character" },
	{ ...timeForCounterattack, count: 2, role: "Event" },
	{ ...mobyDick, count: 4, role: "Stage" },
];

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const simDeckCode = decklist.flatMap((entry) => expandSimLines(entry.count, entry.code)).join("\n");

const idealHandGroups = [
	{
		title: "Searcher",
		cards: [garp, mobyDick],
		copy: "Garp or Moby Dick gets your setup moving right away.",
	},
	{
		title: "Monkey.D.Luffy",
		cards: [luffy],
		copy: "This is the card that makes the whole deck function on both offense and defense.",
	},
	{
		title: "2K Counter",
		cards: [sanji, uta, curiel],
		copy: "These keep your early defense clean while still feeding the Whitebeard Pirates plan.",
	},
	{
		title: "8000-Power Character",
		cards: [thatch, marco, vista],
		copy: "These are the bodies you want ready once Ace starts handing out Rush.",
	},
	{
		title: "Late-Game Threat",
		cards: [newgate],
		copy: "Having Newgate early means your closing turns are already mapped out.",
	},
];

const mulliganQuestionsCards = [garp, mobyDick];

const techCards = [
	{
		card: asl,
		copy:
			"Very useful power reduction to win board fights.<br />The deck naturally lacks real control, so this card helps patch that weakness.",
	},
	{
		card: curiel,
		copy:
			`Mandatory card.<br />8000-power stats.<br />2000 counter.<br />An excellent card to reveal for your Whitebeard Pirates effects.`,
	},
	{
		card: uta,
		copy:
			`Emergency blocker.<br />Very useful in spots where you just need to survive one more turn.<br />She can be searched by Garp and Moby Dick.`,
	},
	{
		card: sanji,
		copy:
			`The deck struggles against blockers.<br />Sanji can give unblockable to Zoro or Luffy so you can close games through defensive boards.`,
	},
	{
		card: luffy,
		copy:
			`The heart of the deck.<br />By discarding an 8000-power character, he turns Ace into a 7000-power leader.<br />This is the single most important card in the list.`,
	},
	{
		card: oars,
		copy:
			`An 8000-power blocker for just 4 cost.<br />It's an excellent defensive card and fits exactly what the deck needs.`,
	},
	{
		card: ace118,
		copy:
			`Not the best card in the deck.<br />Its main job is to find the missing pieces when you still haven't found Luffy.`,
	},
	{
		card: vista,
		copy:
			`One of the best cards in the deck.<br />Draws a card.<br />Gets rush through the leader effect.<br />Cleans up low-cost characters.`,
	},
	{
		card: marco,
		copy:
			`Probably the best card in the deck against opposing removal.<br />It protects your board and stays extremely difficult to clear.`,
	},
	{
		card: newgate,
		copy:
			`The real boss of the deck.<br />-6000 power reduction.<br />Gives your leader double attack and +2000 power during your turn.<br />Constant pressure.<br />He often closes games by himself.`,
	},
	{
		card: zoro,
		copy:
			`An excellent generic red card.<br />It gives you board control while also improving the deck's defense.`,
	},
	{
		card: timeForCounterattack,
		copy:
			`Counter +4000 for just 1 DON!! when you control an 8000-power character. That's very easy to turn on in this deck.`,
	},
];

const curveFirst = [
	{
		don: "1 DON!!",
		cards: [garp, mobyDick],
		copy: "Play Garp or Moby Dick. The goal is to find Luffy or your 8000-power Whitebeard Pirates.",
	},
	{
		don: "3 DON!!",
		cards: [garp, mobyDick, aceLeader],
		copy: "Same idea, but now you can start attacking opposing Life while still digging for the right pieces.",
	},
	{
		don: "5 DON!!",
		cards: [luffy, ace118],
		copy: "Luffy is the best play. If you still haven't found him, play OP16-118 Ace to dig for the missing pieces and pitch dead cards.",
	},
	{
		don: "7 DON!!",
		cards: [marco, vista, luffy, ace118, zoro],
		copy: "You can chain another 8000-power Whitebeard Pirates body, play Luffy + OP16-118 Ace for the full 7 DON!! line, or lean on Zoro if the opponent built a wide board.",
	},
	{
		don: "9 DON!!",
		cards: [luffy, zoro, newgate],
		copy: "The same pressure plan keeps going, but the big swing here is Luffy plus Zoro for exactly 9 DON!! to push even harder.",
	},
	{
		don: "Late Game",
		cards: [newgate],
		copy: "Keep chaining Newgate turns and Rush bodies until the opponent collapses under the pressure.",
	},
];

const curveSecond = [
	{
		don: "2 DON!!",
		cards: [garp, mobyDick],
		copy: "Play Garp or Moby Dick. Your entire early game is about finding Luffy and lining up your 8000-power threats.",
	},
	{
		don: "4 DON!!",
		cards: [luffy],
		copy: "Your absolute top priority is finding and playing Luffy. If you miss him, keep developing your setup while still keeping pressure on the opponent.",
	},
	{
		don: "6 DON!!",
		cards: [vista, marco],
		copy:
			`Vista is ideal into low-cost boards because it draws a card, attacks immediately through rush, and clears smaller characters. Marco is the better line into decks packed with removal because he's so hard to clear and protects your board.`,
	},
	{
		don: "8 DON!!",
		cards: [newgate, luffy, marco],
		copy:
			`Newgate is the most aggressive play in the deck. He gives your leader double attack plus +2000 power while cutting an opposing character by 6000. Luffy plus another Whitebeard Pirates body is the more tempo-focused alternative.`,
	},
	{
		don: "10 DON!!",
		cards: [newgate, vista, marco, timeForCounterattack],
		copy:
			`Keep chaining Newgate, keep giving rush to Whitebeard Pirates, and ideally leave 1 DON!! up so Time for the Counterattack stays live.`,
	},
];

const matchupLegend = [
	{ tone: "slight-unfavored", label: "Slightly Unfavorable" },
	{ tone: "slight-favored", label: "Slightly Favorable" },
	{ tone: "unfavored", label: "Unfavorable" },
	{ tone: "favored", label: "Favored" },
	{ tone: "even", label: "Even" },
];

const matchups = [
	{
		title: "Nami OP11",
		tone: "slight-unfavored",
		leader: nami11,
		bullets: [
			"Tough matchup, but very winnable.",
			"Luffy matters because turning Ace into a 7000-power leader changes the math a lot.",
			"Vista clears low-cost characters like Girl P-096 while also keeping your pressure moving.",
			"Newgate is one of your best ways to keep the pressure high.",
			"Sanji helps you push through blockers once the game gets tight.",
			"The goal is to pressure opposing Life as hard as possible until Nami runs short on resources.",
			"Protect your board whenever you reasonably can so the pressure never stops.",
		],
	},
	{
		title: "Enel OP15",
		tone: "slight-favored",
		leader: enel15,
		bullets: [
			"Difficult matchup, but favorable on paper.",
			"Play Luffy fast so Ace becomes a 7000-power leader.",
			"Marco and Vista are the key cards here: Marco protects your board and Vista picks off smaller characters.",
			"When Secret Enel hits the field, Newgate gives you the cleanest way to handle it with the power reduction.",
			"The whole plan is to pressure Enel as quickly as possible before the yellow deck stabilizes.",
		],
	},
	{
		title: "Teach OP16",
		tone: "unfavored",
		leader: teach16,
		bullets: [
			"One of the hardest matchups for the deck.",
			"Try to get Teach to 1 Life or lower as quickly as possible.",
			"Once multiple Teach blockers pile up, the game gets much harder.",
			"Newgate helps shrink the blockers and Sanji can create an opening with Unblockable.",
			"Watch Vasco Shot, Van Augur, Teach triggers, and anything that makes your board vanish.",
			"If you lose Luffy, the matchup gets dramatically worse because Ace drops back below 7000 power.",
		],
	},
	{
		title: "Blue/Green Luffy OP16",
		tone: "slight-favored",
		leader: gbLuffy16,
		bullets: [
			"Ace is usually the faster deck.",
			"Whitebeard Pirates bodies with Rush create a lot of pressure before Luffy stabilizes.",
			"Vista cleanly K.O.s cards like Mr. 1, Mr. 2, and Luffy.",
			"Newgate often forces the opponent to spend multiple cards defending because of the Double Attack threat.",
			"Luffy gets better as the game goes longer, so Ace wants to keep the initiative the whole time.",
			"Take Life quickly, force Luffy to defend instead of building the board, and prioritize pressure over board control.",
		],
	},
	{
		title: "Red/Blue Lucy OP15",
		tone: "even",
		leader: lucy15,
		bullets: [
			"Both decks are aggressive.",
			"Both decks can create explosive turns.",
			"Lucy usually has better resource generation.",
			"Ace usually has more raw pressure because the 8000-power Whitebeard Pirates gain Rush.",
			"Keep Luffy on the board, force Lucy to spend defensive resources, and don't let the game drag out too long.",
		],
	},
	{
		title: "Red/Black Sabo OP13",
		tone: "slight-unfavored",
		leader: sabo13,
		bullets: [
			"Sabo controls the board better than Ace does.",
			"Ace also depends a lot on a few key characters.",
			"Marco is extremely important because Sabo's removal can break Ace's rhythm if you don't protect the board.",
			"Find Marco early, flood the board, and never rely on just one character to carry the game.",
		],
	},
	{
		title: "Black Yamato OP16",
		tone: "even",
		leader: blackYamato16,
		bullets: [
			"Yamato becomes incredibly explosive once the trash is ready.",
			"Ace is faster in the first few turns.",
			"The matchup usually comes down to which deck hits its main plan first.",
			"Both decks are capable of killing very quickly.",
			"Pressure immediately, make Yamato defend instead of setting up the trash, and exploit your Newgate turns before the reanimation chains begin.",
		],
	},
	{
		title: "Purple/Yellow Rosinante OP12",
		tone: "unfavored",
		leader: rosinante12,
		bullets: [
			"This is probably the matchup that would worry me the most.",
			"It excels in long games.",
			"It protects its characters extremely well.",
