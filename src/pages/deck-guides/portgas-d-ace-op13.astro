---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Portgas.D.Ace OP13 Deck Guide";
const description =
	"Portgas.D.Ace OP13 deck guide for One Piece Card Game with decklist, mulligan priorities, curve reference, tech cards, matchup notes, and OP16 gameplay tips.";

const icon = "/assets/guides/portgas-d-ace-op13.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP13-002", name: "Portgas.D.Ace", count: 1, img: "/Cards/OP13/OP13-002.jpg", role: "Leader" },
	{ code: "ST15-004", name: "Thatch", count: 2, img: "/Cards/ST15/ST15-004.png", role: "Character" },
	{ code: "OP13-043", name: "Otama", count: 4, img: "/Cards/OP13/OP13-043.jpg", role: "Character" },
	{ code: "ST22-002", name: "Izo", count: 4, img: "/Cards/ST22/ST22-002.jpg", role: "Character" },
	{ code: "OP13-016", name: "Monkey.D.Garp", count: 4, img: "/Cards/OP13/OP13-016.jpg", role: "Character" },
	{ code: "OP08-040", name: "Atmos", count: 3, img: "/Cards/OP08/OP08-040.png", role: "Character" },
	{ code: "PRB02-008", name: "Marco", count: 4, img: "/Cards/PRB02/PRB02-008.jpg", role: "Character" },
	{ code: "OP13-054", name: "Yamato", count: 4, img: "/Cards/OP13/OP13-054.jpg", role: "Character" },
	{ code: "ST23-001", name: "Uta", count: 2, img: "/Cards/ST23/ST23-001.jpg", role: "Character" },
	{ code: "OP08-047", name: "Jozu", count: 4, img: "/Cards/OP08/OP08-047.png", role: "Character" },
	{ code: "OP07-051", name: "Boa Hancock", count: 3, img: "/Cards/OP07/OP07-051.png", role: "Character" },
	{ code: "EB04-007", name: "Roronoa Zoro", count: 3, img: "/Cards/EB04/EB04-007.jpg", role: "Character" },
	{ code: "OP13-042", name: "Edward.Newgate", count: 4, img: "/Cards/OP13/OP13-042.jpg", role: "Character" },
	{ code: "OP09-118", name: "Gol.D.Roger", count: 1, img: "/Cards/OP09/OP09-118.jpg", role: "Character" },
	{
		code: "OP13-057",
		name: "If I Bowed Down to Power, What's the Point in Living?",
		count: 1,
		img: "/Cards/OP13/OP13-057.jpg",
		role: "Event",
	},
	{ code: "OP14-018", name: "Time for the Counterattack", count: 1, img: "/Cards/OP14/OP14-018.jpg", role: "Event" },
	{ code: "ST22-015", name: "I Am Whitebeard!!", count: 4, img: "/Cards/ST22/ST22-015.jpg", role: "Event" },
	{ code: "OP16-021", name: "Moby Dick", count: 2, img: "/Cards/OP16/OP16-021.jpg", role: "Stage" },
];

const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const mulliganKeeps = [
	{
		copy:
			"Izo is one of the best cards to see early. It improves your opening hand by finding the important pieces while still moving your game plan forward.",
		cards: [{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" }],
	},
	{
		copy:
			"Monkey.D.Garp is also a priority. It helps stabilize the first turns and sets up your midgame threats efficiently.",
		cards: [{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" }],
	},
	{
		copy:
			"Marco is often an excellent keep because of his defensive value. He forces the opponent to spend resources while buying you time to develop your plan.",
		cards: [{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" }],
	},
	{
		copy:
			"Yamato is a very good keep once your early game is already covered. She helps bridge into the midgame while keeping pressure on the opponent.",
		cards: [{ code: "OP13-054", name: "Yamato", img: "/Cards/OP13/OP13-054.jpg" }],
	},
];

const mulliganSendBackCards = [
	{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" },
	{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
	{ code: "ST22-015", name: "I Am Whitebeard!!", img: "/Cards/ST22/ST22-015.jpg" },
	{ code: "OP14-018", name: "Time for the Counterattack", img: "/Cards/OP14/OP14-018.jpg" },
	{
		code: "OP13-057",
		name: "If I Bowed Down to Power, What's the Point in Living?",
		img: "/Cards/OP13/OP13-057.jpg",
	},
];

const curveFirst = [
	{
		label: "1 DON",
		notes:
			"Look for the missing pieces. The goal isn't to be aggressive right away, but to build a functional hand.",
		cards: [
			{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" },
			{ code: "OP13-043", name: "Otama", img: "/Cards/OP13/OP13-043.jpg" },
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
		],
	},
	{
		label: "3 DON",
		notes:
			"Attach 1 DON!! to Ace whenever possible. Drawing on damage is one of the main reasons the deck exists.",
		cards: [
			{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg", badgeCard: "/Cards/P/Don_small.jpg" },
			{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" },
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
		],
	},
	{
		label: "5 DON",
		notes:
			"Marco locks down your defense. Atmos slows the opponent down. Yamato is better if you're setting up your next big turn.",
		cards: [
			{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
			{ code: "OP08-040", name: "Atmos", img: "/Cards/OP08/OP08-040.png" },
			{ code: "OP13-054", name: "Yamato", img: "/Cards/OP13/OP13-054.jpg" },
		],
	},
	{
		label: "7 DON",
		notes:
			"Jozu controls the board. Boa buys time. Zoro is the pressure option when you want to push harder.",
		cards: [
			{ code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" },
			{ code: "OP07-051", name: "Boa Hancock", img: "/Cards/OP07/OP07-051.png" },
			{ code: "EB04-007", name: "Roronoa Zoro", img: "/Cards/EB04/EB04-007.jpg" },
		],
	},
	{
		label: "9 DON",
		notes:
			"This is your best stabilization turn: huge body, blocker, pressure, and protection all at once.",
		cards: [
			{ code: "ST22-015", name: "I Am Whitebeard!!", img: "/Cards/ST22/ST22-015.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
	{
		label: "Late game",
		notes:
			"Roger is your finisher, not a card you play just because you drew it. Otherwise, keep looping Newgate when that's the cleaner line.",
		cards: [
			{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
];

const curveSecond = [
	{
		label: "2 DON",
		notes: "This turn matters a lot. You want to turn Ace on as early as possible.",
		cards: [
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
			{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" },
			{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg", badgeCard: "/Cards/P/Don_small.jpg" },
		],
	},
	{
		label: "4 DON",
		notes: "You slow the opponent down without emptying your hand.",
		cards: [
			{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
			{ code: "OP08-040", name: "Atmos", img: "/Cards/OP08/OP08-040.png" },
		],
	},
	{
		label: "6 DON",
		notes:
			"Yamato is often the best value line. Jozu and Boa are better when an opposing threat has to disappear.",
		cards: [
			{ code: "OP13-054", name: "Yamato", img: "/Cards/OP13/OP13-054.jpg" },
			{ code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" },
			{ code: "OP07-051", name: "Boa Hancock", img: "/Cards/OP07/OP07-051.png" },
		],
	},
	{
		label: "8 DON",
		notes: "You should be starting to lock the game down here.",
		cards: [
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
			{ code: "ST22-015", name: "I Am Whitebeard!!", img: "/Cards/ST22/ST22-015.jpg" },
		],
	},
	{
		label: "10 DON",
		notes: "The best turn isn't always Roger. Double action turns and Newgate loops are often stronger.",
		cards: [
			{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
];

const optionsCards = [
	{
		code: "OP10-045",
		name: "Cavendish",
		img: "/Cards/OP10/OP10-045.jpg",
		copy:
			"Play it if you want to see more cards against control decks or the mirror. It's worse if the format removes small bodies too easily.",
	},
	{
		code: "OP08-043",
		name: 'Edward.Newgate / "Taxbeard"',
		img: "/Cards/OP08/OP08-043.png",
		copy:
			"It's good into decks that need to play multiple cards in the same turn. It's useful against some control decks, but it's still more situational than Boa.",
	},
	{
		code: "OP14-017",
		name: "Chambres",
		img: "/Cards/OP14/OP14-017.jpg",
		copy: "A tempo card that can buy you a turn.",
	},
	{
		code: "OP06-058",
		name: "Gravity Blade Raging Tiger",
		img: "/Cards/OP06/OP06-058.png",
		copy:
			"An option if the format becomes more board-based. It's less important if the main threats are too big or protected.",
	},
];

const matchups = [
	{
		label: "Favored to Slightly Favored",
		tone: "up",
		icon: "↑",
		leader: { code: "OP16-060", name: "Purple Sengoku", img: "/Cards/OP16/OP16-060.jpg" },
		notes: [
			"Your card advantage helps you keep pace.",
			"Save your removal for their value pieces.",
			"Don't over-invest into a single character.",
		],
	},
	{
		label: "Difficult",
		tone: "down",
		icon: "↓",
		leader: { code: "OP16-080", name: "Black Yellow Teach", img: "/Cards/OP16/OP16-080.jpg" },
		notes: [
			"You need to make the most of your early game.",
			"Keep steady pressure on before their late game turns on.",
			"Teach's big 10-DON!! turns get hard to manage.",
		],
	},
	{
		label: "Even",
		tone: "even",
		icon: "≈",
		leader: { code: "OP16-079", name: "Black Yamato", img: "/Cards/OP16/OP16-079.jpg" },
		notes: [
			"Marco is excellent here.",
			"Protecting your resources matters more than protecting your life.",
		],
	},
	{
		label: "Favored",
		tone: "up",
		icon: "↑",
		leader: { code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
		notes: [
			"Attack the leader constantly.",
			"Don't waste time clearing the board if it doesn't matter.",
			"Force Nami to spend defensive resources.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: { code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg" },
		notes: [
			"You need to keep pressure on throughout the game.",
			"Roger and the big Newgate turns are usually your most important cards.",
		],
	},
];

const tips = [
	{
		copy: "Only take damage when your leader has a DON attached whenever possible.",
		cards: [{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" }],
	},
	{
		copy: "Marco is often your best resource generator.",
		cards: [{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" }],
	},
	{
		copy: "Don't waste the leader's -2000 effect on low-impact attacks.",
		cards: [{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" }],
	},
	{
		copy: "Against aggressive OP16 decks, managing your hand is often more important than managing your life total.",
		cards: [
			{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
		],
	},
	{
		copy: "The format has more protection effects than OP15, so plan around them before using your removal.",
		cards: [{ code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" }],
	},
	{
		copy: "Roger is a finisher, not the deck's main game plan.",
		cards: [{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" }],
	},
	{
		copy:
			"Most wins come from building resource advantage over the course of the game, not from a single explosive turn.",
		cards: [
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
			{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
		],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Portgas.D.Ace OP13 Deck Guide</h1>
				<p>
					Portgas.D.Ace is still one of the better value-oriented leaders in OP16, but this version has to be
					less greedy, more defensive, and less dependent on Roger. The goal is to keep the midrange value core
					intact while making the list smoother and safer across the format.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Portgas.D.Ace OP13 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="decklist-title-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<p>Main list for Portgas.D.Ace OP13 in the OP16 format.</p>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>
						Portgas.D.Ace is one of the best value-oriented leaders in the format, but starting with only 3
						life makes your opening hand stability essential. A good mulligan should set up your resource
						engine while still giving you a clean path into the midgame.
					</p>
				</div>
			</div>
			<div class="mulligan-stack">
				<div class="tip-card glow-block">
					<h3>Cards to Prioritize</h3>
					<div class="mulligan-rows">
						{mulliganKeeps.map((entry) => (
							<div class="mulligan-row">
								<div class="tip-cards">
									{entry.cards.map((card) => (
										<button
											class="mini-card"
											type="button"
											data-card-preview
											data-full={card.img}
											data-name={`${card.code} ${card.name}`}
										>
											<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
											<div class="mini-label">{card.name}</div>
										</button>
									))}
								</div>
								<div class="mulligan-copy">
									<p>{entry.copy}</p>
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="tip-card glow-block">
					<h3>Cards to Send Back</h3>
					<div class="sendback-grid">
						{mulliganSendBackCards.map((card) => (
							<button
								class="mini-card sendback-card"
								type="button"
								data-card-preview
								data-full={card.img}
								data-name={`${card.code} ${card.name}`}
							>
								<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
								<div class="mini-label sendback-label">{card.name}</div>
							</button>
						))}
					</div>
					<ul class="bullet-list">
						<li>Roger</li>
						<li>Multiple Newgate copies</li>
						<li>Too many late-game cards</li>
						<li>Too many events</li>
						<li>No setup card</li>
					</ul>
					<p class="mulligan-text">
						Ace can't afford a slow start when the leader only has 3 life. A balanced hand with a clean curve
						will usually perform better than a hand full of powerful cards you can't play for several turns.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Turn-by-turn reminders for going first and going second.</p>
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going First</h3>
				<div class="curve-rows">
					{curveFirst.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class={`mini-card curve-card ${card.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
											{card.badgeCard && <img class="card-badge-image" src={card.badgeCard} alt="1 DON!! attached" loading="lazy" />}
										</span>
										<div class="mini-label">{card.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going Second</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class={`mini-card curve-card ${card.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
											{card.badgeCard && <img class="card-badge-image" src={card.badgeCard} alt="1 DON!! attached" loading="lazy" />}
										</span>
										<div class="mini-label">{card.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Alternative cards and flex slots for different OP16 rooms.</p>
				</div>
			</div>
			<div class="options-rich-grid">
				{optionsCards.map((card) => (
					<div class="option-note-card glow-block">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							<div class="option-info">
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</button>
						<p>{card.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>How the main OP16 leaders line up against Ace.</p>
