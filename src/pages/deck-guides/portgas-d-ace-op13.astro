	{ code: "PRB02-008", name: "Marco", count: 4, img: "/Cards/PRB02/PRB02-008.jpg", role: "Character" },
	{ code: "OP13-054", name: "Yamato", count: 4, img: "/Cards/OP13/OP13-054.jpg", role: "Character" },
	{ code: "ST23-001", name: "Uta", count: 2, img: "/Cards/ST23/ST23-001.jpg", role: "Character" },
	{ code: "OP08-047", name: "Jozu", count: 4, img: "/Cards/OP08/OP08-047.png", role: "Character" },
	{ code: "OP07-051", name: "Boa Hancock", count: 3, img: "/Cards/OP07/OP07-051.png", role: "Character" },
	{ code: "EB04-007", name: "Roronoa Zoro", count: 3, img: "/Cards/EB04/EB04-007.jpg", role: "Character" },
	{ code: "OP13-042", name: "Edward.Newgate", count: 4, img: "/Cards/OP13/OP13-042.jpg", role: "Character" },
	{ code: "OP09-118", name: "Gol.D.Roger", count: 2, img: "/Cards/OP09/OP09-118.jpg", role: "Character" },
	{ code: "EB04-008", name: "Distorted Future", count: 2, img: "/Cards/EB04/EB04-008.jpg", role: "Event" },
	{ code: "ST22-015", name: "I Am Whitebeard!!", count: 4, img: "/Cards/ST22/ST22-015.jpg", role: "Event" },
];

const optionsGroups = [
	{
		cards: [
			{ code: "OP10-045", name: "Cavendish", img: "/Cards/OP10/OP10-045.jpg" },
			{ code: "OP08-043", name: "Edward.Newgate", img: "/Cards/OP08/OP08-043.png" },
			{ code: "OP14-017", name: "Chambres", img: "/Cards/OP14/OP14-017.jpg" },
		],
		note:
			"These are just some of the valid cards that can be inserted in the deck. Cavendish is a good option against Lucy where you need to see as many cards as possible, the problem is that it is removed in all ways such as Zeus, Nojiko, Barrier etc. Taxbeard and Shambles are useful to earn a turn or do control board against Enel P, they are not on the list because for me Boa is stronger and more versatile in this meta.",
	},
];

const mulliganCards = [
	{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" },
	{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
	{ code: "OP08-040", name: "Atmos", img: "/Cards/OP08/OP08-040.png" },
	{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
];

const curveFirst = [
	{
		label: "1 DON",
		notes: "1C for the missing pieces in the curve.",
		cards: [
			{ code: "OP13-043", name: "Otama", img: "/Cards/OP13/OP13-043.jpg" },
			{ code: "ST22-002", name: "Izo", img: "/Cards/ST22/ST22-002.jpg" },
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
		],
	},
	{
		label: "3 DON",
		notes: "Repeat last turn and give one DON to your leader for the ability and swing 7 face.",
		cards: [{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" }],
	},
	{
		label: "5 DON",
		notes: "Atmos/Marco + 1 DON to leader for decrease opponent's pressure or Yamato if you need card for next turn/combo.",
		cards: [
			{ code: "OP08-040", name: "Atmos", img: "/Cards/OP08/OP08-040.png" },
			{ code: "PRB02-008", name: "Marco", img: "/Cards/PRB02/PRB02-008.jpg" },
			{ code: "OP13-054", name: "Yamato", img: "/Cards/OP13/OP13-054.jpg" },
		],
	},
	{
		label: "7 DON",
		notes: "Jozu bounces one of your 1C and removes a useful 6C to remove a threat, Boa makes you earn 1 turn against Enel P and Zoro brings the leader to 7K base but you don't have the DON assigned necessary for the ability. The choice depends a lot on the situation and against which deck we are.",
		cards: [
			{ code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" },
			{ code: "EB04-007", name: "Roronoa Zoro", img: "/Cards/EB04/EB04-007.jpg" },
			{ code: "OP07-051", name: "Boa Hancock", img: "/Cards/OP07/OP07-051.png" },
		],
	},
	{
		label: "9 DON",
		notes: "There's the strongest combo for the strongest Character, the father! Or take life if you need more time or if you are playing for Roger.",
		cards: [
			{ code: "ST22-015", name: "I Am Whitebeard!!", img: "/Cards/ST22/ST22-015.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
	{
		label: "Late game",
		notes: "You can repeat your last turn or if you are in the right setup Roger is the card needed to finish the match saying goodbye to the opposing blockers.",
		cards: [{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" }],
	},
];

const curveSecond = [
	{
		label: "2 DON",
		notes: "1C for the missing pieces in the curve + 1 DON to leader for the ability.",
		cards: [
			{ code: "OP13-016", name: "Monkey.D.Garp", img: "/Cards/OP13/OP13-016.jpg" },
			{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" },
		],
	},
