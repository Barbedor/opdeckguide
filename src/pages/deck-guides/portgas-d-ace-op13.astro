		cards: [
			{ code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" },
			{ code: "OP07-051", name: "Boa Hancock", img: "/Cards/OP07/OP07-051.png" },
			{ code: "OP13-054", name: "Yamato", img: "/Cards/OP13/OP13-054.jpg" },
		],
	},
	{
		label: "8 DON",
		notes: "There's the strongest combo for the strongest Character, the father! Or take life if you need more time or if you are playing for Roger.",
		cards: [
			{ code: "ST22-015", name: "I Am Whitebeard!!", img: "/Cards/ST22/ST22-015.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
	{
		label: "Late game",
		notes: "You can repeat your last turn or if you are in the right setup Roger is the card needed to finish the match saying goodbye to the opposing blockers.",
		cards: [{ code: "OP09-118", name: "Gol.D.Roger", img: "/Cards/OP09/OP09-118.jpg" }],
	},
];

const tips = [
	{
		title:
			"The deck doesn't have great tips or special combos, you have to remember which cards the searchers have seen to know when or what will arrive once you have turned the whole deck because it will happen. Another suggestion is not to be afraid to discard for the Leader's ability but to do it with intelligence because in late game you also have to prepare for an opponent Roger.",
		cards: [{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" }],
	},
];

const matchups = [
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP13-001", name: "Monkey.D.Luffy", img: "/Cards/OP13/OP13-001.jpg" },
		notes: ["Start 2nd", "Atmos/Jozu key cards", "You win in late game"],
	},
	{
		label: "Negative MU",
		icon: "↓",
		leader: { code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg" },
		notes: ["Start 1st", "Control oppo board", "Boa key card"],
	},
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
		notes: ["Start 2nd", "Manage your live", "Control oppo board"],
	},
	{
		label: "Even",
		icon: "≈",
		leader: { code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" },
		notes: ["Start 2nd", "Manage your board", "Spam your Jozu"],
	},
	{
		label: "Slight Adv.",
		icon: "↑",
		leader: { code: "OP15-098", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-098.jpg" },
		notes: ["Start 2nd", "Force Leader ability", "Go only face"],
	},
	{
		label: "Negative MU",
		icon: "↓",
		leader: { code: "OP15-002", name: "Lucy", img: "/Cards/OP15/OP15-002.jpg" },
		notes: ["Start 2nd", "Go aggro", "Control oppo board"],
