---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Buggy OP16 Preview Deck Guide";
const description =
	"Buggy OP16 preview deck guide for One Piece Card Game with an early decklist idea, the clown package, the old-set shell, and early strengths and weaknesses.";

const icon = "/assets/guides/Buggy%20op16.png";
const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP16-041", name: "Buggy", count: 1, img: "/Cards/OP16/OP16-041.jpg", role: "Leader" },
	{ code: "OP16-054", name: "Mr.1(Daz.Bonez)", count: 4, img: "/Cards/OP16/OP16-054.jpg", role: "Character" },
	{ code: "OP16-055", name: "Mr.2.Bon.Kurei(Bentham)", count: 4, img: "/Cards/OP16/OP16-055.jpg", role: "Character" },
	{ code: "OP16-045", name: "Crocodile", count: 4, img: "/Cards/OP16/OP16-045.jpg", role: "Character" },
	{ code: "OP16-056", name: "Mr.3(Galdino)", count: 4, img: "/Cards/OP16/OP16-056.jpg", role: "Character" },
	{ code: "OP16-044", name: "Emporio.Ivankov", count: 4, img: "/Cards/OP16/OP16-044.jpg", role: "Character" },
	{ code: "OP16-048", name: "Buggy", count: 4, img: "/Cards/OP16/OP16-048.jpg", role: "Character" },
	{ code: "OP16-050", name: "Miss Olive", count: 4, img: "/Cards/OP16/OP16-050.jpg", role: "Character" },
	{ code: "OP16-042", name: "Prisoner of Impel Down", count: 18, img: "/Cards/OP16/OP16-042.jpg", role: "Character" },
	{ code: "OP16-058", name: "The Prisoners Are Rioting!!", count: 2, img: "/Cards/OP16/OP16-058.jpg", role: "Event" },
	{ code: "EB01-028", name: "Gum-Gum Champion Rifle", count: 2, img: "/Cards/EB01/EB01-028.png", role: "Event" },
];
const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const leaderCard = { code: "OP16-041", name: "Buggy", img: "/Cards/OP16/OP16-041.jpg" };

const spoilerCards = [
	{
		code: "OP16-042",
		name: "Prisoner of Impel Down",
		img: "/Cards/OP16/OP16-042.jpg",
	},
	{
		code: "OP16-048",
		name: "Buggy",
		img: "/Cards/OP16/OP16-048.jpg",
	},
	{
		code: "OP16-056",
		name: "Mr.3(Galdino)",
		img: "/Cards/OP16/OP16-056.jpg",
	},
];

const prepPackage = [
	{ count: 4, code: "ST12-010", name: "Emporio Ivankov", img: "/Cards/ST12/ST12-010.png" },
	{ count: 4, code: "OP14-052", name: "Hannyabal", img: "/Cards/OP14/OP14-052.jpg" },
	{ count: 4, code: "EB01-022", name: "Inazuma", img: "/Cards/EB01/EB01-022.png" },
	{ count: 4, code: "OP08-047", name: "Jozu", img: "/Cards/OP08/OP08-047.png" },
	{ count: 4, code: "EB01-028", name: "Gum Gum Champion Rifle", img: "/Cards/EB01/EB01-028.png" },
	{ count: 4, code: "OP07-056", name: "Slave Arrow", img: "/Cards/OP07/OP07-056.png" },
];

const strengths = [
	"Very strong at swarming the board",
	"Excellent tempo thanks to blue",
	"Constant pressure",
	"Very good into slower decks",
];

const weaknesses = [
	"Low raw power on its characters",
	"Too dependent on keeping a full board",
	"Loses to purple decks",
	"Does not have many instant-win finishers",
];

const conclusion =
	"The deck looks very fun, but it's clearly not in the running to become the new BDIF. That said, you can still lean into the meme and play 50 copies of the same card. For me, it's still missing some cards, like a 7-cost or higher character or a searcher. For those reasons, I'd put the deck at 6.5 / 10.";
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Buggy OP16 Preview Deck Guide</h1>
				<p>
					First look at Buggy OP16 in the OP16 format. This preview focuses on the leader effect, the key
					spoilers, an early decklist idea, and the early read on the blue Impel Down shell.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#thoughts">Early Thoughts</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Buggy OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header">
				<div class="section-heading-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<div>
					<p class="decklist-intro">An early decklist idea for Buggy OP16 in the OP16 format.</p>
				</div>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="leader" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Leader</h2>
					<p>Core identity and leader effect for Buggy OP16-041.</p>
				</div>
			</div>
			<div class="leader-card">
				<button
					class="leader-preview"
					type="button"
					data-card-preview
					data-full={leaderCard.img}
					data-name={`${leaderCard.code} ${leaderCard.name}`}
				>
					<img loading="lazy" src={leaderCard.img} alt={`${leaderCard.code} ${leaderCard.name}`} />
				</button>
				<div class="leader-copy">
					<div class="fact-grid">
						<div class="fact-box">
							<span class="fact-label">Color</span>
							<p>Blue</p>
						</div>
						<div class="fact-box">
							<span class="fact-label">Type</span>
							<p>Impel Down / Buggy Pirates</p>
						</div>
					</div>
					<div class="text-card">
						<h3>Leader Effect</h3>
						<p class="effect-copy">
							<img class="keyword-badge" src="/assets/keywords/don-x1.png" alt="DON!! x1" />
							<img class="keyword-badge" src="/assets/keywords/once-per-turn.png" alt="Once Per Turn" />
							This effect can be activated when your {"{Impel Down}"} type Character card is removed from the
							field. Play up to 1 [Prisoner of Impel Down] card from your hand.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="spoiler" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Key preview cards</h2>
					<p>Main cards that define the clown package.</p>
				</div>
			</div>
			<div class="loop-grid loop-grid-three">
				{spoilerCards.map((card) => (
					<div class="loop-card spoiler-three-card">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="text-card">
							<h3>{card.name}</h3>
							<div class="ability-stack">
								{card.code === "OP16-042" ? (
									<div class="ability-line">
										<span>Under the rules of this game, you may have any number of this card in your deck.</span>
									</div>
								) : card.code === "OP16-048" ? (
									<>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/on-play.png" alt="On Play" />
												<span>
													If your Leader has the {"{Impel Down}"} type, draw 1 card and play up to 1 [Prisoner
													of Impel Down] from your hand.
												</span>
											</span>
										</div>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/once-per-turn.png" alt="Once Per Turn" />
												<span>
													This effect can be activated when your opponent attacks. Up to 1 of your [Prisoner of
													Impel Down] cards gains Blocker during this turn.
												</span>
											</span>
										</div>
									</>
								) : (
									<div class="ability-line">
										<span class="ability-inline">
											<img class="keyword-badge" src="/assets/keywords/activate-main.png" alt="Activate Main" />
											<span>
												You may trash this Character: draw 2 cards, and up to 1 of your opponent's
												Characters with a cost of 9 or less cannot attack until the end of your opponent's
												next End Phase.
											</span>
										</span>
									</div>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="prep" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Prep</h2>
					<p>Old-set support that helps hold the shell together.</p>
				</div>
			</div>
			<div class="prep-card">
				<p class="prep-intro">The list still leans on a sizable older shell for consistency and utility.</p>
				<div class="prep-grid">
					{prepPackage.map((entry) => (
						<button
							class="prep-chip"
							type="button"
							data-card-preview
							data-full={entry.img}
							data-name={entry.code}
						>
							<img loading="lazy" src={entry.img} alt={entry.code} />
							<div class="prep-copy">
								<span class="prep-code">{entry.code}</span>
								<span class="prep-name">{entry.name}</span>
							</div>
						</button>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="thoughts" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Thoughts</h2>
					<p>Strengths, weaknesses, and conclusion.</p>
				</div>
			</div>
			<div class="thoughts-grid">
				<div class="thought-card">
					<div class="thought-head thought-up">
						<span class="thought-icon" aria-hidden="true">+</span>
						<h3>Strengths</h3>
					</div>
					<ul>
						{strengths.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
				<div class="thought-card">
					<div class="thought-head thought-down">
						<span class="thought-icon" aria-hidden="true">-</span>
						<h3>Weaknesses</h3>
					</div>
					<ul>
						{weaknesses.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</div>
			<div class="conclusion-card">
				<div class="conclusion-head">
					<div>
						<h3>Conclusion</h3>
					</div>
					<div class="score-badge">6.5 / 10</div>
				</div>
				<p>{conclusion}</p>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<div class="card-modal-frame">
				<img src="" alt="" data-modal-image />
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalFrame = document.querySelector(".card-modal-frame");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	let lockedScrollY = 0;

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		lockedScrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${lockedScrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
		document.body.style.overflow = "hidden";
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		document.body.style.overflow = "";
		window.scrollTo(0, lockedScrollY);
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target === modalImage) {
			closeModal();
			return;
		}
		if (modalFrame && !modalFrame.contains(target) && target !== closeButton) {
			closeModal();
		}
	});
	modalImage?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	const copySimButton = document.querySelector("[data-copy-sim]");

	copySimButton?.addEventListener("click", async () => {
		const deckCode = copySimButton.getAttribute("data-sim-deck");
		if (!deckCode) return;

		try {
			await navigator.clipboard.writeText(deckCode);
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = deckCode;
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		}

		copySimButton.textContent = "Copied!";
		window.setTimeout(() => {
			copySimButton.textContent = "Copy for Sim";
		}, 1800);
	});
</script>

<style>
	.copy-sim-button {
		font-family: inherit;
		font-weight: 700;
	}

	.section-heading-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
	}

	.section-heading-row h2 {
		margin: 0;
	}

	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.leader-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.loop-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.leader-card {
		display: grid;
		grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
	}

	.leader-preview,
	.option-card {
		border: none;
		background: transparent;
		padding: 0;
		cursor: pointer;
	}

	.leader-preview img,
	.option-card img {
		width: 100%;
		border-radius: 14px;
		display: block;
	}

	.leader-copy,
	.loop-grid,
	.thoughts-grid {
		display: grid;
		gap: 1rem;
	}

	.fact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.fact-box,
	.text-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.deck-card {
		padding: 1rem;
	}

	.fact-box {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border);
		border-radius: 14px;
	}

	.fact-label {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		margin-bottom: 0.45rem;
	}

	.fact-box p,
	.text-card p,
	.prep-intro,
	.section-note {
		margin: 0;
		color: var(--text-200);
	}

	.text-card h3,
	.thought-card h3,
	.conclusion-card h3 {
		margin-top: 0;
		margin-bottom: 0.6rem;
	}

	.text-card ul,
	.thought-card ul {
		margin: 0;
		padding-left: 1.15rem;
	}

	.effect-copy {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.keyword-badge {
		height: 24px;
		width: auto;
		vertical-align: middle;
		flex: 0 0 auto;
		transform: translateY(4px);
		margin: 0 0.12rem;
	}

	.ability-inline {
		display: inline;
	}

	.ability-inline .keyword-badge {
		display: inline-block;
		height: 18px;
		margin-right: 0.35rem;
		vertical-align: middle;
		transform: translateY(-1px);
	}

	.effect-copy .keyword-badge {
		height: 18px;
	}

	.effect-copy > .keyword-badge {
		transform: translateY(-2px);
		margin-right: 0.35rem;
	}

	.ability-stack {
		display: grid;
		gap: 0.55rem;
	}

	.ability-line {
		margin: 0;
		color: var(--text-100);
	}

	.loop-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-bottom: 1rem;
	}

	#spoiler .loop-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.loop-card {
		display: grid;
		grid-template-columns: 160px minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
		align-items: start;
	}

	.spoiler-three-card {
		grid-template-columns: 1fr;
	}

	.spoiler-three-card .option-card {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		height: 300px;
	}

	.spoiler-three-card .option-card img {
		max-width: 200px;
		max-height: 280px;
		margin: 0 auto;
	}

	.spoiler-three-card .text-card {
		display: flex;
		flex-direction: column;
	}

	.spoiler-three-card .text-card h3 {
		min-height: 2.8em;
		margin-bottom: 0.85rem;
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	@media (min-width: 901px) {
		.decklist-intro {
			white-space: nowrap;
		}
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible,
	.leader-preview:hover,
	.leader-preview:focus-visible,
	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		outline: none;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code,
	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.prep-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1rem;
	}

	.prep-chip {
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		text-align: left;
		display: grid;
		gap: 0.65rem;
		align-content: start;
		color: var(--text-100);
		cursor: pointer;
	}

	.prep-chip img {
		width: 100%;
		max-width: 110px;
		height: auto;
		border-radius: 10px;
		margin: 0 auto;
	}

	.prep-copy {
		display: grid;
		gap: 0.2rem;
	}

	.prep-count,
	.prep-code {
