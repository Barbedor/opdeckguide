---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Buggy OP16 Deck Guide";
const description =
	"Buggy OP16 deck guide for One Piece Card Game with decklist, mulligan priorities, a going-second curve guide, tech cards, matchup notes, and gameplay tips.";

const icon = "/assets/guides/Buggy%20op16.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const card = (code, name, img) => ({ code, name, img });

const buggyLeader = card("OP16-041", "Buggy", "/Cards/OP16/OP16-041.jpg");
const mr1 = card("OP16-054", "Mr.1 (Daz Bonez)", "/Cards/OP16/OP16-054.jpg");
const mr2 = card("OP16-055", "Mr.2 Bon Clay (Bentham)", "/Cards/OP16/OP16-055.jpg");
const crocodile = card("OP16-045", "Crocodile", "/Cards/OP16/OP16-045.jpg");
const mr3 = card("OP16-056", "Mr.3 (Galdino)", "/Cards/OP16/OP16-056.jpg");
const buggyCharacter = card("OP16-048", "Buggy", "/Cards/OP16/OP16-048.jpg");
const missOlive = card("OP16-050", "Miss Olive", "/Cards/OP16/OP16-050.jpg");
const prisoner = card("OP16-042", "Prisoner of Impel Down", "/Cards/OP16/OP16-042.jpg");
const slaveArrow = card("OP07-056", "Slave Arrow", "/Cards/OP07/OP07-056.png");
const gravityBlade = card("OP06-058", "Gravity Blade Raging Tiger", "/Cards/OP06/OP06-058.png");
const ivankov = card("OP16-044", "Emporio Ivankov", "/Cards/OP16/OP16-044.jpg");
const sanji = card("OP15-047", "Sanji", "/Cards/OP15/OP15-047.jpg");
const jozu = card("OP08-047", "Jozu", "/Cards/OP08/OP08-047.png");
const prisonersRioting = card("OP16-058", "The Prisoners Are Rioting!!", "/Cards/OP16/OP16-058.jpg");

const teach16 = card("OP16-080", "Marshall.D.Teach OP16", "/Cards/OP16/OP16-080.jpg");
const rosinante12 = card("OP12-061", "Donquixote Rosinante OP12", "/Cards/OP12/OP12-061.jpg");
const nami11 = card("OP11-041", "Nami OP11", "/Cards/OP11/OP11-041.jpg");
const luffy16 = card("OP16-022", "Monkey.D.Luffy OP16", "/Cards/OP16/OP16-022.jpg");
const enel15 = card("OP15-058", "Enel OP15", "/Cards/OP15/OP15-058.jpg");

const decklist = [
	{ ...buggyLeader, count: 1, role: "Leader" },
	{ ...mr1, count: 4, role: "Character" },
	{ ...mr2, count: 4, role: "Character" },
	{ ...crocodile, count: 4, role: "Character" },
	{ ...mr3, count: 4, role: "Character" },
	{ ...buggyCharacter, count: 4, role: "Character" },
	{ ...missOlive, count: 4, role: "Character" },
	{ ...prisoner, count: 20, role: "Character" },
	{ ...slaveArrow, count: 4, role: "Event" },
	{ ...gravityBlade, count: 2, role: "Event" },
];

const simDeckCode = decklist.flatMap((entry) => expandSimLines(entry.count, entry.code)).join("\n");

const mulliganKeeps = [
	{
		copy:
			"One of the best starts in the deck. It draws a card on play, swings at 6000 with just 1 DON!! attached, and once Crocodile removes it from your board, the leader turns that exchange into a Prisoner of Impel Down.",
		cards: [mr1],
	},
	{
		copy:
			"It plays the same early role as Mr.1. It draws a card on play, often attacks at 6000, 7000, or even 8000 depending on the matchup, and still turns into a Prisoner of Impel Down once Crocodile bounces it.",
		cards: [mr2],
	},
	{
		copy:
			"Even with 20 copies in the deck, having one in your opener is still great because it guarantees your leader effect is online the moment one of your characters gets removed from the board.",
		cards: [prisoner],
	},
];

const idealHandCards = [mr1, mr2, prisoner, crocodile];

const curveSecond = [
	{
		label: "2 DON!!",
		notes: "Play Mr.1 or Mr.2. These are your best opening plays.",
		cards: [mr1, mr2],
	},
	{
		label: "4 DON!!",
		notes:
			"You either deploy two more 2-cost characters or start attacking while keeping 1 DON!! on the leader so the effect stays live. If one of your characters gets removed, it immediately turns into a Prisoner of Impel Down.",
		cards: [
			mr1,
			mr2,
			{ ...buggyLeader, badgeCard: "/Cards/P/Don_small.jpg" },
		],
	},
	{
		label: "6 DON!!",
		notes:
			"Crocodile is usually the best play here: bounce one of your 2-cost characters, play a Prisoner of Impel Down, replay the bounced character, and draw again. That's where the deck really starts snowballing.",
		cards: [crocodile, prisoner, mr1],
	},
	{
		label: "8 DON!!",
		notes:
			"Miss Olive lets you bounce a character, play a Prisoner of Impel Down, then draw two and trash one. From there, the deck keeps stacking 6000-power swings while staying ahead on board and in hand.",
		cards: [missOlive, prisoner, mr2],
	},
	{
		label: "10 DON!!",
		notes:
			"At this point your board is usually full. Keep attacking with everything and try to leave DON!! up for your defensive events whenever the game state allows it.",
		cards: [prisoner, mr1, slaveArrow],
	},
	{
		label: "Late game",
		notes:
			"Buggy usually closes games by repeating wide attack turns. Once the board is built, the deck wins through volume and pressure more than through a single giant finisher.",
		cards: [prisoner, buggyCharacter, crocodile],
	},
];

const optionsCards = [
	{
		...ivankov,
		copy:
			"A good defensive option. It works as a blocker first, then turns into a Prisoner of Impel Down when it leaves the field. I still prefer the more aggressive version of the deck.",
	},
	{
		...sanji,
		copy:
			"It gives unblockable to one of your characters while also being a blocker itself. It's very useful into decks that lean heavily on blockers, and very few opponents expect to see it here.",
	},
	{
		...jozu,
		copy:
			"An excellent tempo option. By returning one of your own characters, you trigger a Prisoner of Impel Down and still bounce an opposing cost 6 or lower character. It's especially strong against big curve plays.",
	},
	{
		...prisonersRioting,
		copy:
			"An interesting alternative. At 10 DON!!, all of your Prisoners of Impel Down become 7000-power characters. In counter, it also gives your leader +4000 power for just 1 DON!!.",
	},
];

const matchups = [
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: teach16,
		notes: [
			"The matchup gets harder the better Teach players understand their deck.",
			"Your results are better when Buggy goes second.",
			"Go second whenever you can.",
			"Develop your board quickly before Teach gets full control online.",
			"Use your repeated 6000-power attacks to drain their hand before the blockers start stacking up.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: rosinante12,
		notes: [
			"Rosinante protects its characters well, which makes Buggy's repeated attacks less efficient.",
			"Gravity Blade is especially strong in this matchup.",
			"Save Gravity Blade for key characters like Rosinante or Law.",
			"Keep developing multiple Prisoners of Impel Down so the pressure never disappears.",
			"Don't waste resources on character exchanges that don't actually improve the board state.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: nami11,
		notes: [
			"Nami is tricky because Buggy leans on repeated 6000-power attacks while Nami can raise the leader's power and drag the game out.",
			"Go second.",
			"Keep the pressure high from the very first turns.",
			"Push for 7000-power attacks whenever the window is there.",
			"Use Gravity Blade Raging Tiger to remove the opposing cards that would snowball too much value.",
		],
	},
	{
		label: "Even",
		tone: "even",
		icon: "≈",
		leader: luffy16,
		notes: [
			"The matchup is very balanced overall, but Buggy's numbers improve when it goes second.",
			"Go second.",
			"Pressure the game quickly with your 2-cost characters.",
			"Try to keep a wide board so you can multiply the number of attacks each turn.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: enel15,
		notes: [
			"Purple Enel can develop huge threats while generating a lot of value over time.",
			"If Buggy can't keep the pressure on right away, Enel usually takes over the pace of the game.",
			"Go first.",
			"Put Enel under pressure before their setup is fully online.",
			"Build a wide board so you can keep throwing multiple attacks every turn.",
			"Use Gravity Blade Raging Tiger to answer the most annoying characters and hold tempo.",
		],
	},
];

const tips = [
	{
		copy: "Go second whenever you have the choice.",
		cards: [buggyLeader],
	},
	{
		copy: "Always keep 1 DON!! on your leader so the effect stays available.",
		cards: [{ ...buggyLeader, badgeCard: "/Cards/P/Don_small.jpg" }],
	},
	{
		copy:
			"Don't be afraid to see your characters leave the board. They'll often be replaced immediately by Prisoners of Impel Down.",
		cards: [prisoner],
	},
	{
		copy:
			"Your 2-cost characters are the real engine of the deck, so keep replaying them as often as you can in the early turns.",
		cards: [mr1, mr2],
	},
	{
		copy:
			"Use Crocodile and Miss Olive to recycle your characters while putting more Prisoners of Impel Down onto the field.",
		cards: [crocodile, missOlive],
	},
	{
		copy:
			"Slave Arrow is one of the best defensive tools in the deck because it protects you while also helping keep the leader effect active.",
		cards: [slaveArrow],
	},
	{
		copy:
			"Gravity Blade is a great answer into several current meta decks, especially Rosinante, Red/Green Luffy & Ace, and Teach.",
		cards: [gravityBlade],
	},
	{
		copy:
			"The deck wins mostly through repeated 6000- and 7000-power attacks, not through one oversized finisher.",
		cards: [mr1, mr2, prisoner],
	},
	{
		copy:
			"If your board is already full, shift your focus to pressuring opposing Life instead of adding more characters.",
		cards: [prisoner, buggyCharacter],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Buggy OP16 Deck Guide</h1>
				<p>
					Buggy OP16 is a wide-board blue deck that turns every removal exchange into more pressure. The list
					wins by looping value off its 2-cost starters, flooding Prisoners of Impel Down, and attacking over
					and over with a board that never really stays empty.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Buggy OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="decklist-title-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<p>Main list for Buggy OP16 in the OP16 format.</p>
			</div>
			<div class="deck-grid">
				{decklist.map((entry) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={entry.img}
						data-name={`${entry.code} ${entry.name}`}
					>
						<img loading="lazy" src={entry.img} alt={`${entry.code} ${entry.name}`} />
						<div class="deck-info">
							<span class="deck-count">{entry.count}x</span>
							<div>
								<div class="deck-name">{entry.name}</div>
								<div class="deck-code">{entry.code}</div>
							</div>
						</div>
						<span class="deck-role">{entry.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>
						The mulligan is very simple. More than anything else, the deck wants to see its 2-cost characters,
						because they're the most important cards in the first turns.
					</p>
				</div>
			</div>
			<div class="mulligan-stack">
				<div class="tip-card glow-block">
					<h3>Cards to Prioritize</h3>
					<div class="mulligan-rows">
						{mulliganKeeps.map((entry) => (
							<div class="mulligan-row">
								<div class="tip-cards">
									{entry.cards.map((entryCard) => (
										<button
											class="mini-card"
											type="button"
											data-card-preview
											data-full={entryCard.img}
											data-name={`${entryCard.code} ${entryCard.name}`}
										>
											<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											<div class="mini-label">{entryCard.name}</div>
										</button>
									))}
								</div>
								<div class="mulligan-copy">
									<p>{entry.copy}</p>
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="tip-card glow-block">
					<h3>Ideal Hand</h3>
					<div class="sendback-grid ideal-grid">
						{idealHandCards.map((entryCard) => (
							<button
								class="mini-card sendback-card"
								type="button"
								data-card-preview
								data-full={entryCard.img}
								data-name={`${entryCard.code} ${entryCard.name}`}
							>
								<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
								<div class="mini-label sendback-label">{entryCard.name}</div>
							</button>
						))}
					</div>
					<ul class="bullet-list">
						<li>At least one Mr.1 or Mr.2</li>
						<li>A Prisoner of Impel Down</li>
						<li>Enough follow-up to keep developing the board on the next turns</li>
					</ul>
					<p class="mulligan-text">
						The deck isn't looking for big cards early. It only wants to get its game plan online as quickly as
						possible.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Going second is the recommended seat because Buggy has better results in that setup.</p>
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going Second</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((entryCard) => (
									<button
										class={`mini-card curve-card ${entryCard.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={entryCard.img}
										data-name={`${entryCard.code} ${entryCard.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											{entryCard.badgeCard && (
												<img class="card-badge-image" src={entryCard.badgeCard} alt="1 DON!! attached" loading="lazy" />
											)}
										</span>
										<div class="mini-label">{entryCard.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tech Cards</h2>
					<p>Alternative cards and flex slots for different OP16 rooms.</p>
				</div>
			</div>
			<div class="options-rich-grid">
				{optionsCards.map((entryCard) => (
					<div class="option-note-card glow-block">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={entryCard.img}
							data-name={`${entryCard.code} ${entryCard.name}`}
						>
							<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
							<div class="option-info">
								<div class="deck-name">{entryCard.name}</div>
								<div class="deck-code">{entryCard.code}</div>
							</div>
						</button>
						<p>{entryCard.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>How the main OP16 leaders line up against Buggy.</p>
				</div>
			</div>
			<div class="matchups-stack">
				{matchups.map((matchup) => (
					<div class="matchup-card glow-block">
						<div class={`matchup-badge ${matchup.tone === "down" ? "badge-down" : matchup.tone === "even" ? "badge-even" : "badge-up"}`}>
							<span class="badge-icon">{matchup.icon}</span>
							<span>{matchup.label}</span>
						</div>
						<div class="matchup-row">
							<div class="tip-cards">
								<button
									class="mini-card"
									type="button"
									data-card-preview
									data-full={matchup.leader.img}
									data-name={`${matchup.leader.code} ${matchup.leader.name}`}
								>
									<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
									<div class="mini-label">{matchup.leader.name}</div>
								</button>
							</div>
							<ul class="bullet-list matchup-list">
								{matchup.notes.map((note) => (
									<li>{note}</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Core reminders for Buggy in the OP16 format.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class={`tip-card glow-block ${tip.cards.length > 1 ? "multi-card-tip" : ""}`}>
						<div class={`tip-row ${tip.cards.length > 1 ? "multi-card-tip-row" : ""}`}>
							<div class="tip-cards">
								{tip.cards.map((entryCard) => (
									<button
										class={`mini-card ${entryCard.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={entryCard.img}
										data-name={`${entryCard.code} ${entryCard.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											{entryCard.badgeCard && (
												<img class="card-badge-image" src={entryCard.badgeCard} alt="1 DON!! attached" loading="lazy" />
											)}
										</span>
										<div class="mini-label">{entryCard.name}</div>
									</button>
								))}
							</div>
							<p>{tip.copy}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	const copyButtons = document.querySelectorAll("[data-copy-sim]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	copyButtons.forEach((button) => {
		button.addEventListener("click", async () => {
			const value = button.getAttribute("data-sim-deck") ?? "";
			if (!value) return;
			try {
				await navigator.clipboard.writeText(value);
				const previous = button.textContent;
				button.textContent = "Copied!";
				setTimeout(() => {
					button.textContent = previous ?? "Copy for Sim";
				}, 1400);
			} catch {
				button.textContent = "Copy failed";
				setTimeout(() => {
					button.textContent = "Copy for Sim";
				}, 1400);
			}
		});
	});
</script>

<style>
	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.decklist-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: start;
		column-gap: 1rem;
		row-gap: 0.45rem;
	}

	.decklist-title-row {
		display: contents;
	}

	.decklist-title-row h2,
	.decklist-header p {
		margin: 0;
	}

	.decklist-title-row h2 {
		grid-column: 1;
