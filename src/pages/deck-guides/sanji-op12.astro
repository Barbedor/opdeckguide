---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Sanji OP12 Deck Guide</h1>
				<p>
					Reference guide for Sanji OP12 in the OP15 format with the full list, mulligan priorities, curve
					checkpoints, event-heavy midgame lines, and quick matchup plans. Built to stay easy to scan between rounds.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Sanji OP12 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Decklist</h2>
					<p>Main list for Sanji OP12.</p>
				</div>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Flexible choices that support specific board states or defensive turns.</p>
				</div>
			</div>
			<div class="options-grid options-grid-detailed">
				{options.map((card) => (
					<div class="option-item">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							<div class="option-info">
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</button>
						<p class="option-note">{card.note}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>Prioritize the pieces that find Sanji quickly and keep the trash and event flow online.</p>
				</div>
			</div>
			<div class="mulligan-grid">
				{mulliganCards.map((card) => (
					<button
						class="mini-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="mini-label">{card.name}</div>
					</button>
				))}
			</div>
			<p class="mulligan-text">
				OP12-070 Sanji + Lady&apos;s Teardrops is the clean start: it finds Sanji while also filling the trash.
				Let&apos;s Crash This Wedding is another strong opener because it searches for OP12-070 Sanji, and Boeuf Burst
				is the event you most want to have ready for the midgame or for the draw 2 cards.
			</p>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Turn checkpoints for the search package, Sanji setup turns, and your late-game event finishers.</p>
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve</h3>
				<div class="curve-rows">
					{curve.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Three key lines to keep in mind while piloting the deck.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class="tip-card">
						<div class="tip-flow">
							{tip.flow.map((item) =>
								item.type === "card" ? (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={item.img}
										data-name={`${item.code} ${item.name}`}
									>
										<img loading="lazy" src={item.img} alt={`${item.code} ${item.name}`} />
									</button>
								) : null
							)}
						</div>
						<div class="tip-copy">
							<h3>{tip.title}</h3>
							<p>{tip.text}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>Quick matchup reminders and the main cards or finishers that matter in each pairing.</p>
				</div>
			</div>
			<div class="matchups-grid">
				{matchups.map((matchup) => (
					<div class="matchup-card">
						<div class={`matchup-badge ${matchup.label.includes("Negative") || matchup.label.includes("Disadv") ? "badge-down" : matchup.label === "Even" ? "badge-even" : "badge-up"}`}>
							<span class={`badge-icon ${matchup.label.includes("Negative") || matchup.label.includes("Disadv") ? "badge-icon-down" : matchup.label === "Even" ? "badge-icon-even" : "badge-icon-up"}`} aria-hidden="true"></span>
							<span>{matchup.label}</span>
						</div>
						<button
							class="mini-card"
							type="button"
							data-card-preview
							data-full={matchup.leader.img}
							data-name={`${matchup.leader.code} ${matchup.leader.name}`}
						>
							<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
						</button>
						<div class="matchup-name">{matchup.leader.name}</div>
						<ul>
							{matchup.notes.map((note) => (
								<li>{note}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});
</script>

<style>
	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 0.9rem;
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible,
	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

