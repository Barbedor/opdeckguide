---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Donquixote Rosinante OP12 Deck Guide";
const description =
	"Donquixote Rosinante OP12 deck guide for One Piece Card Game with decklist, combos, options, matchup notes, mirror tips, and closing thoughts.";

const icon = "/assets/guides/rosinante-op12.png";
const metaArticleHref = "/meta-analysis/Purple-Yellow-Rosinante-op12-stats/";
const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP12-061", name: "Donquixote Rosinante", count: 1, img: "/Cards/OP12/OP12-061.jpg", role: "Leader" },
	{ code: "OP16-078", name: "Marineford", count: 4, img: "/Cards/OP16/OP16-078.jpg", role: "Stage" },
	{ code: "OP16-064", name: "Koby", count: 4, img: "/Cards/OP16/OP16-064.jpg", role: "Character" },
	{ code: "OP12-108", name: "Donquixote Rosinante", count: 2, img: "/Cards/OP12/OP12-108.jpg", role: "Character" },
	{ code: "OP10-114", name: "X.Drake", count: 4, img: "/Cards/OP10/OP10-114.jpg", role: "Character" },
	{ code: "P-093", name: "Trafalgar Law", count: 4, img: "/Cards/P/P-093.jpg", role: "Character" },
	{ code: "ST10-010", name: "Trafalgar Law", count: 4, img: "/Cards/ST10/ST10-010.png", role: "Character" },
	{ code: "P-088", name: "Trafalgar Law", count: 4, img: "/Cards/P/P-088.jpg", role: "Character" },
	{ code: "EB04-058", name: "Borsalino", count: 4, img: "/Cards/EB04/EB04-058.jpg", role: "Character" },
	{ code: "EB04-038", name: "Rosinante & Law", count: 4, img: "/Cards/EB04/EB04-038.jpg", role: "Character" },
	{ code: "OP16-065", name: "Sakazuki", count: 4, img: "/Cards/OP16/OP16-065.jpg", role: "Character" },
	{ code: "EB03-062", name: "Trafalgar Law", count: 2, img: "/Cards/EB03/EB03-062.jpg", role: "Character" },
	{ code: "OP15-078", name: "Mamaragan", count: 4, img: "/Cards/OP15/OP15-078.jpg", role: "Event" },
	{ code: "OP12-115", name: "I Love You!!", count: 4, img: "/Cards/OP12/OP12-115.jpg", role: "Event" },
	{ code: "OP07-076", name: "Slow-Slow Beam Sword", count: 2, img: "/Cards/OP07/OP07-076.png", role: "Event" },
];
const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const comboLineOne = [
	{
		code: "OP12-061",
		name: "Donquixote Rosinante",
		img: "/Cards/OP12/OP12-061.jpg",
		text: 'Use Leader effect to play "Law" for -2 Cost.',
	},
	{
		code: "P-093",
		name: "Trafalgar Law",
		img: "/Cards/P/P-093.jpg",
		text: "Drop 4-Cost Law on Turn 2.",
	},
	{
		code: "EB04-038",
		name: "Rosinante & Law",
		img: "/Cards/EB04/EB04-038.jpg",
		text: "Drop 6-Cost Rosinante & Law on Turn 3.",
		extra: "Result: Board pressure + solid Blocker defense.",
	},
];

const comboLineTwoCards = [
	{
		code: "OP16-065",
		name: "Sakazuki",
		img: "/Cards/OP16/OP16-065.jpg",
	},
	{
		code: "OP15-078",
		name: "Mamaragan",
		img: "/Cards/OP15/OP15-078.jpg",
	},
];

const comboLineTwoText = [
	"Combine Sakazuki's -6000 power ability with Mamaragan to rest a character up to 11K power!",
	"Tip: Only play Sakazuki at 8+ DON!! to use his 2-for-1 ramp ability. If you're at 7 DON!!, dropping a second 6-cost Rosinante is your best play.",
];

const options = [
	{
		code: "OP09-077",
		name: "Gum-Gum Lightning",
		img: "/Cards/OP09/OP09-077.jpg",
		lines: ["K.O.", "UP TO 12K POWER"],
	},
	{
		code: "OP15-077",
		name: "Lightning Dragon",
		img: "/Cards/OP15/OP15-077.jpg",
		lines: ["FREEZE", "UP TO 12K POWER"],
	},
	{
		code: "OP16-067",
		name: "Tsuru",
		img: "/Cards/OP16/OP16-067.jpg",
		lines: ["COUNTER +2K", "SEARCHER"],
	},
	{
		code: "OP16-068",
		name: "Trafalgar Law",
		img: "/Cards/OP16/OP16-068.jpg",
		lines: ["FOR ANOTHER", "4-COST OPTION"],
	},
	{
		code: "OP13-076",
		name: "Divine Departure",
		img: "/Cards/OP13/OP13-076.jpg",
		lines: ["-8K POWER", "0-COST EVENT"],
	},
	{
		code: "OP15-114",
		name: "Wyper",
		img: "/Cards/OP15/OP15-114.jpg",
		lines: ["-2K ALL OPP BOARD", "K.O. ALL 0-POWER"],
	},
];

const matchups = [
	{ code: "OP16-080", name: "Marshall.D.Teach", img: "/Cards/OP16/OP16-080.jpg", first: "even", second: "favored" },
	{ code: "OP16-079", name: "Yamato", img: "/Cards/OP16/OP16-079.jpg", first: "favored", second: "favored" },
	{ code: "OP16-022", name: "Monkey.D.Luffy", img: "/Cards/OP16/OP16-022.jpg", first: "favored", second: "even" },
	{ code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg", first: "unfavored", second: "pray" },
	{ code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg", first: "even", second: "pray" },
	{ code: "OP09-001", name: "Shanks", img: "/Cards/OP09/OP09-001.jpg", first: "favored", second: "favored" },
	{ code: "OP14-041", name: "Boa Hancock", img: "/Cards/OP14/OP14-041.jpg", first: "even", second: "even" },
	{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg", first: "unfavored", second: "unfavored" },
];

const mirrorCard = { code: "OP12-061", name: "Donquixote Rosinante", img: "/Cards/OP12/OP12-061.jpg" };

const badMatchups = [
	{
		code: "OP15-058",
		name: "Enel",
		img: "/Cards/OP15/OP15-058.jpg",
		bullets: [
			{ label: "Dice roll", text: "Always go first." },
			{
				label: "Turn 2",
				text: "Avoid the 4-drop, especially if your opponent went DON!! -1 (you won't ramp). Your ideal play is the 3-cost X-Drake to trade into his 1-drops.",
			},
			{ label: "Manage 1-drops", text: "Set up your 1-cost searchers to swing at his 1-cost drops." },
			{ label: "Rest & Trade Combo", text: "Use Sakazuki + Mamaragan to rest and trade into his Enel & Reiju." },
			{
				label: "Rosinante Warning",
				text: "If your first Rosinante gets hit by Gamma Knife + El Thor, use your Leader effect to take a life (and pray he doesn't drop Mamaragan!).",
			},
		],
	},
	{
		code: "OP11-041",
		name: "Nami",
		img: "/Cards/OP11/OP11-041.jpg",
		bullets: [
			{ label: "Keep life high", text: "Counter and block as much as possible." },
			{ label: "Clear the board", text: "Use Sakazuki + Mamaragan on her 7-cost Robin." },
			{ label: "Play on curve", text: "4-drop into 6-drop. These blockers stop attacks and deny her card draws ability." },
			{ label: "Manage Whitebeard", text: "Use Sakazuki to drop the 10-cost's power down to 6k." },
			{
				label: "Dice roll",
				text: "Always go first to mess up her curve, but her triggers can always flip the game upside down!",
			},
		],
	},
];

const matchupLegend = [
	{ tone: "favored", label: "Favored" },
	{ tone: "even", label: "Even" },
	{ tone: "unfavored", label: "Unfavored" },
	{ tone: "pray", label: "Pray" },
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Donquixote Rosinante OP12 Deck Guide</h1>
				<p>
					Decklist, combos, tech options, matchup spread, mirror advice, and the closing notes for Donquixote
					Rosinante in the OP16 format.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Donquixote Rosinante OP12 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="section-heading-copy">
					<h2>Decklist</h2>
				</div>
				<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
					Copy for Sim
				</button>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="combos" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Combos</h2>
				</div>
			</div>
			<div class="feature-panel combo-panel">
				<div class="combo-line combo-line-three">
					{comboLineOne.map((card, index) => (
						<div class:list={["combo-stack", index < comboLineOne.length - 1 && "combo-stack-arrow"]}>
							<button
								class="mini-card combo-card"
								type="button"
								data-card-preview
								data-full={card.img}
								data-name={`${card.code} ${card.name}`}
							>
								<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							</button>
							<div class="combo-copy">
								<p class="combo-text">{card.text}</p>
								{card.extra && <p class="combo-text combo-result">{card.extra}</p>}
							</div>
						</div>
					))}
				</div>
				<div class="combo-line combo-line-two">
					<div class="combo-pair-cards">
						{comboLineTwoCards.map((card) => (
							<button
								class="mini-card combo-card"
								type="button"
								data-card-preview
								data-full={card.img}
								data-name={`${card.code} ${card.name}`}
							>
								<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							</button>
						))}
					</div>
					<div class="combo-copy combo-copy-wide">
						{comboLineTwoText.map((line) => (
							<p class="combo-text">{line}</p>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options &amp; Tech Cards</h2>
				</div>
			</div>
			<div class="options-grid">
				{options.map((card) => (
					<div class="option-card">
						<button
							class="option-card-button"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="option-name">{card.name}</div>
						<div class="option-lines">
							{card.lines.map((line) => (
								<div>{line}</div>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p class="matchup-link-line">
						See the full turn-order data in
						<a class="matchup-article-link" href={metaArticleHref}>OP12 Purple/Yellow Rosinante stats in OP16 Format</a>.
					</p>
				</div>
			</div>
			<div class="feature-panel">
				<div class="matchup-legend">
					{matchupLegend.map((entry) => (
						<div class="legend-row">
							<span class={`legend-dot ${entry.tone}`}></span>
							<span>{entry.label}</span>
						</div>
					))}
				</div>
				<div class="matchups-grid">
					{matchups.map((matchup) => (
						<div class="matchup-card">
							<button
								class="mini-card matchup-image"
								type="button"
								data-card-preview
								data-full={matchup.img}
								data-name={`${matchup.code} ${matchup.name}`}
							>
								<img loading="lazy" src={matchup.img} alt={`${matchup.code} ${matchup.name}`} />
							</button>
							<div class="matchup-name">{matchup.name}</div>
							<div class="turn-lines">
								<div class="turn-line">
									<span class={`legend-dot ${matchup.first}`}></span>
									<span>1ST</span>
								</div>
								<div class="turn-line">
									<span class={`legend-dot ${matchup.second}`}></span>
									<span>2ND</span>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="mirror" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mirror advice</h2>
				</div>
			</div>
			<div class="feature-panel text-panel">
				<button
					class="mini-card large-mini-card"
					type="button"
					data-card-preview
					data-full={mirrorCard.img}
					data-name={`${mirrorCard.code} ${mirrorCard.name}`}
				>
					<img loading="lazy" src={mirrorCard.img} alt={`${mirrorCard.code} ${mirrorCard.name}`} />
				</button>
				<ul class="bullet-list">
					<li><strong>Dice roll:</strong> Always go first (it's a huge advantage).</li>
					<li><strong>Perfect curve:</strong> 4-drop (T2) into 6-drop (T3) into 6-drop (T4).</li>
					<li><strong>Turn 5:</strong> Sakazuki + Mamaragan combo on their Rosinante, then swing.</li>
					<li><strong>DON!! Management:</strong> Stay at fewer DON!! than your opponent to gain advantage.</li>
				</ul>
			</div>
		</div>
	</section>

	<section id="bad-matchup" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Bads Machtups</h2>
				</div>
			</div>
			<div class="bad-matchups-stack">
				{badMatchups.map((matchup) => (
					<div class="feature-panel text-panel">
						<button
							class="mini-card large-mini-card"
							type="button"
							data-card-preview
							data-full={matchup.img}
							data-name={`${matchup.code} ${matchup.name}`}
						>
							<img loading="lazy" src={matchup.img} alt={`${matchup.code} ${matchup.name}`} />
						</button>
						<ul class="bullet-list">
							{matchup.bullets.map((bullet) => (
								<li><strong>{bullet.label}:</strong> {bullet.text}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="conclusion" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Conclusion</h2>
				</div>
			</div>
			<div class="conclusion-shell">
				<div class="conclusion-lead">
					<p>
						The deck is very strong and consistent, thanks also to the new 1-cost Navy searchers from OP16, and
						the Sakazuki card is an incredible addition.
					</p>
				</div>
				<div class="conclusion-grid">
					<div class="conclusion-panel">
						<p>
							It's a deck that performs very well in a 'jungle meta'; however, if the OP16 meta remains similar
							to that of OP15, with Nami and Enel dominating, it becomes difficult for Rosinante to prove its
							worth.
						</p>
					</div>
					<div class="conclusion-panel">
						<p>
							Against Enel, in fact, it's an immense struggle, and against Nami, if you go second and don't draw
							well, you're likely going to lose the game.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	const copySimButton = document.querySelector("[data-copy-sim]");

	copySimButton?.addEventListener("click", async () => {
		const deckCode = copySimButton.getAttribute("data-sim-deck");
		if (!deckCode) return;

		try {
			await navigator.clipboard.writeText(deckCode);
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = deckCode;
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		}

		copySimButton.textContent = "Copied!";
		window.setTimeout(() => {
			copySimButton.textContent = "Copy for Sim";
		}, 1800);
	});
</script>

<style>
	.copy-sim-button {
		font-family: inherit;
		font-weight: 700;
	}

	.decklist-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
	}

	.section-heading-copy {
		display: grid;
		gap: 0.35rem;
	}

	.section-heading-copy h2 {
		margin: 0;
	}

	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card,
	.option-card,
	.feature-panel,
	.conclusion-panel,
	.conclusion-lead {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow);
	}

	.deck-card {
		padding: 0.9rem;
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible,
	.option-card-button:hover,
	.option-card-button:focus-visible,
	.mini-card:hover,
	.mini-card:focus-visible {
		transform: translateY(-4px);
		outline: none;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		border-color: rgba(255, 107, 61, 0.4);
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name,
	.matchup-name,
	.option-name {
		font-weight: 700;
	}

	.deck-code {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.feature-panel {
		padding: 1.3rem;
	}

	.combo-panel,
	.text-panel {
		display: grid;
		gap: 1.5rem;
