		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.matchups-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.matchup-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1rem;
		display: grid;
		gap: 0.6rem;
	}

	.matchup-badge {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		font-weight: 700;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(12, 17, 30, 0.8);
	}

