---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Enel OP15 Deck Guide";
const description =
	"Enel OP15 deck guide for One Piece Card Game with decklist, curve reference, mulligan targets, options, and matchup notes.";

const icon = "/assets/guides/enel-op15.png";

const decklist = [
	{ code: "OP15-058", name: "Enel", count: 1, img: "/Cards/OP15/OP15-058.jpg", role: "Leader" },
	{ code: "OP15-060", name: "Enel", count: 4, img: "/Cards/OP15/OP15-060.jpg", role: "Character" },
	{ code: "OP15-118", name: "Enel", count: 4, img: "/Cards/OP15/OP15-118.jpg", role: "Character" },
	{ code: "OP15-061", name: "Ohm", count: 4, img: "/Cards/OP15/OP15-061.jpg", role: "Character" },
	{ code: "OP15-066", name: "Satori", count: 4, img: "/Cards/OP15/OP15-066.jpg", role: "Character" },
	{ code: "OP15-067", name: "Shura", count: 4, img: "/Cards/OP15/OP15-067.jpg", role: "Character" },
	{ code: "OP15-071", name: "Holly", count: 4, img: "/Cards/OP15/OP15-071.jpg", role: "Character" },
	{ code: "OP15-074", name: "Varie", count: 4, img: "/Cards/OP15/OP15-074.jpg", role: "Event" },
	{ code: "OP15-075", name: "El Thor", count: 4, img: "/Cards/OP15/OP15-075.jpg", role: "Event" },
	{ code: "OP15-076", name: "Lightning Beast Kiten", count: 4, img: "/Cards/OP15/OP15-076.jpg", role: "Event" },
	{ code: "OP15-077", name: "Lightning Dragon", count: 4, img: "/Cards/OP15/OP15-077.jpg", role: "Event" },
	{ code: "OP15-078", name: "Mamaragan", count: 4, img: "/Cards/OP15/OP15-078.jpg", role: "Event" },
	{ code: "OP12-071", name: "Charlotte Pudding", count: 4, img: "/Cards/OP12/OP12-071.jpg", role: "Character" },
	{ code: "OP13-076", name: "Divine Departure", count: 2, img: "/Cards/OP13/OP13-076.jpg", role: "Event" },
];

const options = [
	{ code: "OP07-064", name: "Sanji", img: "/Cards/OP07/OP07-064.png" },
	{ code: "OP05-077", name: "Gamma Knife", img: "/Cards/OP05/OP05-077.png" },
];

const optionsNote =
	"If you don't like Divine Departure you can think about playing 2x Gamma Knives in their place, but watch out for the counters, while Sanji is a valid alternative instead of the \"Varie\" spell and also increases the Pudding targets.";

const mulliganCards = [
	{ code: "OP15-061", name: "Ohm", img: "/Cards/OP15/OP15-061.jpg" },
	{ code: "OP15-071", name: "Holly", img: "/Cards/OP15/OP15-071.jpg" },
	{ code: "OP15-118", name: "Enel", img: "/Cards/OP15/OP15-118.jpg" },
];

const curve = [
	{
		label: "1/2 DON",
		notes:
			"Ohm is the best choice, but any 1C drop is ok to pressure the board and cycle hand.",
		cards: [
			{ code: "OP12-071", name: "Charlotte Pudding", img: "/Cards/OP12/OP12-071.jpg" },
			{ code: "OP15-061", name: "Ohm", img: "/Cards/OP15/OP15-061.jpg" },
			{ code: "OP15-066", name: "Satori", img: "/Cards/OP15/OP15-066.jpg" },
			{ code: "OP15-067", name: "Shura", img: "/Cards/OP15/OP15-067.jpg" },
		],
	},
	{
		label: "3/4 DON",
		notes:
			"Use leader ability to ramp 1 DON, assign 4 DON rested to Ohm and play Holly. This allows a 6k double attack from turn 2.",
		cards: [
			{ code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg" },
			{ code: "OP15-071", name: "Holly", img: "/Cards/OP15/OP15-071.jpg" },
		],
	},
	{
		label: "5/6 DON",
		notes:
			"Play the SEC to search another Enel or a missing spell for combo. Play SR for setup blocker if you need for the next turn.",
		cards: [
			{ code: "OP15-118", name: "Enel", img: "/Cards/OP15/OP15-118.jpg" },
			{ code: "OP15-060", name: "Enel", img: "/Cards/OP15/OP15-060.jpg" },
		],
	},
	{
		label: "Late game",
		notes:
			"Spells are the best resources. They serve as 2K, but also fuel the combos in the Tips section, so use them carefully.",
		cards: [
			{ code: "OP15-078", name: "Mamaragan", img: "/Cards/OP15/OP15-078.jpg" },
			{ code: "OP15-075", name: "El Thor", img: "/Cards/OP15/OP15-075.jpg" },
			{ code: "OP15-076", name: "Lightning Beast Kiten", img: "/Cards/OP15/OP15-076.jpg" },
			{ code: "OP15-077", name: "Lightning Dragon", img: "/Cards/OP15/OP15-077.jpg" },
		],
	},
];

const tips = [
	{
		title:
			"This is the best combo to see in your first curve and it allows you to survive the opponent's Wypers.",
		cards: [
			{ code: "OP15-061", name: "Ohm", img: "/Cards/OP15/OP15-061.jpg" },
			{ code: "OP15-071", name: "Holly", img: "/Cards/OP15/OP15-071.jpg" },
		],
	},
	{
		title:
			"If a 6k blocker like Borsalino bothers you, use the beast spell to reduce power. Mamaragan lets you rest it and Dragon freezes it. The package is recycled each time.",
		cards: [
			{ code: "OP15-076", name: "Lightning Beast Kiten", img: "/Cards/OP15/OP15-076.jpg" },
			{ code: "OP15-078", name: "Mamaragan", img: "/Cards/OP15/OP15-078.jpg" },
			{ code: "OP15-077", name: "Lightning Dragon", img: "/Cards/OP15/OP15-077.jpg" },
		],
	},
	{
		title:
			"This combo removes any 12k. Very strong against opponent's Sabo blockers and also in mirror to control the opponent's Enel.",
		cards: [
			{ code: "OP13-076", name: "Divine Departure", img: "/Cards/OP13/OP13-076.jpg" },
			{ code: "OP15-075", name: "El Thor", img: "/Cards/OP15/OP15-075.jpg" },
		],
	},
];

const matchups = [
	{
		label: "Slight Disadv.",
		icon: "↓",
		leader: { code: "OP14-041", name: "Boa Hancock", img: "/Cards/OP14/OP14-041.jpg" },
		notes: ["Start 1st", "Manage your life", "Freeze the board"],
	},
	{
		label: "Slight Adv.",
		icon: "↑",
		leader: { code: "OP15-002", name: "Lucy", img: "/Cards/OP15/OP15-002.jpg" },
		notes: ["Start 1st", "Starve with 6C Enel", "Control oppo board"],
	},
	{
		label: "Negative MU",
		icon: "↓",
		leader: { code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
		notes: ["Start 1st", "Try to survive", "Worst MU ever"],
	},
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP13-002", name: "Portgas D. Ace", img: "/Cards/OP13/OP13-002.jpg" },
		notes: ["Start 2nd", "Go aggro with Holly", "6C Enel OP"],
	},
	{
		label: "Negative MU",
		icon: "↓",
		leader: { code: "OP15-098", name: "Monkey D. Luffy", img: "/Cards/OP15/OP15-098.jpg" },
		notes: ["Start 1st", "Holly key card", "Go only face"],
	},
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP13-079", name: "Imu", img: "/Cards/OP13/OP13-079.jpg" },
		notes: ["Start 2nd", "Go aggro with Holly", "Mamaragan combo OP"],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Enel OP15 Deck Guide</h1>
				<p>
					Complete reference guide for Enel OP15: decklist, curve checkpoints, mulligan priorities, tech
					options, and matchup notes. Built for fast reading between rounds.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Enel OP15 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Decklist</h2>
					<p>Main list for Enel OP15.</p>
				</div>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Flexible slots to adapt the list.</p>
				</div>
			</div>
			<div class="options-paired-grid">
				{options.map((card) => (
					<button
						class="option-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="option-info">
							<div class="deck-name">{card.name}</div>
							<div class="deck-code">{card.code}</div>
						</div>
					</button>
				))}
			</div>
			<p class="section-note">{optionsNote}</p>
			<p class="section-note">This is the right ratio of the cards.</p>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>1C vassal + Holly or 1C vassal + Enel 6C is the target.</p>
				</div>
			</div>
			<div class="mulligan-grid">
				{mulliganCards.map((card) => (
					<button
						class="mini-card"
						type="button"
						data-card-preview
						data-full={card.img}
						data-name={`${card.code} ${card.name}`}
					>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="mini-label">{card.name}</div>
					</button>
				))}
			</div>
			<p class="mulligan-text">
				1C vassal + Holly for more aggression, or 1C vassal + Enel 6C for consistency. If you do not see this
				combo, mulligan is the way.
			</p>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Turn-by-turn curve reminders.</p>
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve</h3>
				<div class="curve-rows">
					{curve.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Key reminders and timing notes.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class="tip-card">
						<div class="tip-cards">
							{tip.cards.map((card) => (
								<button
									class="mini-card"
									type="button"
									data-card-preview
									data-full={card.img}
									data-name={`${card.code} ${card.name}`}
								>
									<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
								</button>
							))}
						</div>
						<p>{tip.title}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>Quick matchup snapshot for the key leaders.</p>
				</div>
			</div>
			<div class="matchups-grid">
				{matchups.map((matchup) => (
					<div class="matchup-card">
						<div class={`matchup-badge ${matchup.label === "Negative MU" ? "badge-down" : matchup.label === "Slight Disadv." ? "badge-down" : matchup.label === "Even" ? "badge-even" : "badge-up"}`}>
							<span class="badge-icon">{matchup.icon}</span>
							<span>{matchup.label}</span>
						</div>
						<button
							class="mini-card"
							type="button"
							data-card-preview
							data-full={matchup.leader.img}
							data-name={`${matchup.leader.code} ${matchup.leader.name}`}
						>
							<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
						</button>
						<div class="matchup-name">{matchup.leader.name}</div>
						<ul>
							{matchup.notes.map((note) => (
								<li>{note}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});
</script>

<style>
	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(360px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 0.9rem;
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.options-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
	}

	.options-paired-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 220px));
		gap: 1rem;
		justify-content: start;
		align-items: start;
	}

	.option-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 0.8rem;
		display: grid;
		gap: 0.6rem;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.option-card img {
		width: 100%;
		max-width: 220px;
		margin: 0 auto;
		border-radius: 10px;
	}

	.option-info {
		display: grid;
		gap: 0.2rem;
	}

	.option-note {
		margin: 0.4rem 0 0;
		color: var(--text-300);
		font-size: 0.9rem;
	}

	.note-block {
		background: rgba(14, 18, 30, 0.7);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1.2rem 1.4rem;
	}

	.mulligan-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}

