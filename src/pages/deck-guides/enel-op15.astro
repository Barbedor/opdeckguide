	.curve-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.2rem;
	}

	.curve-block {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1.2rem;
		margin-bottom: 1.2rem;
	}

	.curve-rows {
		display: grid;
		gap: 1rem;
		margin-top: 0.8rem;
	}

	.curve-row {
		display: grid;
		grid-template-columns: 80px minmax(0, 1fr) minmax(0, 1.2fr);
		gap: 1rem;
		align-items: center;
	}

	.curve-label {
		font-weight: 700;
		color: var(--accent);
	}

	.curve-cards {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.curve-note {
		color: var(--text-300);
	}

	.mini-card {
		border: none;
		background: transparent;
		cursor: pointer;
		padding: 0;
		border-radius: 10px;
	}

	.mini-card img {
		width: 120px;
		border-radius: 10px;
		display: block;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.35);
	}

	.mini-label {
		margin-top: 0.4rem;
		font-size: 0.85rem;
		color: var(--text-300);
		text-align: center;
	}

	.tips-grid {
		display: grid;
		gap: 1.2rem;
	}

	.tip-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1rem 1.2rem;
