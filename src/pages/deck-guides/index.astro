---
import MainLayout from "../../layouts/MainLayout.astro";
import Section from "../../components/Section.astro";
import Card from "../../components/Card.astro";

const title = "Deck Guides for One Piece Card Game";
const description = "Leader-focused One Piece Card Game deck guides with game plans, mulligans, upgrade paths, and matchup tips.";
---

<MainLayout title={title} description={description}>
	<section class="hero">
		<div class="container">
			<span class="hero-badge">Deck Guides</span>
			<h1>Deck Guides for One Piece Card Game</h1>
			<p>
				Leader-focused deck guides with clean game plans, clear turn priorities, and the key decisions that
				win matches. Pick a guide below and jump straight into the information you need.
			</p>
		</div>
	</section>

	<Section
		title="Featured Guides"
		description="Popular leaders with clear game plans and matchup angles."
		linkHref="/deck-guides"
		linkLabel="All guides"
	>
		<Card
			eyebrow="May"
			title="Portgas.D.Ace OP13 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/portgas-d-ace-op13.png"
			imageAlt="Portgas.D.Ace OP13 guide icon"
			href="/deck-guides/portgas-d-ace-op13"
		/>
		<Card
			eyebrow="April"
			title="Enel OP15 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/enel-op15.png"
			imageAlt="Enel OP15 guide icon"
			href="/deck-guides/enel-op15"
		/>
		<Card
			eyebrow="April"
			title="Lucy OP15 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/lucy-op15.png"
			imageAlt="Lucy OP15 guide icon"
			href="/deck-guides/lucy-op15"
		/>
		<Card
			eyebrow="April"
			title="Nami OP11 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/nami-op11.png"
			imageAlt="Nami OP11 guide icon"
			href="/deck-guides/nami-op11"
		/>
		<Card
			eyebrow="April"
			title="Rosinante OP12 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/rosinante-op12.png"
			imageAlt="Rosinante OP12 guide icon"
			href="/deck-guides/rosinante-op12"
		/>
		<Card
			eyebrow="March"
			title="Jinbe OP14 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/jinbe-op14.png"
			imageAlt="Jinbe OP14 guide icon"
			href="/deck-guides/jinbe-op14"
		/>
		<Card
			eyebrow="March"
			title="Dracule Mihawk OP14 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/dracule-mihawk-op14.png"
			imageAlt="Dracule Mihawk OP14 guide icon"
			href="/deck-guides/dracule-mihawk-op14"
		/>
		<Card
			eyebrow="March"
			title="Trafalgar Law OP14 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/trafalgar-law-op14.png"
			imageAlt="Trafalgar Law OP14 guide icon"
			href="/deck-guides/trafalgar-law-op14"
		/>
		<Card
			eyebrow="March"
			title="Monkey.D.Luffy ST29 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/monkey-d-luffy-st29.png"
			imageAlt="Monkey.D.Luffy ST29 guide icon"
			href="/deck-guides/monkey-d-luffy-st29"
		/>
		<Card
			eyebrow="March"
			title="Crocodile OP14 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/crocodile-op14.png"
			imageAlt="Crocodile OP14 guide icon"
			href="/deck-guides/crocodile-op14"
		/>
		<Card
			eyebrow="March"
			title="Boa Hancock OP14 Deck Guide"
			description="Decklist, curve checkpoints, mulligan priorities, options, and matchup notes."
			imageSrc="/assets/guides/boa-hancock-op14.png"
			imageAlt="Boa Hancock OP14 guide icon"
			href="/deck-guides/boa-hancock-op14"
		/>
	</Section>

	<section class="seo-block">
		<div class="container">
			<h2>About These Deck Guides</h2>
			<p>
				Build better lists and pilot them with purpose. These deck guides break down leader identities, core
				packages, and the key turns that define each archetype. Whether you are pushing for a top cut finish
				or learning a new leader, the goal is the same: simplify the plan so your decisions are clear and
				repeatable.
			</p>
			<p>
				Each guide focuses on three pillars. First, your opening plan: mulligan priorities, early tempo lines,
				and when to protect life versus race. Second, your mid-game: resource loops, attack sequencing, and
				how to pivot based on opposing leaders. Third, your upgrade path: the most impactful changes as your
				collection grows and stay aware of format shifts in <a href="/meta-analysis">Meta Analysis</a>. If you
				are still learning fundamentals, the <a href="/beginner-guides">Beginner Guides</a> will get you up to
				speed fast.
			</p>
			<p>
				Guides are structured to be quick to scan on mobile while still offering depth. Expect realistic list
				snapshots, tech options for common threats, and explanation of why each card matters. You can bookmark
				favorite leaders and return as new sets drop or the <a href="/banlist">Banlist</a> changes.
			</p>
		</div>
	</section>
</MainLayout>
