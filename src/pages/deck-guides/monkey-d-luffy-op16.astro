---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Monkey.D.Luffy OP16 Deck Guide";
const description =
	"Monkey.D.Luffy OP16 deck guide for One Piece Card Game with decklist, mulligan priorities, a curve guide, tech cards, matchup notes, and gameplay tips.";

const icon = "/assets/guides/Luffy%20op16.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const card = (code, name, img) => ({ code, name, img });

const luffyLeader = card("OP16-022", "Monkey D. Luffy", "/Cards/OP16/OP16-022.jpg");
const luffySearcher = card("OP16-034", "Monkey D. Luffy", "/Cards/OP16/OP16-034.jpg");
const jinbe = card("OP16-027", "Jinbe", "/Cards/OP16/OP16-027.jpg");
const mr1 = card("OP16-054", "Mr.1 (Daz Bonez)", "/Cards/OP16/OP16-054.jpg");
const mr2 = card("OP16-055", "Mr.2 Bon Clay (Bentham)", "/Cards/OP16/OP16-055.jpg");
const mr3 = card("OP16-056", "Mr.3 (Galdino)", "/Cards/OP16/OP16-056.jpg");
const ivankov = card("OP16-026", "Emporio Ivankov", "/Cards/OP16/OP16-026.jpg");
const mr3St30 = card("ST30-014", "Mr.3 (Galdino)", "/Cards/ST30/ST30-014.jpg");
const buggy = card("OP16-048", "Buggy", "/Cards/OP16/OP16-048.jpg");
const brook = card("OP15-032", "Brook", "/Cards/OP15/OP15-032.jpg");
const prisoner = card("OP16-042", "Prisoner of Impel Down", "/Cards/OP16/OP16-042.jpg");
const boaHancock = card("OP16-032", "Boa Hancock", "/Cards/OP16/OP16-032.jpg");
const iKnowYoureStrong = card("OP13-040", "I Know You're Strong!!!", "/Cards/OP13/OP13-040.jpg");
const letsGoNavy = card("OP16-038", "Let's Go to the Navy Headquarters!!", "/Cards/OP16/OP16-038.jpg");
const houndBlaze = card("OP05-057", "Hound Blaze", "/Cards/OP05/OP05-057.png");
const gumGumJetCulverin = card("OP11-061", "Gum-Gum Jet Culverin", "/Cards/OP11/OP11-061.jpg");
const crocodile = card("OP16-045", "Crocodile", "/Cards/OP16/OP16-045.jpg");
const luffySt30 = card("ST30-012", "Monkey D. Luffy", "/Cards/ST30/ST30-012.jpg");
const demonAura = card("OP12-037", "Demon Aura Nine Sword Style Asura Blades Drawn Dead Man's Game", "/Cards/OP12/OP12-037.jpg");

const teach16 = card("OP16-080", "Marshall.D.Teach OP16", "/Cards/OP16/OP16-080.jpg");
const yamato16 = card("OP16-079", "Yamato OP16", "/Cards/OP16/OP16-079.jpg");
const rosinante12 = card("OP12-061", "Donquixote Rosinante OP12", "/Cards/OP12/OP12-061.jpg");
const shanks09 = card("OP09-001", "Shanks OP09", "/Cards/OP09/OP09-001.jpg");
const enel15 = card("OP15-058", "Enel OP15", "/Cards/OP15/OP15-058.jpg");
const nami11 = card("OP11-041", "Nami OP11", "/Cards/OP11/OP11-041.jpg");
const ace16 = card("OP16-001", "Portgas.D.Ace OP16", "/Cards/OP16/OP16-001.jpg");
const boa14 = card("OP14-041", "Boa Hancock OP14", "/Cards/OP14/OP14-041.jpg");
const lucy15 = card("OP15-002", "Lucy OP15", "/Cards/OP15/OP15-002.jpg");
const metaArticleHref = "/meta-analysis/Green-Blue-Luffy-op16-stats/";

const decklist = [
	{ ...luffyLeader, count: 1, role: "Leader" },
	{ ...luffySearcher, count: 4, role: "Character" },
	{ ...jinbe, count: 2, role: "Character" },
	{ ...mr1, count: 4, role: "Character" },
	{ ...mr2, count: 4, role: "Character" },
	{ ...mr3, count: 2, role: "Character" },
	{ ...ivankov, count: 3, role: "Character" },
	{ ...mr3St30, count: 4, role: "Character" },
	{ ...buggy, count: 4, role: "Character" },
	{ ...brook, count: 2, role: "Character" },
	{ ...prisoner, count: 8, role: "Character" },
	{ ...boaHancock, count: 4, role: "Character" },
	{ ...iKnowYoureStrong, count: 4, role: "Event" },
	{ ...letsGoNavy, count: 3, role: "Event" },
	{ ...houndBlaze, count: 2, role: "Event" },
	{ ...gumGumJetCulverin, count: 2, role: "Event" },
];

const simDeckCode = decklist.flatMap((entry) => expandSimLines(entry.count, entry.code)).join("\n");

const mulliganKeeps = [
	{
		copy:
			"The best opener in the deck. It searches an Impel Down character, can even chain into another Luffy to keep digging, and quickly becomes a 6000-power attacker once your board starts covering multiple names.",
		cards: [luffySearcher],
	},
	{
		copy:
			"An excellent turn-1 play. It replaces itself by drawing a card and attacks for 6000 with just 1 DON!! attached as long as you stay at five cards or more in hand.",
		cards: [mr1],
	},
	{
		copy:
			"One of the best characters in the deck. Its power automatically scales 1000 above the opposing leader, which means it cleanly attacks over most leaders with only 1 DON!! attached.",
		cards: [mr2],
	},
	{
		copy:
			"A great card to keep. It searches an Impel Down character and immediately puts a cost-2-or-lower character into play, which gives your board development a huge push right away.",
		cards: [ivankov],
	},
];

const idealHandCards = [luffySearcher, ivankov, mr1, mr2];

const curveSecond = [
	{
		label: "2 DON!!",
		notes:
			"Your priority is to play a low-cost character. Monkey D. Luffy, Mr.1, and Mr.2 are all excellent openers because they build the board immediately while setting up your next turns.",
		cards: [luffySearcher, mr1, mr2],
	},
	{
		label: "4 DON!!",
		notes:
			"Keep developing your board. Emporio Ivankov is the best play here because it searches an Impel Down character and drops a cost 2 or lower straight into play, which lets you cash in on the leader effect even faster.",
		cards: [ivankov, prisoner, { ...luffyLeader, badgeCard: "/Cards/P/Don_small.jpg" }],
	},
	{
		label: "6 DON!!",
		notes:
			"This is where the deck really starts taking over. You want five characters in play so you can set up Let's Go to the Navy Headquarters!! while still throwing multiple 6000-power attacks and restanding 2 DON!! with the leader.",
		cards: [letsGoNavy, luffySearcher, mr2],
	},
	{
		label: "8 DON!!",
		notes:
			"You now have two real game plans. If your board is already strong, keep pressing with the swarm and set up your lethal turn. If your board is weaker, start preparing the Boa Hancock + Brook line as your backup win condition.",
		cards: [letsGoNavy, boaHancock, brook],
	},
	{
		label: "10 DON!!",
		notes:
			"You have two endgame routes here. If the board is already full, play Let's Go to the Navy Headquarters!! to maximize damage and close the game. If the board got controlled, chain Boa Hancock into Brook so you can create two unblockable attacks through blockers.",
		cards: [letsGoNavy, boaHancock, brook],
	},
	{
		label: "Late game",
		notes:
			"Once you know which win condition matters, commit to it. If your wide board survives, finish with Let's Go to the Navy Headquarters!!. If it doesn't, pivot immediately into Boa Hancock + Brook instead of forcing the wrong line.",
		cards: [letsGoNavy, boaHancock, brook],
	},
];

const optionsCards = [
	{
		...crocodile,
		copy:
			"Crocodile gives you more control-oriented lines and can be worth considering in some matchups. Even so, I think it slows the aggressive core of the deck a little too much, so I still prefer the more explosive build.",
	},
	{
		...luffySt30,
		copy:
			"An interesting alternative for longer games, but I don't think it hits as hard as the cards already occupying the main curve.",
	},
	{
		...demonAura,
		copy:
			"A defensive option you can test depending on the meta. I still prefer cards that build more board and keep pushing the aggressive plan harder.",
	},
];

const matchups = [
	{
		label: "Favorable",
		tone: "up",
		icon: "↑",
		leader: teach16,
		notes: [
			"Luffy can build a wide board very quickly, which forces Teach to have the right answers right away.",
			"Go second.",
			"Put on as much pressure as possible before Teach reaches the late game.",
			"If your board gets controlled, pivot quickly into the Boa Hancock + Brook plan.",
		],
	},
	{
		label: "Even",
		tone: "even",
		icon: "≈",
		leader: yamato16,
		notes: [
			"The matchup is mostly about tempo. If Luffy keeps its board, it takes over. If Yamato chains its big threats quickly, it can steal the pace back.",
			"Develop your board as hard as possible in the first turns.",
			"Find Let's Go to the Navy Headquarters!! quickly.",
			"Force Yamato to defend instead of setting up its combo turns.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: rosinante12,
		notes: [
			"Rosinante can slow your plan down, but Luffy usually creates more pressure if the board gets established correctly.",
			"Keep filling your board.",
			"Exploit your tempo edge through the leader effect.",
			"Set up your lethal turn with Let's Go to the Navy Headquarters!!.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: shanks09,
		notes: [
			"Shanks has a lot of tools to control Luffy's board and limit its development.",
			"Develop your board quickly.",
			"Don't let Shanks reach the late game comfortably.",
			"Try to finish before the big threats start landing.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: enel15,
		notes: [
			"Enel can answer Luffy's small characters well while scaling into threats that are hard to push through.",
			"Multiply your attacks from the first turns.",
			"Get the most out of the leader effect to preserve tempo.",
			"Prepare your lethal turn quickly.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: nami11,
		notes: [
			"Nami controls Luffy's small characters very well, which makes it harder to keep a wide enough board to maximize the leader effect.",
			"Pressure the leader immediately.",
			"Keep developing your board instead of trying to control theirs.",
			"Try to finish before Nami gets the tempo back.",
			"Hit Life, not the board.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: ace16,
		notes: [
			"Ace keeps constant pressure through 8000-power Whitebeard Pirate rush threats, and Vista is one of the worst cards for Luffy to see.",
			"Take the board early.",
			"Force Ace to defend instead of extending its own plan.",
			"Keep enough resources for your lethal turn.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: boa14,
		notes: [
			"Boa can control some threats, but Luffy usually creates more characters than Boa can answer over time.",
			"Keep developing your board.",
			"Don't rely only on the Boa Hancock + Brook combo.",
			"Look to finish with Let's Go to the Navy Headquarters!!.",
			"Hit Life, not the board.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: lucy15,
		notes: [
			"Luffy usually has the edge because it develops the board faster than Lucy.",
			"Use your early turns to take the initiative.",
			"Keep the pressure high without slowing your development.",
			"Try to finish before Lucy stabilizes.",
		],
	},
	{
		label: "Mirror Match",
		tone: "even",
		icon: "≈",
		leader: luffyLeader,
		notes: [
			"The mirror usually goes to the player who develops the board more efficiently and times Let's Go to the Navy Headquarters!! better.",
			"Preserve your small characters.",
			"Don't fire off your late-game event too early.",
			"Keep Hound Blaze available when you need to create a board edge.",
		],
	},
];
const tips = [
	{
		copy:
			"Build your board quickly. The deck works when it stacks several Impel Down characters that can attack for 6000 with just 1 DON!! attached, so don't sit on characters in hand for too long.",
		cards: [luffySearcher, mr1, mr2],
	},
	{
		copy:
			"Use the leader effect every turn when you can. Re-standing 2 DON!! is what lets the deck chain multiple plays together while keeping pressure high.",
		cards: [{ ...luffyLeader, badgeCard: "/Cards/P/Don_small.jpg" }],
	},
	{
		copy:
			"Don't tunnel only on Let's Go to the Navy Headquarters!!. Even though it's your main finisher, the Boa Hancock + Brook package is a very real backup win condition when your board gets controlled.",
		cards: [letsGoNavy, boaHancock, brook],
	},
	{
		copy:
			"Attack with your small characters first, then keep extending the board. Thanks to the leader effect, you get DON!! back and can still keep attacking after playing more characters.",
		cards: [mr1, mr2, { ...luffyLeader, badgeCard: "/Cards/P/Don_small.jpg" }],
	},
	{
		copy:
			"Don't be afraid to play multiple copies of the same character early. Different names matter later, but in the opening turns the priority is simply to pressure as hard as possible.",
		cards: [luffySearcher, luffySearcher, mr1],
	},
	{
		copy:
			"Set up your lethal turn one turn in advance. Let's Go to the Navy Headquarters!! can still be strong with only four characters in play because the leader effect gives back the DON!! you need to finish building the board that same turn.",
		cards: [letsGoNavy, { ...luffyLeader, badgeCard: "/Cards/P/Don_small.jpg" }],
	},
	{
		copy:
			"Figure out your win condition quickly. If your board stays intact, lean into Let's Go to the Navy Headquarters!!. If the opponent is controlling your board well, switch immediately to the Boa Hancock + Brook plan instead of forcing the wrong route.",
		cards: [letsGoNavy, boaHancock, brook],
	},
	{
		copy:
			"The deck rewards timing. Knowing when to attack and when not to attack matters a lot, and a well-prepared lethal turn is usually worth more than pushing a few extra points too early.",
		cards: [houndBlaze, gumGumJetCulverin],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Monkey.D.Luffy OP16 Deck Guide</h1>
				<p>
					Monkey.D.Luffy OP16 is an Impel Down go-wide deck that snowballs through the leader's DON!! refund,
					constant board development, and relentless tempo. The list wins either by flooding the board into
					Let's Go to the Navy Headquarters!! or by pivoting into the Boa Hancock + Brook finish when the board
					gets controlled.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Monkey.D.Luffy OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="decklist-title-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<p>Main list for Monkey.D.Luffy OP16 in the OP16 format.</p>
			</div>
			<div class="deck-grid">
				{decklist.map((entry) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={entry.img}
						data-name={`${entry.code} ${entry.name}`}
					>
						<img loading="lazy" src={entry.img} alt={`${entry.code} ${entry.name}`} />
						<div class="deck-info">
							<span class="deck-count">{entry.count}x</span>
							<div>
								<div class="deck-name">{entry.name}</div>
								<div class="deck-code">{entry.code}</div>
							</div>
						</div>
						<span class="deck-role">{entry.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>
						The mulligan is fairly flexible, but you absolutely need your small characters early. The deck works because it fills the board quickly and starts cashing in on the leader effect right away.
					</p>
				</div>
			</div>
			<div class="mulligan-stack">
				<div class="tip-card glow-block">
					<h3>Cards to Prioritize</h3>
					<div class="mulligan-rows">
						{mulliganKeeps.map((entry) => (
							<div class="mulligan-row">
								<div class="tip-cards">
									{entry.cards.map((entryCard) => (
										<button
											class="mini-card"
											type="button"
											data-card-preview
											data-full={entryCard.img}
											data-name={`${entryCard.code} ${entryCard.name}`}
										>
											<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											<div class="mini-label">{entryCard.name}</div>
										</button>
									))}
								</div>
								<div class="mulligan-copy">
									<p>{entry.copy}</p>
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="tip-card glow-block">
					<h3>Ideal Hand</h3>
					<div class="sendback-grid ideal-grid">
						{idealHandCards.map((entryCard) => (
							<button
								class="mini-card sendback-card"
								type="button"
								data-card-preview
								data-full={entryCard.img}
								data-name={`${entryCard.code} ${entryCard.name}`}
							>
								<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
								<div class="mini-label sendback-label">{entryCard.name}</div>
							</button>
						))}
					</div>
					<ul class="bullet-list">
						<li>One or more 1- or 2-cost characters</li>
						<li>A way to keep filling the board, usually Luffy or Ivankov</li>
						<li>Enough small characters to start exploiting the leader effect quickly</li>
					</ul>
					<p class="mulligan-text">
						It's completely fine to open on multiple copies of the same character. Different names matter later, but early on your priority is just to pressure as hard as possible.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>
						Going second is the recommended seat. The leader gets huge value from restanding 2 rested DON!!, which makes the 4-, 6-, and 8-DON!! turns especially powerful. The goal is to build a wide board while keeping enough DON!! available to keep attacking every turn. If you go first, your curve shifts, so you really want Monkey D. Luffy OP16-034 in your opener because it costs 1 DON!!. That way you aren't passing the first turn and can start building your board immediately.
					</p>
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going Second</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((entryCard) => (
									<button
										class={`mini-card curve-card ${entryCard.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={entryCard.img}
										data-name={`${entryCard.code} ${entryCard.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											{entryCard.badgeCard && (
												<img class="card-badge-image" src={entryCard.badgeCard} alt="1 DON!! attached" loading="lazy" />
											)}
										</span>
										<div class="mini-label">{entryCard.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tech Cards</h2>
					<p>Alternative cards and flex slots for different OP16 rooms.</p>
				</div>
			</div>
			<div class="options-rich-grid">
				{optionsCards.map((entryCard) => (
					<div class="option-note-card glow-block">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={entryCard.img}
							data-name={`${entryCard.code} ${entryCard.name}`}
						>
							<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
							<div class="option-info">
								<div class="deck-name">{entryCard.name}</div>
								<div class="deck-code">{entryCard.code}</div>
							</div>
						</button>
						<p>{entryCard.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p class="matchup-link-line">
						See the full turn-order data in
						<a class="matchup-article-link" href={metaArticleHref}>OP16 Green/Blue Luffy stats in OP16 Format</a>.
					</p>
				</div>
			</div>
			<div class="matchups-stack">
				{matchups.map((matchup) => (
					<div class="matchup-card glow-block">
						<div class={`matchup-badge ${matchup.tone === "down" ? "badge-down" : matchup.tone === "even" ? "badge-even" : "badge-up"}`}>
							<span class="badge-icon">{matchup.icon}</span>
							<span>{matchup.label}</span>
						</div>
						<div class="matchup-row">
							<div class="tip-cards">
								<button
									class="mini-card"
									type="button"
									data-card-preview
									data-full={matchup.leader.img}
									data-name={`${matchup.leader.code} ${matchup.leader.name}`}
								>
									<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
									<div class="mini-label">{matchup.leader.name}</div>
								</button>
							</div>
							<ul class="bullet-list matchup-list">
								{matchup.notes.map((note) => (
									<li>{note}</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Core reminders for Monkey.D.Luffy in the OP16 format.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class={`tip-card glow-block ${tip.cards.length > 1 ? "multi-card-tip" : ""}`}>
						<div class={`tip-row ${tip.cards.length > 1 ? "multi-card-tip-row" : ""}`}>
							<div class="tip-cards">
								{tip.cards.map((entryCard) => (
									<button
										class={`mini-card ${entryCard.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={entryCard.img}
										data-name={`${entryCard.code} ${entryCard.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											{entryCard.badgeCard && (
												<img class="card-badge-image" src={entryCard.badgeCard} alt="1 DON!! attached" loading="lazy" />
											)}
										</span>
										<div class="mini-label">{entryCard.name}</div>
									</button>
								))}
							</div>
							<p>{tip.copy}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<img src="" alt="" data-modal-image />
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	const copyButtons = document.querySelectorAll("[data-copy-sim]");

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		if (event.target === modal) closeModal();
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	copyButtons.forEach((button) => {
		button.addEventListener("click", async () => {
			const value = button.getAttribute("data-sim-deck") ?? "";
			if (!value) return;
			try {
				await navigator.clipboard.writeText(value);
				const previous = button.textContent;
				button.textContent = "Copied!";
				setTimeout(() => {
					button.textContent = previous ?? "Copy for Sim";
				}, 1400);
			} catch {
				button.textContent = "Copy failed";
				setTimeout(() => {
					button.textContent = "Copy for Sim";
				}, 1400);
			}
		});
	});
</script>

