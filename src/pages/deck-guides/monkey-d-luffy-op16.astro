---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Monkey.D.Luffy OP16 Preview Deck Guide";
const description =
	"Monkey.D.Luffy OP16 preview deck guide for One Piece Card Game with an early decklist idea, key Impel Down spoilers, the old-set shell, and early strengths and weaknesses.";

const icon = "/assets/guides/Luffy%20op16.png";
const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP16-022", name: "Monkey.D.Luffy", count: 1, img: "/Cards/OP16/OP16-022.jpg", role: "Leader" },
	{ code: "OP16-034", name: "Monkey.D.Luffy", count: 4, img: "/Cards/OP16/OP16-034.jpg", role: "Character" },
	{ code: "OP16-054", name: "Mr.1(Daz.Bonez)", count: 4, img: "/Cards/OP16/OP16-054.jpg", role: "Character" },
	{ code: "OP16-055", name: "Mr.2.Bon.Kurei(Bentham)", count: 4, img: "/Cards/OP16/OP16-055.jpg", role: "Character" },
	{ code: "OP16-042", name: "Prisoner of Impel Down", count: 8, img: "/Cards/OP16/OP16-042.jpg", role: "Character" },
	{ code: "OP16-026", name: "Emporio.Ivankov", count: 4, img: "/Cards/OP16/OP16-026.jpg", role: "Character" },
	{ code: "OP16-048", name: "Buggy", count: 4, img: "/Cards/OP16/OP16-048.jpg", role: "Character" },
	{ code: "OP16-045", name: "Crocodile", count: 4, img: "/Cards/OP16/OP16-045.jpg", role: "Character" },
	{ code: "OP16-056", name: "Mr.3(Galdino)", count: 4, img: "/Cards/OP16/OP16-056.jpg", role: "Character" },
	{ code: "ST30-012", name: "Monkey.D.Luffy", count: 2, img: "/Cards/ST30/ST30-012.jpg", role: "Character" },
	{ code: "ST30-014", name: "Mr.3(Galdino)", count: 4, img: "/Cards/ST30/ST30-014.jpg", role: "Character" },
	{ code: "OP16-032", name: "Boa Hancock", count: 4, img: "/Cards/OP16/OP16-032.jpg", role: "Character" },
	{ code: "OP16-038", name: "Let's Go!! To the Navy Headquarters!!", count: 2, img: "/Cards/OP16/OP16-038.jpg", role: "Event" },
	{
		code: "OP13-040",
		name: "I Know You're Strong...So I'll Go All Out From the Start!!!",
		count: 2,
		img: "/Cards/OP13/OP13-040.jpg",
		role: "Event",
	},
];
const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const leaderCard = { code: "OP16-022", name: "Monkey.D.Luffy", img: "/Cards/OP16/OP16-022.jpg" };

const spoilerCards = [
	{
		code: "OP16-026",
		name: "Emporio.Ivankov",
		img: "/Cards/OP16/OP16-026.jpg",
	},
	{
		code: "OP16-032",
		name: "Boa Hancock",
		img: "/Cards/OP16/OP16-032.jpg",
	},
];

const prepPackage = [
	{ count: 4, code: "ST12-010", name: "Emporio Ivankov", img: "/Cards/ST12/ST12-010.png" },
	{ count: 2, code: "OP14-052", name: "Hannyabal", img: "/Cards/OP14/OP14-052.jpg" },
	{ count: 4, code: "EB01-022", name: "Inazuma", img: "/Cards/EB01/EB01-022.png" },
	{ count: 4, code: "EB01-028", name: "Gum Gum Champion Rifle", img: "/Cards/EB01/EB01-028.png" },
	{
		count: 4,
		code: "OP13-040",
		name: "I Know You're Strong...So I'll Go All Out From the Start!!!",
		img: "/Cards/OP13/OP13-040.jpg",
	},
	{ count: 4, code: "OP08-036", name: "Electrical Luna", img: "/Cards/OP08/OP08-036.png" },
];

const strengths = [
	"Very powerful DON!! gain",
	"Very strong midgame",
	"Fast snowball potential",
	"Good mix of offense and DON!! efficiency",
];

const weaknesses = [
	"The Impel Down-only condition is very restrictive",
	"Too dependent on keeping a board",
	"Not very stable into removal and control",
	"Lacks overall flexibility",
];

const conclusion =
	"The deck is a bit unusual to pilot, much like the old OP02 Ivankov shells, because it leans on a swarm of smaller pieces. That said, the rest and freeze effects give it real tempo swings, and the updated build looks legitimately strong in the right meta. For now, I would put it at 7.5 / 10.";
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Monkey.D.Luffy OP16 Preview Deck Guide</h1>
				<p>
					First look at Monkey.D.Luffy OP16 in the OP16 format. This preview focuses on the leader effect, the key
					spoilers, an early decklist idea, and the early read on the green-blue Impel Down shell.
				</p>
				<p>
					To see how Green/Blue Luffy performs going first and going second against the other top leaders, see <a class="guide-inline-link" href="/meta-analysis/Green-Blue-Luffy-op16-stats/">OP16 Green/Blue Luffy stats in OP16 Format</a>.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#thoughts">Early Thoughts</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Monkey.D.Luffy OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="section-heading-copy">
					<h2>Decklist</h2>
					<p class="decklist-intro">An early decklist idea for Monkey.D.Luffy OP16 in the OP16 format.</p>
				</div>
				<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
					Copy for Sim
				</button>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="leader" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Leader</h2>
					<p>Core identity and leader effect for Monkey.D.Luffy OP16-022.</p>
				</div>
			</div>
			<div class="leader-card">
				<button
					class="leader-preview"
					type="button"
					data-card-preview
					data-full={leaderCard.img}
					data-name={`${leaderCard.code} ${leaderCard.name}`}
				>
					<img loading="lazy" src={leaderCard.img} alt={`${leaderCard.code} ${leaderCard.name}`} />
				</button>
				<div class="leader-copy">
					<div class="fact-grid">
						<div class="fact-box">
							<span class="fact-label">Color</span>
							<p>Green - Blue</p>
						</div>
						<div class="fact-box">
							<span class="fact-label">Type</span>
							<p>Impel Down / Straw Hat Crew</p>
						</div>
					</div>
					<div class="text-card">
						<h3>Leader Effect</h3>
						<p class="effect-copy">
							<img class="keyword-badge" src="/assets/keywords/activate-main.png" alt="Activate Main" />
							<img class="keyword-badge" src="/assets/keywords/once-per-turn.png" alt="Once Per Turn" />
							If the only Characters on your field are {"{Impel Down}"} type Characters, set up to 2 of your
							DON!! cards as active.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="spoiler" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Key preview cards</h2>
					<p>Main cards that define the Impel Down package.</p>
				</div>
			</div>
			<div class="loop-grid">
				{spoilerCards.map((card) => (
					<div class="loop-card">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="text-card">
							<h3>{card.name}</h3>
							<div class="ability-stack">
								{card.code === "OP16-026" ? (
									<div class="ability-line">
										<span class="ability-inline">
											<img class="keyword-badge" src="/assets/keywords/on-play.png" alt="On Play" />
											<span>
												look at 3 cards from the top of your deck, reveal up to 1 {"{Impel Down}"} type
												card, add it to your hand and place the rest at the bottom of your deck in any
												order. Then, play up to 1 Character card with a cost of 2 or less from your hand.
											</span>
										</span>
									</div>
								) : (
									<>
										<div class="ability-line ability-line-tag-only">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/unblockable.png" alt="Unblockable" />
											</span>
										</div>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/on-play.png" alt="On Play" />
												<span>
													up to 1 of your opponent's Characters other than [Monkey.D.Luffy] cannot be
													rested until the end of your opponent's next End Phase.
												</span>
											</span>
										</div>
									</>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="prep" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Prep</h2>
					<p>Old-set support that helps hold the shell together.</p>
				</div>
			</div>
			<div class="prep-card">
				<p class="prep-intro">The list still leans on a sizable older shell for consistency and utility.</p>
				<div class="prep-grid">
					{prepPackage.map((entry) => (
						<button
							class="prep-chip"
							type="button"
							data-card-preview
							data-full={entry.img}
							data-name={entry.code}
						>
							<img loading="lazy" src={entry.img} alt={entry.code} />
							<div class="prep-copy">
								<span class="prep-code">{entry.code}</span>
								<span class="prep-name">{entry.name}</span>
							</div>
						</button>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="thoughts" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Thoughts</h2>
					<p>Strengths, weaknesses, and conclusion.</p>
				</div>
			</div>
			<div class="thoughts-grid">
				<div class="thought-card">
					<div class="thought-head thought-up">
						<span class="thought-icon" aria-hidden="true">+</span>
						<h3>Strengths</h3>
					</div>
					<ul>
						{strengths.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
				<div class="thought-card">
					<div class="thought-head thought-down">
						<span class="thought-icon" aria-hidden="true">-</span>
						<h3>Weaknesses</h3>
					</div>
					<ul>
						{weaknesses.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</div>
			<div class="conclusion-card">
				<div class="conclusion-head">
					<div>
						<h3>Conclusion</h3>
					</div>
					<div class="score-badge">7.5 / 10</div>
				</div>
				<p>{conclusion}</p>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<div class="card-modal-frame">
				<img src="" alt="" data-modal-image />
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalFrame = document.querySelector(".card-modal-frame");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	let lockedScrollY = 0;

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		lockedScrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${lockedScrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
		document.body.style.overflow = "hidden";
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		document.body.style.overflow = "";
		window.scrollTo(0, lockedScrollY);
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target === modalImage) {
			closeModal();
			return;
		}
		if (modalFrame && !modalFrame.contains(target) && target !== closeButton) {
			closeModal();
		}
	});
	modalImage?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	const copySimButton = document.querySelector("[data-copy-sim]");

	copySimButton?.addEventListener("click", async () => {
		const deckCode = copySimButton.getAttribute("data-sim-deck");
		if (!deckCode) return;

		try {
			await navigator.clipboard.writeText(deckCode);
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = deckCode;
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		}

		copySimButton.textContent = "Copied!";
		window.setTimeout(() => {
			copySimButton.textContent = "Copy for Sim";
		}, 1800);
	});
</script>

<style>
	.copy-sim-button {
		font-family: inherit;
		font-weight: 700;
	}

	.decklist-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
	}

	.section-heading-copy {
		display: grid;
		gap: 0.35rem;
	}

	.section-heading-copy h2 {
		margin: 0;
	}

	@media (min-width: 901px) {
		.decklist-intro {
			white-space: nowrap;
		}
	}

	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-inline-link {
		color: var(--accent);
		font-weight: 700;
	}

	.guide-inline-link:hover,
	.guide-inline-link:focus-visible {
		color: var(--accent-2);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.leader-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.loop-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.leader-card {
		display: grid;
		grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
	}

	.leader-preview,
	.option-card {
		border: none;
		background: transparent;
		padding: 0;
		cursor: pointer;
	}

	.leader-preview img,
	.option-card img {
		width: 100%;
		border-radius: 14px;
		display: block;
	}

	.leader-copy,
	.loop-grid,
	.thoughts-grid {
		display: grid;
		gap: 1rem;
	}

	.fact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.fact-box,
	.text-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.deck-card {
		padding: 1rem;
	}

	.fact-box {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border);
		border-radius: 14px;
	}

	.fact-label {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		margin-bottom: 0.45rem;
	}

	.fact-box p,
	.text-card p,
	.prep-intro,
	.section-note {
		margin: 0;
		color: var(--text-200);
	}

	.text-card h3,
	.thought-card h3,
	.conclusion-card h3 {
		margin-top: 0;
		margin-bottom: 0.6rem;
	}

	.text-card ul,
	.thought-card ul {
		margin: 0;
		padding-left: 1.15rem;
	}

	.effect-copy {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.keyword-badge {
		height: 24px;
		width: auto;
		vertical-align: middle;
		flex: 0 0 auto;
		transform: translateY(4px);
		margin: 0 0.12rem;
	}

	.effect-inline {
		display: inline-flex;
		align-items: baseline;
		gap: 0.5rem;
		white-space: nowrap;
	}

	.keyword-line {
		display: inline-flex;
		align-items: baseline;
		gap: 0.45rem;
		flex-wrap: wrap;
	}

	.ability-inline {
		display: inline;
	}

	.ability-inline .keyword-badge {
		display: inline-block;
		height: 18px;
		margin-right: 0.35rem;
		vertical-align: middle;
		transform: translateY(-1px);
	}

	.effect-copy .keyword-badge {
		height: 18px;
	}

	.effect-copy > .keyword-badge {
		transform: translateY(-2px);
		margin-right: 0.35rem;
	}

	.ability-stack {
		display: grid;
		gap: 0.55rem;
	}

	.ability-line {
		margin: 0;
		color: var(--text-100);
	}

	.ability-line-tag-only {
		margin-bottom: -0.15rem;
	}

	.loop-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-bottom: 1rem;
	}

	.loop-card {
		display: grid;
		grid-template-columns: 160px minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
		align-items: start;
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible,
	.leader-preview:hover,
	.leader-preview:focus-visible,
	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		outline: none;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code,
	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.prep-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1rem;
	}

	.prep-chip {
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 0.75rem;
		background: rgba(255, 255, 255, 0.03);
		text-align: left;
		display: grid;
