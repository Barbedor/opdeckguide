		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.curve-note {
		color: var(--text-300);
	}

	.mini-card {
		border: none;
		background: transparent;
		cursor: pointer;
		padding: 0;
		border-radius: 10px;
	}

	.mini-card img {
		width: 120px;
