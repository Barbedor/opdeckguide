---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Jinbe OP14 Deck Guide";
const description =
	"Jinbe OP14 deck guide for One Piece Card Game with decklist, curve reference, mulligan targets, options, and matchup focus leaders.";

const icon = "/assets/guides/jinbe-op14.png";

const decklist = [
	{ code: "OP14-040", name: "Jinbe", count: 1, img: "/Cards/OP14/OP14-040.jpg", role: "Leader" },
	{ code: "OP14-042", name: "Arlong", count: 4, img: "/Cards/OP14/OP14-042.jpg", role: "Character" },
	{ code: "OP14-050", name: "Chew", count: 4, img: "/Cards/OP14/OP14-050.jpg", role: "Character" },
	{ code: "OP14-051", name: "Octy", count: 4, img: "/Cards/OP14/OP14-051.jpg", role: "Character" },
	{ code: "OP03-044", name: "Kaya", count: 2, img: "/Cards/OP03/OP03-044.png", role: "Character" },
	{ code: "OP14-046", name: "Koala", count: 4, img: "/Cards/OP14/OP14-046.jpg", role: "Character" },
	{ code: "OP14-056", name: "Wadatsumi", count: 4, img: "/Cards/OP14/OP14-056.jpg", role: "Character" },
	{ code: "OP06-047", name: "Charlotte Pudding", count: 3, img: "/Cards/OP06/OP06-047.png", role: "Character" },
	{ code: "ST17-002", name: "Trafalgar Law", count: 4, img: "/Cards/ST17/ST17-002.png", role: "Character" },
	{ code: "OP14-043", name: "Aladine", count: 4, img: "/Cards/OP14/OP14-043.jpg", role: "Character" },
	{ code: "OP08-047", name: "Jozu", count: 4, img: "/Cards/OP08/OP08-047.png", role: "Character" },
	{ code: "OP14-054", name: "Fisher Tiger", count: 4, img: "/Cards/OP14/OP14-054.jpg", role: "Character" },
	{ code: "OP14-049", name: "Jinbe", count: 4, img: "/Cards/OP14/OP14-049.jpg", role: "Character" },
	{ code: "OP07-057", name: "Perfume Femur", count: 2, img: "/Cards/OP07/OP07-057.png", role: "Event" },
	{ code: "OP04-056", name: "Gum-Gum Red Roc", count: 3, img: "/Cards/OP04/OP04-056.png", role: "Event" },
];

const optionsGroups = [
	{
		cards: [
			{ code: "OP07-046", name: "Sengoku", img: "/Cards/OP07/OP07-046.png" },
			{ code: "OP07-047", name: "Trafalgar Law", img: "/Cards/OP07/OP07-047.png" },
		],
		note:
			"SW pack is a good option, Sengoku can search 8C and Perfume Law help vs Ace or Imu.",
	},
	{
		cards: [
			{ code: "OP14-045", name: "Kuroobi", img: "/Cards/OP14/OP14-045.jpg" },
			{ code: "OP14-047", name: "Shirahoshi", img: "/Cards/OP14/OP14-047.jpg" },
		],
		note:
			"Fish pack allows you to go more aggressive and cheat your Characters but the list is very short and this isn’t a good body.",
	},
	{
		cards: [{ code: "OP06-058", name: "Gravity Blade Raging Tiger", img: "/Cards/OP06/OP06-058.png" }],
		note:
