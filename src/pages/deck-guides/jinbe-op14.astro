		gap: 0.8rem;
	}

	.tip-cards {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.matchups-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.matchup-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
