---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Sengoku OP16 Deck Guide";
const description =
	"Sengoku OP16 deck guide for One Piece Card Game with decklist, key cards, turn curve, matchup spread, replacement options, and full deck fundamentals.";

const icon = "/assets/guides/Sengoku-op16.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP16-060", name: "Sengoku", count: 1, img: "/Cards/OP16/OP16-060.jpg", role: "Leader" },
	{ code: "OP16-066", name: "Sengoku", count: 4, img: "/Cards/OP16/OP16-066.jpg", role: "Character" },
	{ code: "OP16-064", name: "Koby", count: 4, img: "/Cards/OP16/OP16-064.jpg", role: "Character" },
	{ code: "OP16-067", name: "Tsuru", count: 4, img: "/Cards/OP16/OP16-067.jpg", role: "Character" },
	{ code: "OP16-070", name: "Donquixote Rosinante", count: 4, img: "/Cards/OP16/OP16-070.jpg", role: "Character" },
	{ code: "OP16-075", name: "Monkey.D.Garp", count: 3, img: "/Cards/OP16/OP16-075.jpg", role: "Character" },
	{ code: "OP16-073", name: "Borsalino", count: 4, img: "/Cards/OP16/OP16-073.jpg", role: "Character" },
	{ code: "OP16-065", name: "Sakazuki", count: 4, img: "/Cards/OP16/OP16-065.jpg", role: "Character" },
	{ code: "OP16-063", name: "Kuzan", count: 3, img: "/Cards/OP16/OP16-063.jpg", role: "Character" },
	{ code: "ST18-001", name: "Uso-Hachi", count: 2, img: "/Cards/ST18/ST18-001.png", role: "Character" },
	{ code: "OP11-067", name: "Charlotte Katakuri", count: 1, img: "/Cards/OP11/OP11-067.jpg", role: "Character" },
	{ code: "OP15-078", name: "Mamaragan", count: 4, img: "/Cards/OP15/OP15-078.jpg", role: "Event" },
	{ code: "OP15-077", name: "Lightning Dragon", count: 2, img: "/Cards/OP15/OP15-077.jpg", role: "Event" },
	{ code: "OP07-076", name: "Slow-Slow Beam Sword", count: 2, img: "/Cards/OP07/OP07-076.png", role: "Event" },
	{ code: "OP16-076", name: "The Three Admirals!!", count: 2, img: "/Cards/OP16/OP16-076.jpg", role: "Event" },
	{ code: "OP16-077", name: '"Buddha" Sengoku', count: 4, img: "/Cards/OP16/OP16-077.jpg", role: "Event" },
	{ code: "OP16-078", name: "Marineford", count: 3, img: "/Cards/OP16/OP16-078.jpg", role: "Stage" },
];

const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const leaderCard = { code: "OP16-060", name: "Sengoku", img: "/Cards/OP16/OP16-060.jpg" };
const admiralCards = [
	{ code: "OP16-073", name: "Borsalino", img: "/Cards/OP16/OP16-073.jpg" },
	{ code: "OP16-065", name: "Sakazuki", img: "/Cards/OP16/OP16-065.jpg" },
	{ code: "OP16-063", name: "Kuzan", img: "/Cards/OP16/OP16-063.jpg" },
];
const garpCard = { code: "OP16-075", name: "Monkey.D.Garp", img: "/Cards/OP16/OP16-075.jpg" };

const keyCards = [
	{
		code: "OP15-078",
		name: "Mamaragan",
		img: "/Cards/OP15/OP15-078.jpg",
		copy: "An incredible counter that doesn't cost you hand cards. It also works perfectly with Sakazuki, letting you rest characters all the way up to 11K power.",
	},
	{
		code: "OP15-077",
		name: "Lightning Dragon",
		img: "/Cards/OP15/OP15-077.jpg",
		copy: "It fills a similar role to Mamaragan, but it also slows the opponent down by freezing attackers, especially in matchups like Nami.",
	},
	{
		code: "ST18-001",
		name: "Uso-Hachi",
		img: "/Cards/ST18/ST18-001.png",
		copy: "A reliable generic 2K counter that helps stabilize early and can also help you close games.",
	},
	{
		code: "OP07-076",
		name: "Slow-Slow Beam Sword",
		img: "/Cards/OP07/OP07-076.png",
		copy: "A very strong counter that helps rest large bodies such as Edward Newgate or Sabo from the Lucy deck.",
	},
	{
		code: "OP11-067",
		name: "Charlotte Katakuri",
		img: "/Cards/OP11/OP11-067.jpg",
		copy: "A very strong fallback option for turns where you still cannot activate the leader effect.",
	},
];

const curveFirst = [
	{
		don: "1 DON!!",
		cards: [
			{ code: "OP16-078", name: "Marineford", img: "/Cards/OP16/OP16-078.jpg" },
			{ code: "OP16-077", name: '"Buddha" Sengoku', img: "/Cards/OP16/OP16-077.jpg" },
			{ code: "OP16-067", name: "Tsuru", img: "/Cards/OP16/OP16-067.jpg" },
			{ code: "OP16-064", name: "Koby", img: "/Cards/OP16/OP16-064.jpg" },
		],
	},
	{
		don: "3 DON!!",
		cards: [
			{ code: "OP16-078", name: "Marineford", img: "/Cards/OP16/OP16-078.jpg" },
			{ code: "OP16-067", name: "Tsuru", img: "/Cards/OP16/OP16-067.jpg" },
			{ code: "OP16-064", name: "Koby", img: "/Cards/OP16/OP16-064.jpg" },
		],
	},
	{
		don: "5 DON!!",
		cards: [{ code: "OP16-075", name: "Monkey.D.Garp", img: "/Cards/OP16/OP16-075.jpg" }],
	},
	{
		don: "7 DON!!",
		cards: admiralCards,
	},
	{
		don: "9 DON!!",
		cards: admiralCards,
	},
];

const curveSecond = [
	{
		don: "2 DON!!",
		cards: [
			{ code: "OP16-078", name: "Marineford", img: "/Cards/OP16/OP16-078.jpg" },
			{ code: "OP16-077", name: '"Buddha" Sengoku', img: "/Cards/OP16/OP16-077.jpg" },
			{ code: "OP16-067", name: "Tsuru", img: "/Cards/OP16/OP16-067.jpg" },
			{ code: "OP16-064", name: "Koby", img: "/Cards/OP16/OP16-064.jpg" },
		],
	},
	{
		don: "4 DON!!",
		cards: [{ code: "OP16-070", name: "Donquixote Rosinante", img: "/Cards/OP16/OP16-070.jpg" }],
	},
	{
		don: "6 DON!!",
		cards: [{ code: "OP16-075", name: "Monkey.D.Garp", img: "/Cards/OP16/OP16-075.jpg" }],
	},
	{
		don: "8 DON!!",
		cards: admiralCards,
	},
	{
		don: "10 DON!!",
		cards: admiralCards,
	},
];

const matchups = [
	{ code: "OP16-080", name: "Marshall.D.Teach", img: "/Cards/OP16/OP16-080.jpg", first: "favored", second: "even" },
	{ code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg", first: "favored", second: "favored" },
	{ code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg", first: "even", second: "bad" },
	{ code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg", first: "even", second: "bad" },
	{ code: "OP15-002", name: "Lucy", img: "/Cards/OP15/OP15-002.jpg", first: "favored", second: "bad" },
	{ code: "OP16-079", name: "Yamato", img: "/Cards/OP16/OP16-079.jpg", first: "favored", second: "even" },
	{ code: "OP16-022", name: "Monkey.D.Luffy", img: "/Cards/OP16/OP16-022.jpg", first: "unfavored", second: "bad" },
	{ code: "OP09-001", name: "Shanks", img: "/Cards/OP09/OP09-001.jpg", first: "favored", second: "unfavored" },
];

const matchupLegend = [
	{ tone: "favored", label: "Favored" },
	{ tone: "even", label: "Even" },
	{ tone: "unfavored", label: "Unfavored" },
	{ tone: "bad", label: "Bad" },
];

const optionCards = [
	{ code: "OP13-076", name: "Divine Departure", img: "/Cards/OP13/OP13-076.jpg" },
	{ code: "EB03-036", name: "Baby 5", img: "/Cards/EB03/EB03-036.jpg" },
	{ code: "EB04-038", name: "Rosinante & Law", img: "/Cards/EB04/EB04-038.jpg" },
	{ code: "OP07-064", name: "Sanji", img: "/Cards/OP07/OP07-064.png" },
	{ code: "EB01-061", name: "Mr.2.Bon.Kurei(Bentham)", img: "/Cards/EB01/EB01-061.jpg" },
	{ code: "OP09-077", name: "Gum-Gum Thunder", img: "/Cards/OP09/OP09-077.jpg" },
];

const strengths = [
	"A huge number of searchers, so it's hard to miss your core pieces.",
	"You can drop three 8-cost bodies as early as turn 4.",
	"The deck can shut off blockers and force damage through.",
];

const weaknesses = [
	"It's a slower deck and needs time to comfortably reach its key turn.",
	"That makes it vulnerable to aggressive decks.",
	"It can brick because it plays a lot of heavy cards.",
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div class="hero-copy">
				<span class="hero-badge">Deck Guide</span>
				<h1>Sengoku OP16 Deck Guide</h1>
				<p>
					This guide covers a new and innovative OP16 deck led by Sengoku. The leader gives you explosive ramp
					and attack turns your opponent won't expect, with a board-spam pattern that can remind you of Imu.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Sengoku OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="section-heading-copy">
					<h2>Decklist</h2>
					<p class="decklist-intro">The current OP16 Sengoku list built around the Admiral curve and event support.</p>
				</div>
				<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
					Copy for Sim
				</button>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="leader" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Leader Sengoku</h2>
				</div>
			</div>
			<div class="feature-card leader-panel">
				<button
					class="card-button leader-card-button"
					type="button"
					data-card-preview
					data-full={leaderCard.img}
					data-name={`${leaderCard.code} ${leaderCard.name}`}
				>
					<img loading="lazy" src={leaderCard.img} alt={`${leaderCard.code} ${leaderCard.name}`} />
				</button>
				<div class="leader-copy">
					<p class="leader-lead">
						Sengoku's leader effect will remind a lot of players of Imu. It's not the same, but it follows a
						similar idea.
					</p>
					<p class="leader-effect-box">
						On <strong>Activate: Main</strong>, you return 8 active DON!! cards from the field to the DON!! deck,
						then play 3 Admirals with different names from your hand. It sounds crazy at first, but when the
						Admirals leave the field they refund DON!!, so the real loss isn't as brutal as it looks.
					</p>
					<p class="leader-closing">
						In practice, after using the effect and letting the Admirals cycle back DON!!, you still get to keep a
						strong board of three 8K bodies while staying on a playable amount of DON!! for the next turn.
					</p>
					<div class="leader-note">Goal: reach your 8-DON!! effect turn cleanly, then flood the board with 3 different Admirals.</div>
				</div>
				<div class="admiral-strip">
					{admiralCards.map((card) => (
						<button
							class="card-button admiral-chip"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="fundamentals" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Deck Fundamentals</h2>
				</div>
			</div>
			<div class="feature-card fundamentals-panel">
				<div class="text-block">
					<ul class="bullet-list">
						<li>This deck mixes ramp with powerful board spam.</li>
						<li>It plays so many searchers that missing the 3 Admirals is uncommon.</li>
						<li>You should always search first and prioritize finding the 3 Admirals and Monkey.D.Garp.</li>
						<li>
							Garp is the most important card because he turns your 5 DON!! turn into 7 DON!!, with 1 DON!! still
							active. That lets you use another searcher, the stage effect, and still set up the following turn
							for the triple-Admiral drop.
						</li>
					</ul>
				</div>
				<div class="spotlight-card">
					<button
						class="card-button spotlight-button"
						type="button"
						data-card-preview
						data-full={garpCard.img}
						data-name={`${garpCard.code} ${garpCard.name}`}
					>
						<img loading="lazy" src={garpCard.img} alt={`${garpCard.code} ${garpCard.name}`} />
					</button>
					<p class="spotlight-copy">The most important bridge card in the deck.</p>
				</div>
			</div>
		</div>
	</section>

	<section id="pros-cons" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Strengths & Weaknesses</h2>
				</div>
			</div>
			<div class="split-grid">
				<div class="info-card info-card-good">
					<div class="info-head">
						<span class="info-icon" aria-hidden="true">+</span>
						<h3>Strengths</h3>
					</div>
					<ul class="bullet-list">
						{strengths.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
				<div class="info-card info-card-bad">
					<div class="info-head">
						<span class="info-icon" aria-hidden="true">-</span>
						<h3>Weaknesses</h3>
					</div>
					<ul class="bullet-list">
						{weaknesses.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section id="key-cards" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Important Cards</h2>
				</div>
			</div>
			<div class="key-grid">
				{keyCards.map((card) => (
					<div class="feature-card key-card">
						<button
							class="card-button key-card-button"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="key-copy">
							<h3>{card.name}</h3>
							<p>{card.copy}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve</h2>
					<p>Priority lines going first and going second.</p>
				</div>
			</div>
			<div class="split-grid curve-layout">
				<div class="curve-column">
					<div class="curve-title">Going First</div>
					<div class="curve-stack">
						{curveFirst.map((step) => (
							<div class="feature-card curve-step">
								<div class="curve-don">{step.don}</div>
								<div class="curve-cards">
									{step.cards.map((card) => (
										<button
											class="card-button mini-curve-card"
											type="button"
											data-card-preview
											data-full={card.img}
											data-name={`${card.code} ${card.name}`}
										>
											<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
										</button>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="curve-column">
					<div class="curve-title">Going Second</div>
					<div class="curve-stack">
						{curveSecond.map((step) => (
							<div class="feature-card curve-step">
								<div class="curve-don">{step.don}</div>
								<div class="curve-cards">
									{step.cards.map((card) => (
										<button
											class="card-button mini-curve-card"
											type="button"
											data-card-preview
											data-full={card.img}
											data-name={`${card.code} ${card.name}`}
										>
											<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
										</button>
									))}
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
				</div>
			</div>
			<div class="feature-card matchups-panel">
				<div class="matchup-legend">
					{matchupLegend.map((item) => (
						<div class="legend-item">
							<span class:list={["legend-dot", item.tone]}></span>
							<span>{item.label}</span>
						</div>
					))}
				</div>
				<div class="matchups-grid">
					{matchups.map((entry) => (
						<div class="matchup-card">
							<button
								class="card-button matchup-card-button"
								type="button"
								data-card-preview
								data-full={entry.img}
								data-name={`${entry.code} ${entry.name}`}
							>
								<img loading="lazy" src={entry.img} alt={`${entry.code} ${entry.name}`} />
							</button>
							<div class="matchup-name">{entry.name}</div>
							<div class="turn-line">
								<span>1st</span>
								<span class:list={["legend-dot", entry.first]}></span>
							</div>
							<div class="turn-line">
								<span>2nd</span>
								<span class:list={["legend-dot", entry.second]}></span>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Good Options</h2>
				</div>
			</div>
			<div class="options-grid">
				{optionCards.map((card) => (
					<div class="feature-card option-card-shell">
						<button
							class="card-button option-card-button"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="option-name">{card.name}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<div class="card-modal-frame">
				<img src="" alt="" data-modal-image />
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalFrame = document.querySelector(".card-modal-frame");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	let lockedScrollY = 0;

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		lockedScrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${lockedScrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
		document.body.style.overflow = "hidden";
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		document.body.style.overflow = "";
		window.scrollTo(0, lockedScrollY);
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target === modalImage) {
			closeModal();
			return;
		}
		if (modalFrame && !modalFrame.contains(target) && target !== closeButton) {
			closeModal();
		}
	});
	modalImage?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	const copySimButton = document.querySelector("[data-copy-sim]");

	copySimButton?.addEventListener("click", async () => {
		const deckCode = copySimButton.getAttribute("data-sim-deck");
		if (!deckCode) return;

		try {
			await navigator.clipboard.writeText(deckCode);
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = deckCode;
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		}

		copySimButton.textContent = "Copied!";
		window.setTimeout(() => {
			copySimButton.textContent = "Copy for Sim";
		}, 1800);
	});
</script>

