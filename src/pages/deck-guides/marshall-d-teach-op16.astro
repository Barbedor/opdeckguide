---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Marshall.D.Teach OP16 Deck Guide";
const description =
	"Marshall.D.Teach OP16 deck guide for One Piece Card Game with decklist, mulligan priorities, a curve guide, tech cards, matchup notes, and gameplay tips.";

const icon = "/assets/guides/Teach-op16.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const card = (code, name, img) => ({ code, name, img });

const teachLeader = card("OP16-080", "Marshall D. Teach", "/Cards/OP16/OP16-080.jpg");
const vanAugur = card("OP16-103", "Van Augur", "/Cards/OP16/OP16-103.jpg");
const docQ = card("OP16-109", "Doc Q", "/Cards/OP16/OP16-109.jpg");
const vascoShot = card("OP16-110", "Vasco Shot", "/Cards/OP16/OP16-110.jpg");
const burgess = card("OP09-086", "Jesus Burgess", "/Cards/OP09/OP09-086.jpg");
const shiryu = card("OP16-108", "Shiryu", "/Cards/OP16/OP16-108.jpg");
const catarinaDevon = card("OP16-104", "Catarina Devon", "/Cards/OP16/OP16-104.jpg");
const teach8 = card("OP16-119", "Marshall D. Teach", "/Cards/OP16/OP16-119.jpg");
const teach10 = card("OP09-093", "Marshall D. Teach", "/Cards/OP09/OP09-093.jpg");
const borsalino = card("EB04-058", "Borsalino", "/Cards/EB04/EB04-058.jpg");
const sanjuanWolf = card("OP16-106", "Sanjuan Wolf", "/Cards/OP16/OP16-106.jpg");
const myEraBegins = card("OP09-096", "My Era Begins!!", "/Cards/OP09/OP09-096.jpg");
const zehahaha = card("OP16-116", "Zehahaha", "/Cards/OP16/OP16-116.jpg");
const fullalead = card("OP09-099", "Fullalead", "/Cards/OP09/OP09-099.jpg");

const lafitte = card("OP16-114", "Lafitte", "/Cards/OP16/OP16-114.jpg");
const baby5 = card("OP12-112", "Baby 5", "/Cards/OP12/OP12-112.jpg");
const shiryuAlt = card("PRB02-015", "Shiryu", "/Cards/PRB02/PRB02-015.jpg");
const wyper = card("OP15-114", "Wyper", "/Cards/OP15/OP15-114.jpg");
const boaHancockTech = card("OP14-112", "Boa Hancock", "/Cards/OP14/OP14-112.jpg");
const youllFrightenMe = card("OP14-118", "You'll Frighten Me!!", "/Cards/OP14/OP14-118.jpg");
const blackVortex = card("OP16-115", "Black Vortex", "/Cards/OP16/OP16-115.jpg");

const yamato16 = card("OP16-079", "Yamato OP16", "/Cards/OP16/OP16-079.jpg");
const nami11 = card("OP11-041", "Nami OP11", "/Cards/OP11/OP11-041.jpg");
const enel15 = card("OP15-058", "Purple Enel OP15", "/Cards/OP15/OP15-058.jpg");
const luffy16 = card("OP16-022", "Green/Blue Luffy OP16", "/Cards/OP16/OP16-022.jpg");
const rosinante12 = card("OP12-061", "Rosinante OP12", "/Cards/OP12/OP12-061.jpg");
const shanks = card("OP09-001", "Shanks OP16", "/Cards/OP09/OP09-001.jpg");
const ace16 = card("OP16-001", "Ace OP16", "/Cards/OP16/OP16-001.jpg");
const boaLeader = card("OP14-041", "Boa OP16", "/Cards/OP14/OP14-041.jpg");
const lucy15 = card("OP15-002", "Lucy OP15", "/Cards/OP15/OP15-002.jpg");

const decklist = [
	{ ...teachLeader, count: 1, role: "Leader" },
	{ ...vanAugur, count: 4, role: "Character" },
	{ ...docQ, count: 4, role: "Character" },
	{ ...vascoShot, count: 4, role: "Character" },
	{ ...burgess, count: 4, role: "Character" },
	{ ...shiryu, count: 4, role: "Character" },
	{ ...catarinaDevon, count: 4, role: "Character" },
	{ ...teach8, count: 4, role: "Character" },
	{ ...teach10, count: 4, role: "Character" },
	{ ...borsalino, count: 4, role: "Character" },
	{ ...sanjuanWolf, count: 4, role: "Character" },
	{ ...myEraBegins, count: 4, role: "Event" },
	{ ...zehahaha, count: 2, role: "Event" },
	{ ...fullalead, count: 4, role: "Stage" },
];

const simDeckCode = decklist.flatMap((entry) => expandSimLines(entry.count, entry.code)).join("\n");

const mulliganKeeps = [
	{
		copy:
			"One of the two most important mulligan cards in the deck. It helps filter your hand and makes it much easier to find the missing pieces that keep your curve intact.",
		cards: [myEraBegins],
	},
	{
		copy:
			"The other key keep. Fullalead smooths out your opener and helps you find the next step of your curve faster. I'd rather keep a searcher plus Fullalead than a hand that already has Burgess but no setup.",
		cards: [fullalead],
	},
];

const idealHandCards = [myEraBegins, fullalead, burgess];
const searchPriorityCards = [vanAugur, docQ, vascoShot];

const curveSecond = [
	{
		label: "2 DON!!",
		notes:
			"Your priority is to play My Era Begins!! and Fullalead. These cards set up the rest of your curve, and if your hand is already fine, you can instead search for the most relevant 1-cost character for the matchup.",
		cards: [myEraBegins, fullalead],
	},
	{
		label: "4 DON!!",
		notes:
			"Jesus Burgess is the best play in the deck here. I almost always want Burgess on this turn because it starts controlling the pace while setting up your later power turns. If you don't have it, just keep developing cleanly without breaking your curve.",
		cards: [burgess],
	},
	{
		label: "6 DON!!",
		notes:
			"This turn belongs to Shiryu. It's the key bridge into the midgame and keeps your plan moving without forcing awkward sequencing before the double-Teach turns.",
		cards: [shiryu],
	},
	{
		label: "8 DON!!",
		notes:
			"Your priority is 8-cost Marshall D. Teach. This is where the lock starts to come together, and I really value respecting this curve more than filling the turn with multiple smaller plays.",
		cards: [teach8],
	},
	{
		label: "10 DON!!",
		notes:
			"The 10-DON!! turn is all about the blocker Marshall D. Teach. This is your main win condition. Once it lands, the opponent's offensive options shrink hard and most games swing permanently in Teach's favor.",
		cards: [teach10],
	},
	{
		label: "Late game",
		notes:
			"Once 10-cost Teach is in play, the goal is to keep full control of the game's pace. Keep leaning on your triggers and control effects so the opponent never gets a clean way back into the game.",
		cards: [teach10, myEraBegins, zehahaha],
	},
];

const optionsCards = [
	{
		...lafitte,
		copy:
			"A very good option against decks that flood the board early. It buys time and improves your control of the game's pace. I'd look at it first if the format gets more aggressive.",
	},
	{
		...baby5,
		copy:
			"It adds more consistency by making the deck's key cards easier to find. Even so, I prefer the current list because the search package already feels sufficient to me.",
	},
	{
		...shiryuAlt,
		copy:
			"This Shiryu is a real option depending on the meta. It offers more control into certain boards, but I still prefer the main version because it lines up better with the overall game plan.",
	},
	{
		...wyper,
		copy:
			"Wyper is a meta call for very aggressive rooms. I think it's a good removal card, but not versatile enough for the main list right now.",
	},
	{
		...boaHancockTech,
		copy:
			"Boa Hancock can improve slower matchups by adding more value. Even then, I think the current list is already stable enough, and I'd rather not change the curve.",
	},
	{
		...youllFrightenMe,
		copy:
			"It's another defensive option that can help your survivability in a few difficult matchups. I still prefer keeping a higher character count instead of loading up on extra defensive events.",
	},
	{
		...blackVortex,
		copy:
			"Black Vortex is worth considering into decks that rely heavily on their effects. The card has real upside, but I don't think it's mandatory in the current build.",
	},
];

const matchups = [
	{
		label: "Mirror Match",
		tone: "even",
		icon: "≈",
		leader: teachLeader,
		notes: [
			"The mirror is mostly about resource management and trigger management.",
			"Choosing the right cards to put back into Life matters a lot.",
			"Respect your curve all the way to 10-cost Teach.",
			"Don't rush 10-cost Teach if waiting one more turn gives you a cleaner, higher-value setup.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: yamato16,
		notes: [
			"Teach can slow the game down and redirect attacks well, but Yamato's ultra-explosive turns are still very hard to handle.",
			"Slow the game down as much as possible.",
			"Prioritize your curve over aggressive plays.",
			"Save your resources for Yamato's biggest threats.",
		],
	},
	{
		label: "Favorable",
		tone: "up",
		icon: "↑",
		leader: nami11,
		notes: [
			"Teach has a lot of control tools that make Nami's game plan much harder to execute.",
			"Don't rush.",
			"Keep developing your board while controlling the opposing threats.",
			"Use your triggers to keep the resource lead.",
		],
	},
	{
		label: "Favorable",
		tone: "up",
		icon: "↑",
		leader: enel15,
		notes: [
			"Enel is a positive matchup for Teach.",
			"If you control the pace of the game, Teach naturally limits Enel's strongest turns.",
			"Play around your curve.",
			"Save your control effects for the most important threats.",
			"Don't let Enel take the tempo back.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: luffy16,
		notes: [
			"Luffy is extremely fast, which is a real problem for Teach early on.",
			"Teach still has tools to stop Luffy from fully developing, but only if your curve stays intact.",
			"Keep advancing your curve.",
			"Don't waste your control cards too early.",
			"Get to 10-cost Teach quickly so the explosive Luffy turns become harder to convert.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: rosinante12,
		notes: [
			"Rosinante isn't easy, but the matchup is very winnable.",
			"I especially like Vasco Shot here because it slows their development efficiently.",
			"Search Vasco Shot early.",
			"Don't let Rosinante settle into a comfortable board state.",
			"Respect your curve all the way to 10-cost Teach.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: shanks,
		notes: [
			"The numbers favor Teach, mostly because the deck is good at slowing Shanks down.",
			"Control the pace of the game.",
			"Preserve your resources for the late game.",
			"Make 10-cost Teach your top priority.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: ace16,
		notes: [
			"Teach can slow Ace's aggressive plan down well if it survives long enough to reach the late game.",
			"Don't get dragged into a damage race.",
			"Stabilize first, then take over with Teach.",
			"Manage the early threats instead of trying to fire back immediately.",
		],
	},
	{
		label: "Slightly Favorable",
		tone: "up",
		icon: "↑",
		leader: boaLeader,
		notes: [
			"Teach has enough control to limit the value Boa generates and slowly pull ahead.",
			"Don't over-invest into your board.",
			"Save your key cards for the important turns.",
			"Build toward your late-game lock one step at a time.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: lucy15,
		notes: [
			"Lucy is tough because it pressures quickly while also building a wide board that Teach struggles to contain in the early turns.",
			"If Teach doesn't find the right stabilizing cards fast, Lucy often closes the game before the control plan is fully online.",
			"Slow the pace down however you can.",
			"Answer the threats one by one.",
			"Respect your curve all the way to 10-cost Teach.",
		],
	},
];

const tips = [
	{
		copy:
			"Don't try to win quickly. Teach is built to slow the game down first, then take permanent control once 10-cost Marshall D. Teach comes online.",
		cards: [teach10],
	},
	{
		copy:
			"Respect your curve whenever possible. The deck is designed to chain Jesus Burgess into Shiryu into 8-cost Teach into 10-cost Teach. Missing one of those checkpoints makes the deck much weaker.",
		cards: [burgess, shiryu, teach8, teach10],
	},
	{
		copy:
			"Adapt your searches to the matchup. Van Augur, Doc Q, and Vasco Shot all do different jobs, so always take the one that answers the opposing deck best.",
		cards: [vanAugur, docQ, vascoShot],
	},
	{
		copy:
			"Manage your trigger cards intelligently. The cards you put back into Life can completely change a game, so think carefully about which trigger gives you the highest-value setup.",
		cards: [teach8, zehahaha],
	},
	{
		copy:
			"Don't waste your control effects. Your resources are limited, so save them for the characters that actually threaten your game plan.",
		cards: [vascoShot, shiryu],
	},
	{
		copy:
			"Learn when to starve your opponent. In some matchups, it's better not to attack Life so you can delay opposing triggers and keep control of the pace.",
		cards: [teachLeader],
	},
	{
		copy:
			"10-cost Marshall D. Teach is your main win condition. Don't slam it down too early if waiting one more turn gives you a much stronger setup.",
		cards: [teach10],
	},
	{
		copy:
			"Resource management is what separates solid Teach play from excellent Teach play. The deck rewards sequencing, restraint, and good Life management more than flashy turns.",
		cards: [myEraBegins, fullalead, teach10],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Marshall.D.Teach OP16 Deck Guide</h1>
				<p>
					Marshall.D.Teach OP16 is a late-game control deck that cares far more about hitting its curve than
					pushing early damage. The list wins by sequencing Jesus Burgess into Shiryu into both Teach bodies,
					then locking the game down once 10-cost Teach hits the field.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Marshall.D.Teach OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="decklist-title-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<p>Main list for Marshall.D.Teach OP16 in the OP16 format.</p>
			</div>
			<div class="deck-grid">
				{decklist.map((entry) => (
					<button
						class="deck-card"
						type="button"
						data-card-preview
						data-full={entry.img}
						data-name={`${entry.code} ${entry.name}`}
					>
						<img loading="lazy" src={entry.img} alt={`${entry.code} ${entry.name}`} />
						<div class="deck-info">
							<span class="deck-count">{entry.count}x</span>
							<div>
								<div class="deck-name">{entry.name}</div>
								<div class="deck-code">{entry.code}</div>
							</div>
						</div>
						<span class="deck-role">{entry.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>
						The mulligan is very simple: more than anything else, the deck wants to make sure its curve is
						covered.
					</p>
				</div>
			</div>
			<div class="mulligan-stack">
				<div class="tip-card glow-block">
					<h3>Cards to Prioritize</h3>
					<div class="mulligan-rows two-column-rows">
						{mulliganKeeps.map((entry) => (
							<div class="mulligan-row">
								<div class="tip-cards">
									{entry.cards.map((entryCard) => (
										<button
											class="mini-card"
											type="button"
											data-card-preview
											data-full={entryCard.img}
											data-name={`${entryCard.code} ${entryCard.name}`}
										>
											<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											<div class="mini-label">{entryCard.name}</div>
										</button>
									))}
								</div>
								<div class="mulligan-copy">
									<p>{entry.copy}</p>
								</div>
							</div>
						))}
					</div>
				</div>
				<div class="tip-card glow-block">
					<h3>Ideal Hand & Search Priorities</h3>
					<div class="sendback-grid ideal-grid six-card-grid">
						{idealHandCards.map((entryCard) => (
							<button
								class="mini-card sendback-card"
								type="button"
								data-card-preview
								data-full={entryCard.img}
								data-name={`${entryCard.code} ${entryCard.name}`}
							>
								<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
								<div class="mini-label sendback-label">{entryCard.name}</div>
							</button>
						))}
					</div>
					<ul class="bullet-list">
						<li>My Era Begins!! and Fullalead</li>
						<li>Jesus Burgess for the 4-DON!! turn</li>
						<li>Enough setup to lead into Shiryu and then both Teach bodies</li>
					</ul>
					<p class="mulligan-text">
						The goal is simply to make sure your curve is covered all the way into the late game.
					</p>
					<h4>Hands to Send Back</h4>
					<ul class="bullet-list">
						<li>No My Era Begins!! and no Fullalead</li>
						<li>No realistic way to hit your curve</li>
						<li>A hand made up mostly of late-game cards</li>
					</ul>
					<p class="mulligan-text">
						The deck works because of its consistency. Missing a DON!! checkpoint slows your whole plan down.
					</p>
					<h4>Search Priorities</h4>
					<p class="mulligan-text">
						What you search depends directly on the matchup. Your searchers are there both to complete your
						curve and to find the right 1-cost character for the spot.
					</p>
					<div class="sendback-grid ideal-grid">
						{searchPriorityCards.map((entryCard) => (
							<button
								class="mini-card sendback-card"
								type="button"
								data-card-preview
								data-full={entryCard.img}
								data-name={`${entryCard.code} ${entryCard.name}`}
							>
								<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
								<div class="mini-label sendback-label">{entryCard.name}</div>
							</button>
						))}
					</div>
					<ul class="bullet-list">
						<li>Van Augur when power reduction matters most</li>
						<li>Doc Q to remove certain low-cost characters</li>
						<li>Vasco Shot when you need to slow specific threats, especially Rosinante</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>
						Going second is the recommended seat in most matchups. It gives you faster access to the key cards
						in your curve and lets Teach set up the full game plan without falling behind. Teach's curve
						isn't really built for going first, so if you do have to go first, your early turns should be
						played based on the matchup with Van Augur, Doc Q, or Vasco Shot.
					</p>
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going Second</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((entryCard) => (
									<button
										class={`mini-card curve-card ${entryCard.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={entryCard.img}
										data-name={`${entryCard.code} ${entryCard.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
											{entryCard.badgeCard && (
												<img class="card-badge-image" src={entryCard.badgeCard} alt="1 DON!! attached" loading="lazy" />
											)}
										</span>
										<div class="mini-label">{entryCard.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tech Cards</h2>
					<p>Alternative cards and flex slots for different OP16 rooms.</p>
				</div>
			</div>
			<div class="options-rich-grid">
				{optionsCards.map((entryCard) => (
					<div class="option-note-card glow-block">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={entryCard.img}
							data-name={`${entryCard.code} ${entryCard.name}`}
						>
							<img loading="lazy" src={entryCard.img} alt={`${entryCard.code} ${entryCard.name}`} />
							<div class="option-info">
								<div class="deck-name">{entryCard.name}</div>
								<div class="deck-code">{entryCard.code}</div>
							</div>
						</button>
						<p>{entryCard.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>How the main OP16 leaders line up against Teach.</p>
					<p class="matchups-intro-link-copy">
						For the full turn-order breakdown, see the
						<a class="guide-inline-link" href="/meta-analysis/Black-Yellow-Marshall-D-Teach-op16-stats/">
							OP16 Black/Yellow Marshall D. Teach stats in OP16 Format
						</a>
					</p>
				</div>
			</div>
			<div class="matchups-stack">
				{matchups.map((matchup) => (
					<div class="matchup-card glow-block">
						<div class={`matchup-badge ${matchup.tone === "down" ? "badge-down" : matchup.tone === "even" ? "badge-even" : "badge-up"}`}>
