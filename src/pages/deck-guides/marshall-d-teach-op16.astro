---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Marshall.D.Teach OP16 Preview Deck Guide";
const description =
	"Marshall.D.Teach OP16 preview deck guide for One Piece Card Game with an early decklist idea, key Blackbeard spoilers, the old-set shell, and early strengths and weaknesses.";

const icon = "/assets/guides/Teach-op16.png";
const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP16-080", name: "Marshall.D.Teach", count: 1, img: "/Cards/OP16/OP16-080.jpg", role: "Leader" },
	{ code: "OP16-103", name: "Van Augur", count: 2, img: "/Cards/OP16/OP16-103.jpg", role: "Character" },
	{ code: "OP16-109", name: "Doc Q", count: 4, img: "/Cards/OP16/OP16-109.jpg", role: "Character" },
	{ code: "OP16-110", name: "Vasco Shot", count: 4, img: "/Cards/OP16/OP16-110.jpg", role: "Character" },
	{ code: "OP12-112", name: "Baby 5", count: 4, img: "/Cards/OP12/OP12-112.jpg", role: "Character" },
	{ code: "OP16-104", name: "Catarina Devon", count: 4, img: "/Cards/OP16/OP16-104.jpg", role: "Character" },
	{ code: "EB04-058", name: "Borsalino", count: 4, img: "/Cards/EB04/EB04-058.jpg", role: "Character" },
	{ code: "OP16-108", name: "Shiryu", count: 4, img: "/Cards/OP16/OP16-108.jpg", role: "Character" },
	{ code: "OP09-093", name: "Marshall.D.Teach", count: 4, img: "/Cards/OP09/OP09-093.jpg", role: "Character" },
	{ code: "OP09-086", name: "Jesus Burgess", count: 4, img: "/Cards/OP09/OP09-086.jpg", role: "Character" },
	{ code: "OP16-119", name: "Marshall.D.Teach", count: 4, img: "/Cards/OP16/OP16-119.jpg", role: "Character" },
	{ code: "OP09-096", name: "This is MY AGE!!!!", count: 4, img: "/Cards/OP09/OP09-096.jpg", role: "Event" },
	{ code: "OP09-097", name: "Black Vortex", count: 2, img: "/Cards/OP09/OP09-097.jpg", role: "Event" },
	{ code: "OP16-116", name: "ZEHAHAHAHAH", count: 2, img: "/Cards/OP16/OP16-116.jpg", role: "Event" },
	{ code: "OP09-099", name: "Fullalead", count: 4, img: "/Cards/OP09/OP09-099.jpg", role: "Stage" },
];
const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const leaderCard = { code: "OP16-080", name: "Marshall.D.Teach", img: "/Cards/OP16/OP16-080.jpg" };

const spoilerCards = [
	{ code: "OP16-119", name: "Marshall.D.Teach", img: "/Cards/OP16/OP16-119.jpg" },
	{ code: "OP16-116", name: "ZEHAHAHAHAH", img: "/Cards/OP16/OP16-116.jpg" },
];

const prepPackage = [
	{ count: 2, code: "OP09-091", name: "Vasco Shot", img: "/Cards/OP09/OP09-091.jpg" },
	{ count: 4, code: "OP09-086", name: "Jesus Burgess", img: "/Cards/OP09/OP09-086.jpg" },
	{ count: 2, code: "OP10-086", name: "Shiryu", img: "/Cards/OP10/OP10-086.jpg" },
	{ count: 4, code: "OP12-112", name: "Baby 5", img: "/Cards/OP12/OP12-112.jpg" },
	{ count: 2, code: "PRB02-015", name: "Shiryu", img: "/Cards/PRB02/PRB02-015.jpg" },
	{ count: 4, code: "OP10-082", name: "Kuzan", img: "/Cards/OP10/OP10-082.jpg" },
	{ count: 4, code: "ST27-003", name: "Kuzan", img: "/Cards/ST27/ST27-003.jpg" },
	{ count: 2, code: "OP14-112", name: "Boa Hancock", img: "/Cards/OP14/OP14-112.jpg" },
	{ count: 4, code: "OP09-093", name: "Marshall.D.Teach", img: "/Cards/OP09/OP09-093.jpg" },
	{ count: 2, code: "OP06-115", name: "You’re the One Who Should Disappear!", img: "/Cards/OP06/OP06-115.png" },
	{ count: 4, code: "OP09-096", name: "This is MY AGE!!!!", img: "/Cards/OP09/OP09-096.jpg" },
	{ count: 2, code: "OP09-098", name: "Black Hole", img: "/Cards/OP09/OP09-098.jpg" },
	{ count: 4, code: "OP09-099", name: "Fullalead", img: "/Cards/OP09/OP09-099.jpg" },
];

const strengths = [
	"Very strong board control",
	"Excellent midgame and late-game stability",
	"Very good at breaking up the opponent's game plan",
	"High value from key cards",
];

const weaknesses = [
	"Slow to set up",
	"Dependence on good management cards",
	"Not much early pressure",
	"Weak against aggro decks",
];

const conclusion =
	"The deck has a lot of very good cards, especially now that the two spoiler cards are in the mix, and the updated list looks cleaner and more stable than the first draft. Teach still has strong control tools and a solid shell, and this version does a better job of trimming the clunkier pieces. For now, I'd put it at 8 / 10.";
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Marshall.D.Teach OP16 Preview Deck Guide</h1>
				<p>
					First look at Marshall.D.Teach OP16 in the OP16 format. This preview focuses on the leader effect, the
					key spoilers, an early decklist idea, and the early read on the black-yellow Blackbeard shell.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#thoughts">Early Thoughts</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Marshall.D.Teach OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="section-heading-copy">
					<h2>Decklist</h2>
					<p class="decklist-intro">An early decklist idea for Marshall.D.Teach OP16 in the OP16 format.</p>
				</div>
				<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
					Copy for Sim
				</button>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="leader" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Leader</h2>
					<p>Core identity and leader effect for Marshall.D.Teach OP16-080.</p>
				</div>
			</div>
			<div class="leader-card">
				<button
					class="leader-preview"
					type="button"
					data-card-preview
					data-full={leaderCard.img}
					data-name={`${leaderCard.code} ${leaderCard.name}`}
				>
					<img loading="lazy" src={leaderCard.img} alt={`${leaderCard.code} ${leaderCard.name}`} />
				</button>
				<div class="leader-copy">
					<div class="fact-grid">
						<div class="fact-box">
							<span class="fact-label">Color</span>
							<p>Black - Yellow</p>
						</div>
						<div class="fact-box">
							<span class="fact-label">Type</span>
							<p>The Seven Warlords of the Sea / Blackbeard Pirates</p>
						</div>
					</div>
					<div class="text-card">
						<h3>Leader Effect</h3>
						<p class="effect-copy">
							<img class="keyword-badge" src="/assets/keywords/opponents-turn.png" alt="Opponent's Turn" />
							All of your Characters gain +1 cost.
							<img class="keyword-badge" src="/assets/keywords/on-your-opponents-attack.png" alt="On Your Opponent's Attack" />
							<img class="keyword-badge" src="/assets/keywords/once-per-turn.png" alt="Once Per Turn" />
							You may trash 1 card with a
							<img class="keyword-badge" src="/assets/keywords/trigger.png" alt="Trigger" />
							from your hand: change the target of that attack to this Leader or to one of your
							{"{Blackbeard Pirates}"} type Character cards.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="spoiler" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Key preview cards</h2>
					<p>Main cards that push the Teach shell forward.</p>
				</div>
			</div>
			<div class="loop-grid">
				{spoilerCards.map((card) => (
					<div class="loop-card">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						</button>
						<div class="text-card">
							<h3>{card.name}</h3>
							<div class="ability-stack">
								{card.code === "OP16-119" ? (
									<>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/on-play.png" alt="On Play" />
												<span>
													look at 3 cards from the top of your deck and add up to 1 card to the top of
													your Life cards. Then, place the rest at the bottom of your deck in any order.
												</span>
											</span>
										</div>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/trigger.png" alt="Trigger" />
												<span>
													Negate the effect of up to 1 of your opponent's Characters during this turn.
													Then, K.O. up to 1 of your opponent's Characters with a cost of 5 or less.
												</span>
											</span>
										</div>
									</>
								) : (
									<>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/main.png" alt="Main" />
												<span>
													If you have 10 DON!! cards on your field, play up to 1 [Marshall.D.Teach] from
													your hand. Then, your opponent adds 1 card from the top of their Life to their
													hand.
												</span>
											</span>
										</div>
										<div class="ability-line">
											<span class="ability-inline">
												<img class="keyword-badge" src="/assets/keywords/trigger.png" alt="Trigger" />
												<span>Draw 2 cards and trash 1 card from your hand.</span>
											</span>
										</div>
									</>
								)}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="prep" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Prep</h2>
					<p>Old-set support that helps hold the shell together.</p>
				</div>
			</div>
			<div class="prep-card">
				<p class="prep-intro">The list still leans on a sizable older shell for consistency and utility.</p>
				<div class="prep-grid">
					{prepPackage.map((entry) => (
						<button
							class="prep-chip"
							type="button"
							data-card-preview
							data-full={entry.img}
							data-name={entry.code}
						>
							<img loading="lazy" src={entry.img} alt={entry.code} />
							<div class="prep-copy">
								<span class="prep-code">{entry.code}</span>
								<span class="prep-name">{entry.name}</span>
							</div>
						</button>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="thoughts" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Thoughts</h2>
					<p>Strengths, weaknesses, and conclusion.</p>
				</div>
			</div>
			<div class="thoughts-grid">
				<div class="thought-card">
					<div class="thought-head thought-up">
						<span class="thought-icon" aria-hidden="true">+</span>
						<h3>Strengths</h3>
					</div>
					<ul>
						{strengths.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
				<div class="thought-card">
					<div class="thought-head thought-down">
						<span class="thought-icon" aria-hidden="true">-</span>
						<h3>Weaknesses</h3>
					</div>
					<ul>
						{weaknesses.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</div>
			<div class="conclusion-card">
				<div class="conclusion-head">
					<div>
						<h3>Conclusion</h3>
					</div>
					<div class="score-badge">8 / 10</div>
				</div>
				<p>{conclusion}</p>
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<div class="card-modal-frame">
				<img src="" alt="" data-modal-image />
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalFrame = document.querySelector(".card-modal-frame");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	let lockedScrollY = 0;

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		lockedScrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${lockedScrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
		document.body.style.overflow = "hidden";
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		document.body.style.overflow = "";
		window.scrollTo(0, lockedScrollY);
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target === modalImage) {
			closeModal();
			return;
		}
		if (modalFrame && !modalFrame.contains(target) && target !== closeButton) {
			closeModal();
		}
	});
	modalImage?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});

	const copySimButton = document.querySelector("[data-copy-sim]");

	copySimButton?.addEventListener("click", async () => {
		const deckCode = copySimButton.getAttribute("data-sim-deck");
		if (!deckCode) return;

		try {
			await navigator.clipboard.writeText(deckCode);
		} catch {
			const textarea = document.createElement("textarea");
			textarea.value = deckCode;
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		}

		copySimButton.textContent = "Copied!";
		window.setTimeout(() => {
			copySimButton.textContent = "Copy for Sim";
		}, 1800);
	});
</script>

<style>
	.copy-sim-button {
		font-family: inherit;
		font-weight: 700;
	}

	.decklist-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
	}

	.section-heading-copy {
		display: grid;
		gap: 0.35rem;
	}

	.section-heading-copy h2 {
		margin: 0;
	}

	@media (min-width: 901px) {
		.decklist-intro {
			white-space: nowrap;
		}
	}

	.guide-hero .hero-grid {
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
	}

	.guide-icon {
		display: grid;
		place-items: center;
	}

	.guide-icon img {
		width: min(320px, 90%);
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: var(--shadow);
	}

	.leader-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.loop-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
	}

	.leader-card {
		display: grid;
		grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
	}

	.leader-preview,
	.option-card {
		border: none;
		background: transparent;
		padding: 0;
		cursor: pointer;
	}

	.leader-preview img,
	.option-card img {
		width: 100%;
		border-radius: 14px;
		display: block;
	}

	.leader-copy,
	.loop-grid,
	.thoughts-grid {
		display: grid;
		gap: 1rem;
	}

	.fact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.fact-box,
	.text-card,
	.prep-card,
	.thought-card,
	.conclusion-card,
	.deck-card {
		padding: 1rem;
	}

	.fact-box {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border);
		border-radius: 14px;
	}

	.fact-label {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		margin-bottom: 0.45rem;
	}

	.fact-box p,
	.text-card p,
	.prep-intro,
	.section-note {
		margin: 0;
		color: var(--text-200);
	}

	.text-card h3,
	.thought-card h3,
	.conclusion-card h3 {
		margin-top: 0;
		margin-bottom: 0.6rem;
	}

	.text-card ul,
	.thought-card ul {
		margin: 0;
		padding-left: 1.15rem;
	}

	.effect-copy {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.keyword-badge {
		height: 24px;
		width: auto;
		vertical-align: middle;
		flex: 0 0 auto;
		transform: translateY(4px);
		margin: 0 0.12rem;
	}

	.ability-inline {
		display: inline;
	}

	.ability-inline .keyword-badge {
		display: inline-block;
		height: 18px;
		margin-right: 0.35rem;
		vertical-align: middle;
		transform: translateY(-1px);
	}

	.effect-copy .keyword-badge {
		height: 18px;
	}

	.effect-copy > .keyword-badge {
		transform: translateY(-2px);
		margin-right: 0.35rem;
	}

	.ability-stack {
		display: grid;
		gap: 0.55rem;
	}

	.ability-line {
		margin: 0;
		color: var(--text-100);
	}

	.loop-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-bottom: 1rem;
	}

	.loop-card {
		display: grid;
		grid-template-columns: 160px minmax(0, 1fr);
		gap: 1rem;
		padding: 1rem;
		align-items: start;
	}

	.deck-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.2rem;
	}

	.deck-card {
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		display: grid;
		gap: 0.75rem;
		text-align: left;
		cursor: pointer;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.deck-card:hover,
	.deck-card:focus-visible,
	.leader-preview:hover,
	.leader-preview:focus-visible,
	.option-card:hover,
	.option-card:focus-visible {
		transform: translateY(-4px);
		outline: none;
	}

	.deck-card:hover,
	.deck-card:focus-visible {
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
	}

	.deck-card img {
		width: 100%;
		max-width: 150px;
		margin: 0 auto;
		border-radius: 12px;
	}

	.deck-info {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.6rem;
		align-items: center;
	}

	.deck-count {
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 700;
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		font-size: 0.9rem;
	}

	.deck-name {
		font-weight: 600;
	}

	.deck-code,
	.deck-role {
		color: var(--text-300);
		font-size: 0.85rem;
	}

	.deck-role {
		text-transform: uppercase;
		letter-spacing: 1px;
	}

