	{ code: "EB04-058", name: "Borsalino", count: 4, img: "/Cards/EB04/EB04-058.jpg", role: "Character" },
	{ code: "EB03-055", name: "Nico Robin", count: 4, img: "/Cards/EB03/EB03-055.jpg", role: "Character" },
	{ code: "OP14-104", name: "Gecko Moria", count: 4, img: "/Cards/OP14/OP14-104.jpg", role: "Character" },
