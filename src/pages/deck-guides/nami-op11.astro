const optionsNote =
	"These are just some of the valid cards that can be inserted in the deck: Nojiko is useful for bouncing Lucy’s Cavendish or in the mirror, Marco helps to see the pieces on curve, Hiyori is one of best 2K for the deck both to arrange lives and to use the leader ability, and Kid is a piece of end game even if in this format you don’t need it so much anymore.";

const mulliganCards = [
	{ code: "EB03-060", name: "Will You Be My Servant?", img: "/Cards/EB03/EB03-060.jpg" },
	{ code: "P-096", name: "Girl", img: "/Cards/P/P-096.jpg" },
	{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
	{ code: "OP06-104", name: "Kikunojo", img: "/Cards/OP06/OP06-104.png" },
	{ code: "OP14-111", name: "Perona", img: "/Cards/OP14/OP14-111.jpg" },
