		cards: [{ code: "P-096", name: "Girl", img: "/Cards/P/P-096.jpg" }],
	},
	{
		label: "5 DON",
		notes: "5C Nami burns a opponent’s life and assigns a DON to the Leader, remember that oppo must have 3+ lives.",
		cards: [{ code: "EB03-053", name: "Nami", img: "/Cards/EB03/EB03-053.jpg" }],
