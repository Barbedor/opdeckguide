		notes: "Borsalino is one of the strongest cards in the game and it’s like having 2 lives while Newgate is the monster boss of the deck that is needed to have even more cards but be careful to have 7 max.",
		cards: [
			{ code: "EB04-058", name: "Borsalino", img: "/Cards/EB04/EB04-058.jpg" },
			{ code: "OP13-042", name: "Edward.Newgate", img: "/Cards/OP13/OP13-042.jpg" },
		],
	},
];

const tips = [
	{
		title:
			"Don’t be afraid to play Zeus to remove a threat because in addition to taking a life the Leader ability allows you to draw a card.",
		cards: [
			{ code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
			{ code: "OP11-106", name: "Zeus", img: "/Cards/OP11/OP11-106.jpg" },
		],
	},
	{
		title:
			"Zoro is great for setup Perona in the trash in preparation for 8C Moria on for a possible Trigger, how lucky are you?",
		cards: [
			{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
			{ code: "OP14-111", name: "Perona", img: "/Cards/OP14/OP14-111.jpg" },
		],
	},
	{
		title:
			"This is one of the possible and strongest closures of the deck, play Sanji to make Newgate unlockable and finish the game with a 21K attack.",
