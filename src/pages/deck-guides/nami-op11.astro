const matchups = [
	{
		label: "Even",
		icon: "≈",
		leader: { code: "OP13-001", name: "Monkey.D.Luffy", img: "/Cards/OP13/OP13-001.jpg" },
		notes: ["Start 1st", "Manage your board", "Attack correctly"],
	},
	{
		label: "Positive MU",
		icon: "↑",
		leader: { code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg" },
		notes: ["Start 1st", "Control oppo board", "Recover your lives"],
	},
	{
		label: "Even",
		icon: "≈",
		leader: { code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
		notes: ["Start 1st", "Manage your live", "Dependent on the list"],
	},
	{
