---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Yamato OP16 Deck Guide";
const description =
	"Yamato OP16 deck guide for One Piece Card Game with decklist, mulligan priorities, curve guide, tech cards, matchup notes, and OP16 gameplay tips.";

const icon = "/assets/guides/yamato-op16.png";

const expandSimLines = (count, code) => {
	const lines = [];
	let remaining = count;

	while (remaining > 4) {
		lines.push(`4x${code}`);
		remaining -= 4;
	}

	if (remaining > 0) {
		lines.push(`${remaining}x${code}`);
	}

	return lines;
};

const decklist = [
	{ code: "OP16-079", name: "Yamato", count: 1, img: "/Cards/OP16/OP16-079.jpg", role: "Leader" },
	{ code: "OP16-091", name: "Nami", count: 4, img: "/Cards/OP16/OP16-091.jpg", role: "Character" },
	{ code: "OP16-092", name: "Nico Robin", count: 4, img: "/Cards/OP16/OP16-092.jpg", role: "Character" },
	{ code: "OP16-081", name: "Otama", count: 4, img: "/Cards/OP16/OP16-081.jpg", role: "Character" },
	{ code: "OP16-087", name: "Shinobu", count: 4, img: "/Cards/OP16/OP16-087.jpg", role: "Character" },
	{ code: "OP16-088", name: "Shimotsuki Ushimaru", count: 2, img: "/Cards/OP16/OP16-088.jpg", role: "Character" },
	{ code: "OP16-082", name: "Kin'emon", count: 4, img: "/Cards/OP16/OP16-082.jpg", role: "Character" },
	{ code: "OP16-084", name: "Kozuki Momonosuke", count: 4, img: "/Cards/OP16/OP16-084.jpg", role: "Character" },
	{ code: "OP16-098", name: "Yamato", count: 4, img: "/Cards/OP16/OP16-098.jpg", role: "Character" },
	{ code: "OP16-089", name: "Sanji", count: 2, img: "/Cards/OP16/OP16-089.jpg", role: "Character" },
	{ code: "OP16-096", name: "Yamato", count: 4, img: "/Cards/OP16/OP16-096.jpg", role: "Character" },
	{ code: "OP16-097", name: "Yamato", count: 4, img: "/Cards/OP16/OP16-097.jpg", role: "Character" },
	{ code: "OP16-085", name: "Kozuki Momonosuke", count: 4, img: "/Cards/OP16/OP16-085.jpg", role: "Character" },
	{ code: "OP14-096", name: "Ground Death", count: 2, img: "/Cards/OP14/OP14-096.jpg", role: "Event" },
	{ code: "OP16-099", name: "I've Come Here To Cut Those Chains!", count: 4, img: "/Cards/OP16/OP16-099.jpg", role: "Event" },
];

const simDeckCode = decklist.flatMap((card) => expandSimLines(card.count, card.code)).join("\n");

const mulliganKeeps = [
	{
		copy:
			"Nami is the best opening card in the deck. She finds a Land of Wano card from the top four cards while sending the rest to the trash, which smooths out your hand and sets up your future recursion turns right away.",
		cards: [{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" }],
	},
	{
		copy:
			"Kin'emon is the deck's best 4- or 5-DON!! play. He finds a Land of Wano card from the top five cards while loading the trash with the rest, which is exactly what this deck wants to do.",
		cards: [{ code: "OP16-082", name: "Kin'emon", img: "/Cards/OP16/OP16-082.jpg" }],
	},
	{
		copy:
			"Nico Robin upgrades your hand quality. She lets you discard a character you want to play from the trash later while drawing two cards to help you find the missing pieces.",
		cards: [{ code: "OP16-092", name: "Nico Robin", img: "/Cards/OP16/OP16-092.jpg" }],
	},
];

const mulliganSendBackCards = [
	{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
	{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
	{ code: "OP16-085", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-085.jpg" },
	{ code: "OP14-096", name: "Ground Death", img: "/Cards/OP14/OP14-096.jpg" },
];

const curveFirst = [
	{
		label: "1 DON",
		notes: "Nami is your best possible start. The goal is to begin filling the trash immediately.",
		cards: [{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" }],
	},
	{
		label: "3 DON",
		notes: "Keep playing Nami or Robin while attacking with your leader.",
		cards: [
			{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" },
			{ code: "OP16-092", name: "Nico Robin", img: "/Cards/OP16/OP16-092.jpg" },
		],
	},
	{
		label: "5 DON",
		notes:
			"Kin'emon is the ideal play here. He fills the trash, finds the next pieces you need, and still gives you a body that can attack.",
		cards: [{ code: "OP16-082", name: "Kin'emon", img: "/Cards/OP16/OP16-082.jpg" }],
	},
	{
		label: "7 DON",
		notes:
			"Your main lines are Yamato OP16-098 from hand or I've Come Here To Cut Those Chains!. Both lines help you reach the 8-cost Yamatos quickly.",
		cards: [
			{ code: "OP16-098", name: "Yamato", img: "/Cards/OP16/OP16-098.jpg" },
			{ code: "OP16-099", name: "I've Come Here To Cut Those Chains!", img: "/Cards/OP16/OP16-099.jpg" },
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
	{
		label: "9 DON",
		notes:
			"Your two main lines are dropping the 9-cost Momonosuke directly or playing 5-cost Momonosuke plus Shinobu. The second line gives you almost the same result for less DON!!.",
		cards: [
			{ code: "OP16-085", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-085.jpg" },
			{ code: "OP16-084", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-084.jpg" },
			{ code: "OP16-087", name: "Shinobu", img: "/Cards/OP16/OP16-087.jpg" },
		],
	},
	{
		label: "Late game",
		notes:
			"The Yamato loop is your late-game engine. Keep chaining your trash plays into more pressure and force the opponent to keep answering wave after wave.",
		cards: [
			{ code: "OP16-098", name: "Yamato", img: "/Cards/OP16/OP16-098.jpg" },
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
];

const curveSecond = [
	{
		label: "2 DON",
		notes:
			"Nami or Robin are your best plays here. Look for useful midgame and endgame cards while loading the trash for your recursion turns.",
		cards: [
			{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" },
			{ code: "OP16-092", name: "Nico Robin", img: "/Cards/OP16/OP16-092.jpg" },
		],
	},
	{
		label: "4 DON",
		notes:
			"Kin'emon is the ideal line. He fills the trash, finds the next cards you need, and still gives you an attacker.",
		cards: [{ code: "OP16-082", name: "Kin'emon", img: "/Cards/OP16/OP16-082.jpg" }],
	},
	{
		label: "6 DON",
		notes: "Yamato OP16-098 is your main play here so you can bring back an 8-cost Yamato from the trash.",
		cards: [
			{ code: "OP16-098", name: "Yamato", img: "/Cards/OP16/OP16-098.jpg" },
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
	{
		label: "8 DON",
		notes: "I've Come Here To Cut Those Chains! and the Yamato loop are your main lines here.",
		cards: [
			{ code: "OP16-099", name: "I've Come Here To Cut Those Chains!", img: "/Cards/OP16/OP16-099.jpg" },
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
	{
		label: "10 DON",
		notes:
			"The Momonosuke plus Shinobu lines come online here and lead to the deck's most explosive turns.",
		cards: [
			{ code: "OP16-085", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-085.jpg" },
			{ code: "OP16-084", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-084.jpg" },
			{ code: "OP16-087", name: "Shinobu", img: "/Cards/OP16/OP16-087.jpg" },
		],
	},
];

const optionsCards = [
	{
		code: "OP16-095",
		name: "Monkey.D.Luffy",
		img: "/Cards/OP16/OP16-095.jpg",
		copy:
			"An alternative to Sanji. He can give Unblockable to a Land of Wano character. I prefer Sanji, but I still think Luffy is a completely viable option.",
	},
	{
		code: "OP16-094",
		name: "Portgas.D.Ace",
		img: "/Cards/OP16/OP16-094.jpg",
		copy:
			"Some lists play him to strengthen the turn-4 setup. I don't like that option very much and would rather keep those slots for the deck's main game plan.",
	},
	{
		code: "OP05-091",
		name: "Rebecca",
		img: "/Cards/OP05/OP05-091.png",
		copy:
			"An interesting defensive option. She can give you an extra blocker in some aggressive matchups.",
	},
	{
		code: "OP07-085",
		name: "Stussy",
		img: "/Cards/OP07/OP07-085.png",
		copy:
			"A tech choice for decks that play very large threats. She helps answer some characters that are otherwise hard to remove efficiently.",
	},
];

const matchups = [
	{
		label: "Favored",
		tone: "up",
		icon: "↑",
		leader: { code: "OP16-080", name: "Teach OP16", img: "/Cards/OP16/OP16-080.jpg" },
		notes: [
			"Yamato's high number of attacks forces Teach to spend a huge amount of defensive resources.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: { code: "OP15-058", name: "Purple Enel", img: "/Cards/OP15/OP15-058.jpg" },
		notes: [
			"Games often come down to whether you can keep constant pressure going.",
		],
	},
	{
		label: "Slightly Unfavorable",
		tone: "down",
		icon: "↓",
		leader: { code: "OP12-061", name: "Rosinante OP12", img: "/Cards/OP12/OP12-061.jpg" },
		notes: [
			"Choosing between the two 8-cost Yamatos matters a lot depending on which removal tools the opponent has access to.",
		],
	},
	{
		label: "Unfavorable",
		tone: "down",
		icon: "↓",
		leader: { code: "OP11-041", name: "Nami OP11", img: "/Cards/OP11/OP11-041.jpg" },
		notes: [
			"Yamato's extra attacks matter less here than they do against most other leaders in the format.",
		],
	},
	{
		label: "Mirror Match",
		tone: "even",
		icon: "≈",
		leader: { code: "OP16-079", name: "Yamato OP16", img: "/Cards/OP16/OP16-079.jpg" },
		notes: [
			"Going second gives you a slight edge in the mirror.",
		],
	},
];

const tips = [
	{
		copy: "Going second is usually the better seat for this deck.",
		cards: [{ code: "OP16-079", name: "Yamato", img: "/Cards/OP16/OP16-079.jpg" }],
	},
	{
		copy: "Filling the trash correctly is the top priority in the early turns.",
		cards: [
			{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" },
			{ code: "OP16-082", name: "Kin'emon", img: "/Cards/OP16/OP16-082.jpg" },
		],
	},
	{
		copy: "Nami and Kin'emon are your best setup cards in the deck.",
		cards: [
			{ code: "OP16-091", name: "Nami", img: "/Cards/OP16/OP16-091.jpg" },
			{ code: "OP16-082", name: "Kin'emon", img: "/Cards/OP16/OP16-082.jpg" },
		],
	},
	{
		copy: "Always think through the exact order of your combos before you start the turn.",
		cards: [
			{ code: "OP16-084", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-084.jpg" },
			{ code: "OP16-087", name: "Shinobu", img: "/Cards/OP16/OP16-087.jpg" },
			{ code: "OP16-085", name: "Kozuki Momonosuke", img: "/Cards/OP16/OP16-085.jpg" },
		],
	},
	{
		copy:
			"If the opponent can remove your characters easily, prioritize the 8-cost Yamato that can bring back the 6-cost Yamato when it's KO'd.",
		cards: [
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
			{ code: "OP16-098", name: "Yamato", img: "/Cards/OP16/OP16-098.jpg" },
		],
	},
	{
		copy:
			"If the opponent doesn't have much interaction with your board, prioritize the 8-cost Yamato that generates more value.",
		cards: [
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
	{
		copy:
			"Most of your wins come from explosive turns where multiple characters are played from the trash and attack immediately thanks to the leader effect.",
		cards: [
			{ code: "OP16-098", name: "Yamato", img: "/Cards/OP16/OP16-098.jpg" },
			{ code: "OP16-096", name: "Yamato", img: "/Cards/OP16/OP16-096.jpg" },
			{ code: "OP16-097", name: "Yamato", img: "/Cards/OP16/OP16-097.jpg" },
		],
	},
	{
		copy: "The deck is aggressive, but it rewards precise sequencing more than raw pressure.",
		cards: [{ code: "OP16-079", name: "Yamato", img: "/Cards/OP16/OP16-079.jpg" }],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Yamato OP16 Deck Guide</h1>
				<p>
					Yamato OP16 is built around loading the trash quickly, then converting that setup into explosive Land
					of Wano turns. The deck is aggressive, but its real edge comes from how cleanly you sequence your
					recursion and pressure turns.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Yamato OP16 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header decklist-header">
				<div class="decklist-title-row">
					<h2>Decklist</h2>
					<button class="btn btn-primary copy-sim-button" type="button" data-copy-sim data-sim-deck={simDeckCode}>
						Copy for Sim
					</button>
				</div>
				<p>Main list for Yamato OP16 in the OP16 format.</p>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>
						The mulligan plan is simple: find the cards that fill the trash and set up the turns where you'll
						start playing characters back from the trash.
					</p>
				</div>
			</div>
			<div class="tip-card glow-block mulligan-stack">
				<h3>Absolute Priority</h3>
				<div class="mulligan-rows">
					{mulliganKeeps.map((entry) => (
						<div class="mulligan-row">
							<div class="tip-cards">
								{entry.cards.map((card) => (
									<button
										class="mini-card"
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
										<div class="mini-label">{card.name}</div>
									</button>
								))}
							</div>
							<div class="mulligan-copy">
								<p>{entry.copy}</p>
							</div>
						</div>
					))}
				</div>
			</div>
			<div class="tip-card glow-block">
				<h3>Cards to Send Back</h3>
				<div class="sendback-grid">
					{mulliganSendBackCards.map((card) => (
						<div class="sendback-card">
							<button
								class="mini-card"
								type="button"
								data-card-preview
								data-full={card.img}
								data-name={`${card.code} ${card.name}`}
							>
								<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							</button>
							<div class="mini-label sendback-label">{card.name}</div>
						</div>
					))}
				</div>
				<ul class="bullet-list">
					<li>The 8-cost Yamatos.</li>
					<li>The 9-cost Momonosuke.</li>
					<li>Ground Death.</li>
					<li>Too many late-game cards.</li>
					<li>No cards that help fill the trash.</li>
				</ul>
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Turn-by-turn reminders for going first and going second.</p>
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going First</h3>
				<div class="curve-rows">
					{curveFirst.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class={`mini-card curve-card ${card.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
											{card.badgeCard && <img class="card-badge-image" src={card.badgeCard} alt="1 DON!! attached" loading="lazy" />}
										</span>
										<div class="mini-label">{card.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
			<div class="curve-block glow-block">
				<h3>Going Second</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button
										class={`mini-card curve-card ${card.badgeCard ? "has-badge" : ""}`}
										type="button"
										data-card-preview
										data-full={card.img}
										data-name={`${card.code} ${card.name}`}
									>
										<span class="card-wrap">
											<img class="card-main-image" loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
											{card.badgeCard && <img class="card-badge-image" src={card.badgeCard} alt="1 DON!! attached" loading="lazy" />}
										</span>
										<div class="mini-label">{card.name}</div>
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Alternative cards and flex slots for different OP16 rooms.</p>
				</div>
			</div>
			<div class="options-rich-grid">
				{optionsCards.map((card) => (
					<div class="option-note-card glow-block">
						<button
							class="option-card"
							type="button"
							data-card-preview
							data-full={card.img}
							data-name={`${card.code} ${card.name}`}
						>
							<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
							<div class="option-info">
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</button>
						<p>{card.copy}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>How the main OP16 leaders line up against Yamato.</p>
				</div>
			</div>
			<div class="matchups-stack">
				{matchups.map((matchup) => (
					<div class="matchup-card glow-block">
						<div class={`matchup-badge ${matchup.tone === "down" ? "badge-down" : matchup.tone === "even" ? "badge-even" : "badge-up"}`}>
							<span class="badge-icon">{matchup.icon}</span>
							<span>{matchup.label}</span>
						</div>
						<div class="matchup-row">
							<div class="tip-cards">
								<button
									class="mini-card"
									type="button"
