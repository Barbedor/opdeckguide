---
import MainLayout from "../layouts/MainLayout.astro";

const title = "Page Not Found";
const description =
	"The page you requested doesn't exist on OPDeckGuide. Use the links below to continue browsing the main site sections.";
---

<MainLayout title={title} description={description} noindex={true}>
	<section class="hero">
		<div class="container not-found">
			<span class="hero-badge">404</span>
			<h1>Page not found</h1>
			<p>
				This URL doesn't match a published OPDeckGuide page. Use one of the main sections below to keep
				browsing the site.
			</p>
			<h2>Browse OPDeckGuide sections</h2>
			<div class="hero-actions">
				<a class="btn btn-primary" href="/deck-guides/">Deck Guides</a>
				<a class="btn btn-secondary" href="/beginner-guides/">Beginner Guides</a>
				<a class="btn btn-secondary" href="/meta-analysis/">Meta Analysis</a>
				<a class="btn btn-secondary" href="/tournaments-decklists/">Tournament Decklists</a>
				<a class="btn btn-secondary" href="/banlist/">Banlist</a>
				<a class="btn btn-secondary" href="/cards-list/">Cards List</a>
			</div>
		</div>
	</section>
</MainLayout>

<style>
	.not-found {
		max-width: 720px;
		text-align: center;
	}

	.not-found p {
		margin: 0 auto;
		max-width: 56ch;
	}

	.not-found h2 {
		margin: 1.5rem 0 0.8rem;
		font-size: 1.1rem;
	}

	.not-found .hero-actions {
		justify-content: center;
	}
</style>
