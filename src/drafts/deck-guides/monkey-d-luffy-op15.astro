---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Monkey.D.Luffy OP15 Deck Guide";
const description =
	"Monkey.D.Luffy OP15 deck guide for One Piece Card Game with decklist, replacement options, mulligan priorities, curve plans, tips, and matchup notes for the OP15 format.";

const icon = "/assets/guides/monkey-d-luffy-op15.png";

const decklist = [
	{ code: "OP15-098", name: "Monkey.D.Luffy", count: 1, img: "/Cards/OP15/OP15-098.jpg", role: "Leader" },
	{ code: "OP15-108", name: "Nami", count: 4, img: "/Cards/OP15/OP15-108.jpg", role: "Character" },
	{ code: "OP05-106", name: "Shura", count: 4, img: "/Cards/OP05/OP05-106.png", role: "Character" },
	{ code: "OP11-106", name: "Zeus", count: 4, img: "/Cards/OP11/OP11-106.jpg", role: "Character" },
	{ code: "EB03-056", name: "Belo Betty", count: 3, img: "/Cards/EB03/EB03-056.jpg", role: "Character" },
	{ code: "OP15-113", name: "Roronoa Zoro", count: 4, img: "/Cards/OP15/OP15-113.jpg", role: "Character" },
	{ code: "ST29-009", name: "Nico Robin", count: 4, img: "/Cards/ST29/ST29-009.jpg", role: "Character" },
	{ code: "EB04-058", name: "Borsalino", count: 4, img: "/Cards/EB04/EB04-058.jpg", role: "Character" },
	{ code: "OP05-102", name: "Gedatsu", count: 2, img: "/Cards/OP05/OP05-102.png", role: "Character" },
	{ code: "OP12-099", name: "Kalgara", count: 3, img: "/Cards/OP12/OP12-099.jpg", role: "Character" },
	{ code: "OP15-114", name: "Wyper", count: 4, img: "/Cards/OP15/OP15-114.jpg", role: "Character" },
	{ code: "OP15-119", name: "Monkey.D.Luffy", count: 4, img: "/Cards/OP15/OP15-119.jpg", role: "Character" },
	{ code: "OP15-109", name: "Nico Robin", count: 4, img: "/Cards/OP15/OP15-109.jpg", role: "Character" },
	{ code: "EB02-052", name: "Enel", count: 2, img: "/Cards/EB02/EB02-052.jpg", role: "Character" },
	{ code: "OP15-116", name: "Gum-Gum Golden Rifle", count: 4, img: "/Cards/OP15/OP15-116.jpg", role: "Event" },
];

const optionsGroups = [
	{
		cards: [{ code: "EB04-054", name: "Bartholomew Kuma", img: "/Cards/EB04/EB04-054.jpg" }],
		note:
			"If you don't have Borsalino (EB04-058), Bartholomew Kuma is the cleanest replacement because he keeps the low-Life heal effect. You lose the Blocker utility, but Kuma gives you a bigger body and turns a K.O. into extra pressure.",
	},
	{
		cards: [{ code: "OP05-105", name: "Satori", img: "/Cards/OP05/OP05-105.png" }],
		note:
			"If you're missing the Zeus (OP11-106) and Belo Betty (EB03-056) package, Satori is the safer fallback if you want to keep the Sky Island core intact. He doesn't replace their removal, but the 2k counter and Trigger body give you a more defensive, consistent option.",
	},
];

const mulliganCards = [
	{ code: "OP15-108", name: "Nami", img: "/Cards/OP15/OP15-108.jpg" },
	{ code: "OP05-106", name: "Shura", img: "/Cards/OP05/OP05-106.png" },
	{ code: "OP12-099", name: "Kalgara", img: "/Cards/OP12/OP12-099.jpg" },
];

const mulliganNotes = [
	{
		title: "Nami (OP15-108)",
		text: "Your best clean opener. It starts the board right away and looks at the top 3 cards to find another Sky Island piece, which helps smooth the rest of your curve. It's the kind of keep that makes your early turns much more consistent.",
	},
	{
		title: "Shura (OP05-106)",
		text: "One of your strongest keeps because it digs 5 cards deep for a Sky Island card. It gives you better access to your core pieces and makes your early development much more reliable than keeping a random midgame hand.",
	},
	{
		title: "Kalgara (OP12-099)",
		text: "A strong keep only if the rest of your opener already works. Kalgara isn't your setup piece, but once your early turns are covered, he's one of the best cards for keeping hand size up while still applying pressure.",
	},
];

const curveFirst = [
	{
		label: "1 DON!!",
		cards: [{ code: "OP15-108", name: "Nami", img: "/Cards/OP15/OP15-108.jpg" }],
		notes:
			"Start with Nami (OP15-108). It is your cleanest turn-1 setup piece and gives you the first body you can begin protecting with the leader.",
	},
	{
		label: "3 DON!!",
		cards: [
			{ code: "OP15-108", name: "Nami", img: "/Cards/OP15/OP15-108.jpg" },
			{ code: "OP05-106", name: "Shura", img: "/Cards/OP05/OP05-106.png" },
		],
		notes:
			"Keep building with Nami (OP15-108) and Shura (OP05-106). This turn is mostly about developing the board while making sure your next turns stay consistent.",
	},
	{
		label: "5 DON!!",
		cards: [
			{ code: "OP05-102", name: "Gedatsu", img: "/Cards/OP05/OP05-102.png" },
			{ code: "OP12-099", name: "Kalgara", img: "/Cards/OP12/OP12-099.jpg" },
			{ code: "OP15-114", name: "Wyper", img: "/Cards/OP15/OP15-114.jpg" },
		],
		notes:
			"This is your first flexible turn. Gedatsu (OP05-102) gives you removal, Kalgara (OP12-099) helps you keep resources flowing, and Wyper (OP15-114) lets you pressure while still pushing your main game plan.",
	},
	{
		label: "7 DON!!",
		cards: [
			{ code: "OP15-109", name: "Nico Robin", img: "/Cards/OP15/OP15-109.jpg" },
			{ code: "OP15-119", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-119.jpg" },
		],
		notes:
			"Prioritize Nico Robin (OP15-109) + Monkey.D.Luffy (OP15-119) whenever the line is available, because Robin is what lets you play Luffy through her effect. Once this core setup sticks, the deck becomes much harder to cleanly answer and your protected board starts taking over the game.",
	},
	{
		label: "9 DON!!",
		cards: [
			{ code: "OP15-119", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-119.jpg" },
			{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
		],
		notes:
			"Keep stacking Monkey.D.Luffy (OP15-119) and back it up with Roronoa Zoro (OP15-113). Once you reach this part of the game, the deck starts to feel almost immortal if your bodies stay on board.",
	},
];

const curveSecond = [
	{
		label: "2 DON!!",
		cards: [
			{ code: "OP15-108", name: "Nami", img: "/Cards/OP15/OP15-108.jpg" },
			{ code: "OP05-106", name: "Shura", img: "/Cards/OP05/OP05-106.png" },
		],
		notes:
			"Nami (OP15-108) + Shura (OP05-106) is the ideal second-player opening. You develop immediately and keep your search/setup lines clean.",
	},
	{
		label: "4 DON!!",
		cards: [
			{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
			{ code: "EB03-056", name: "Belo Betty", img: "/Cards/EB03/EB03-056.jpg" },
		],
		notes:
			"Roronoa Zoro (OP15-113) helps protect your board while Belo Betty (EB03-056) helps you keep your turn productive before the bigger power turns start.",
	},
	{
		label: "6 DON!!",
		cards: [
			{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
			{ code: "OP11-106", name: "Zeus", img: "/Cards/OP11/OP11-106.jpg" },
			{ code: "OP15-114", name: "Wyper", img: "/Cards/OP15/OP15-114.jpg" },
			{ code: "OP12-099", name: "Kalgara", img: "/Cards/OP12/OP12-099.jpg" },
			{ code: "OP05-102", name: "Gedatsu", img: "/Cards/OP05/OP05-102.png" },
		],
		notes:
			"This is your most flexible mid-game turn. Zoro protects your board, Zeus and Gedatsu help clear problem bodies, Wyper keeps pressure on, and Kalgara lets you stay comfortable on resources. Choose the line that either stabilizes the board or sets up your 8-DON!! turn.",
	},
	{
		label: "8 DON!!",
		cards: [
			{ code: "OP15-109", name: "Nico Robin", img: "/Cards/OP15/OP15-109.jpg" },
			{ code: "OP15-119", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-119.jpg" },
		],
		notes:
			"Nico Robin (OP15-109) + Monkey.D.Luffy (OP15-119) is still your priority power line, because Robin is what lets you play Luffy through her effect. If this turn lands cleanly, your opponent usually has to start overworking every removal sequence.",
	},
	{
		label: "10 DON!!",
		cards: [{ code: "EB02-052", name: "Enel", img: "/Cards/EB02/EB02-052.jpg" }],
		notes:
			"At 10 DON!!, Enel (EB02-052) gives you the huge heal turn that pushes this deck over the top. Combined with the leader, Zoro, Borsalino, and your 1-cost event, these are the turns where the deck starts feeling almost impossible to kill.",
	},
];

const tips = [
	{
		title: "Go first whenever you can.",
		text:
			"Going first is the cleaner version of this deck. It lines up your strongest curve, makes your healing turns easier to sequence, and gives you more time to establish the Robin + Luffy core before the game gets chaotic.",
		cards: [
			{ code: "OP15-109", name: "Nico Robin", img: "/Cards/OP15/OP15-109.jpg" },
			{ code: "OP15-119", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-119.jpg" },
		],
	},
	{
		title: "This deck turns life into board protection.",
		text:
			"The leader is what makes the deck so hard to deal with. Whenever one of your 6000-power-or-more Sky Island characters would leave the field, you can take 1 life to hand instead. That makes your board much harder to clear and lets you create turns where your opponent feels like they never truly removed anything important.",
		cards: [
			{ code: "OP15-098", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-098.jpg" },
			{ code: "EB02-052", name: "Enel", img: "/Cards/EB02/EB02-052.jpg" },
		],
	},
	{
		title: "Prioritize the Robin + Luffy core.",
		text:
			"Always prioritize the Nico Robin (OP15-109) + Monkey.D.Luffy (OP15-119) setup when the game allows it. Robin is what lets you play Luffy through her effect, and once that core is online, your board becomes incredibly difficult to clean up and your healing turns get much more threatening.",
		cards: [
			{ code: "OP15-109", name: "Nico Robin", img: "/Cards/OP15/OP15-109.jpg" },
			{ code: "OP15-119", name: "Monkey.D.Luffy", img: "/Cards/OP15/OP15-119.jpg" },
		],
	},
	{
		title: "Your healing turns matter more than your flashy swings.",
		text:
			"This deck can pressure hard, but a lot of your best DON!! turns are spent keeping your life total and board stable instead of simply attacking bigger. Your life will disappear quickly between the leader effect and direct pressure, so you need to recognize when the correct line is to heal and stay safe instead of overcommitting to damage.",
		cards: [
			{ code: "EB04-058", name: "Borsalino", img: "/Cards/EB04/EB04-058.jpg" },
			{ code: "OP15-116", name: "Gum-Gum Golden Rifle", img: "/Cards/OP15/OP15-116.jpg" },
		],
	},
	{
		title: "Know exactly what the deck is good at and bad at.",
		text:
			"The strengths are clear: character spam, protected bodies that feel immortal, and turns where you can heal 2 or more life in one sequence. The weaknesses are just as real: leaders that stack power can be awkward, your DON!! can get pulled more toward healing than attacking, and some games become very predictable because your opponent knows when your big safe turns are coming. Electrical Luna is also a real problem and should always be respected.",
		cards: [
			{ code: "OP11-106", name: "Zeus", img: "/Cards/OP11/OP11-106.jpg" },
			{ code: "OP15-113", name: "Roronoa Zoro", img: "/Cards/OP15/OP15-113.jpg" },
		],
	},
];

const matchups = [
	{
		label: "Positive MU",
		status: "up",
		leader: { code: "OP15-002", name: "Lucy", img: "/Cards/OP15/OP15-002.jpg" },
		notes: [
			"Go first.",
			"Clear the board early so Lucy cannot comfortably stack pressure.",
			"Prioritize Kalgara (OP12-099) and try to get 1 to 2 copies of Monkey.D.Luffy (OP15-119) online before 10 DON!!.",
			"Heal while you keep applying pressure with your Campaign bodies.",
		],
	},
	{
		label: "Slight Adv.",
		status: "up",
		leader: { code: "OP14-079", name: "Crocodile", img: "/Cards/OP14/OP14-079.jpg" },
		notes: [
			"Go first.",
			"Spam the board and prioritize Kalgara (OP12-099) so your hand size stays healthy.",
			"Clear their board when you can so Crocodile's top-end turns do not come with too many extra attacks.",
		],
	},
	{
		label: "Positive MU",
		status: "up",
		leader: { code: "OP15-058", name: "Enel", img: "/Cards/OP15/OP15-058.jpg" },
		notes: [
			"Go first.",
			"Clear Holy and the small setup bodies first so Enel cannot build a free board.",
			"Wyper (OP15-114) helps a lot in keeping the board manageable while you work toward your protected power turns.",
			"If you can set up 2 copies of Monkey.D.Luffy (OP15-119) before you fully commit to lethal, the matchup becomes much harder for Enel to defend cleanly.",
		],
	},
	{
		label: "Slight Disadv.",
		status: "down",
		leader: { code: "OP13-002", name: "Portgas.D.Ace", img: "/Cards/OP13/OP13-002.jpg" },
		notes: [
			"Go second.",
			"Prioritize Kalgara (OP12-099), then work toward Monkey.D.Luffy (OP15-119) so your 10 DON!! Enel turn stays threatening.",
			"The game gets much harder if Ace starts chaining multiple Zoros or combines event pressure with bigger top-end turns.",
		],
	},
	{
		label: "Negative MU",
		status: "down",
		leader: { code: "OP11-041", name: "Nami", img: "/Cards/OP11/OP11-041.jpg" },
		notes: [
			"Go first.",
			"Kalgara (OP12-099) and Wyper (OP15-114) are priority cards because they help you keep hand size while still making meaningful 7k swings.",
			"The Robin + Luffy setup is mandatory here because you need repeated pressure and safe defensive turns.",
			"Defend life aggressively and always respect Electrical Luna.",
		],
	},
	{
		label: "Slight Disadv.",
		status: "down",
		leader: { code: "EB02-010", name: "Monkey.D.Luffy", img: "/Cards/EB02/EB02-010.jpg" },
		notes: [
			"Go second.",
			"Try to break up their curve with Zeus (OP11-106) and Gedatsu (OP05-102) so they do not get too many safe development turns.",
			"If they flood the board too early, your 10 DON!! Enel turn becomes much less secure, so stabilize first and race second.",
		],
	},
];
---

<MainLayout title={title} description={description}>
	<section class="hero guide-hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Deck Guide</span>
				<h1>Monkey.D.Luffy OP15 Deck Guide</h1>
				<p>
					Reference guide for Yellow Monkey.D.Luffy OP15-098 in the OP15 format with the full list, replacement
					options, mulligan priorities, curve plans, and matchup notes. If you want the turn-order numbers and
					stat breakdown, the <a href="/meta-analysis/monkey-d-luffy-op15-stats-in-op15/">Monkey.D.Luffy OP15
					stats article</a> is available separately.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="#decklist">Jump to Decklist</a>
					<a class="btn btn-secondary" href="#matchups">Matchups</a>
				</div>
			</div>
			<div class="guide-icon">
				<img src={icon} alt="Monkey.D.Luffy OP15 guide icon" loading="lazy" />
			</div>
		</div>
	</section>

	<section id="decklist" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Decklist</h2>
					<p>Main list for Monkey.D.Luffy OP15 in the OP15 format.</p>
				</div>
			</div>
			<div class="deck-grid">
				{decklist.map((card) => (
					<button class="deck-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
						<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
						<div class="deck-info">
							<span class="deck-count">{card.count}x</span>
							<div>
								<div class="deck-name">{card.name}</div>
								<div class="deck-code">{card.code}</div>
							</div>
						</div>
						<span class="deck-role">{card.role}</span>
					</button>
				))}
			</div>
		</div>
	</section>

	<section id="options" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Options & Tech Cards</h2>
					<p>Replacement options if you are missing parts of the main shell.</p>
				</div>
			</div>
			<div class="options-stack">
				{optionsGroups.map((group) => (
					<div class="option-group">
						<div class="options-grid">
							{group.cards.map((card) => (
								<button
									class="option-card"
									type="button"
									data-card-preview
									data-full={card.img}
									data-name={`${card.code} ${card.name}`}
								>
									<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
								</button>
							))}
						</div>
						<p class="section-note">{group.note}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="mulligan" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Mulligan</h2>
					<p>Recommended opening hand.</p>
				</div>
			</div>
			<div class="mulligan-grid">
				{mulliganNotes.map((note, index) => (
					<div class="mulligan-item">
						<button class="mini-card" type="button" data-card-preview data-full={mulliganCards[index].img} data-name={`${mulliganCards[index].code} ${mulliganCards[index].name}`}>
							<img loading="lazy" src={mulliganCards[index].img} alt={`${mulliganCards[index].code} ${mulliganCards[index].name}`} />
							<div class="mini-label">{mulliganCards[index].name}</div>
						</button>
						<div class="text-card">
							<h3>{note.title}</h3>
							<p>{note.text}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="curve" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Curve Guide</h2>
					<p>Your turn-by-turn curve for going first or second.</p>
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve 1st</h3>
				<div class="curve-rows">
					{curveFirst.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button class="mini-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
			<div class="curve-block">
				<h3>Curve 2nd</h3>
				<div class="curve-rows">
					{curveSecond.map((slot) => (
						<div class="curve-row">
							<div class="curve-label">{slot.label}</div>
							<div class="curve-cards">
								{slot.cards.map((card) => (
									<button class="mini-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
										<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
									</button>
								))}
							</div>
							<div class="curve-note">{slot.notes}</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="tips" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Tips</h2>
					<p>Important reminders for your sequencing, healing turns, and matchup approach.</p>
				</div>
			</div>
			<div class="tips-grid">
				{tips.map((tip) => (
					<div class="tip-card">
						<div class="tip-cards">
							{tip.cards.map((card) => (
								<button class="mini-card" type="button" data-card-preview data-full={card.img} data-name={`${card.code} ${card.name}`}>
									<img loading="lazy" src={card.img} alt={`${card.code} ${card.name}`} />
								</button>
							))}
						</div>
						<h3>{tip.title}</h3>
						<p>{tip.text}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="matchups" class="list-section">
		<div class="container">
			<div class="section-header">
				<div>
					<h2>Matchups</h2>
					<p>Main matchup notes for the OP15 field.</p>
				</div>
			</div>
			<div class="matchups-grid">
				{matchups.map((matchup) => (
					<div class="matchup-card">
						<div class={`matchup-badge ${matchup.status === "down" ? "badge-down" : matchup.status === "up" ? "badge-up" : "badge-even"}`}>
							<span class={`badge-icon ${matchup.status === "down" ? "badge-icon-down" : matchup.status === "up" ? "badge-icon-up" : "badge-icon-even"}`} aria-hidden="true"></span>
							<span>{matchup.label}</span>
						</div>
						<button class="mini-card" type="button" data-card-preview data-full={matchup.leader.img} data-name={`${matchup.leader.code} ${matchup.leader.name}`}>
							<img loading="lazy" src={matchup.leader.img} alt={`${matchup.leader.code} ${matchup.leader.name}`} />
						</button>
						<div class="matchup-name">{matchup.leader.name}</div>
						<ul>
							{matchup.notes.map((note) => (
								<li>{note}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<div class="card-modal" data-modal aria-hidden="true">
		<div class="card-modal-inner" role="dialog" aria-modal="true" aria-label="Card preview">
			<button class="modal-close" type="button" data-close>Close</button>
			<div class="card-modal-frame">
				<img src="" alt="" data-modal-image />
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const previewButtons = document.querySelectorAll("[data-card-preview]");
	const modal = document.querySelector("[data-modal]");
	const modalFrame = document.querySelector(".card-modal-frame");
	const modalImage = document.querySelector("[data-modal-image]");
	const closeButton = document.querySelector("[data-close]");
	let lockedScrollY = 0;

	const openModal = (button) => {
		if (!modal || !modalImage) return;
		const full = button.getAttribute("data-full");
		const name = button.getAttribute("data-name") || "Card preview";
		modalImage.setAttribute("src", full);
		modalImage.setAttribute("alt", name);
		lockedScrollY = window.scrollY;
		document.body.style.position = "fixed";
		document.body.style.top = `-${lockedScrollY}px`;
		document.body.style.left = "0";
		document.body.style.right = "0";
		document.body.style.width = "100%";
		document.body.style.overflow = "hidden";
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	};

	const closeModal = () => {
		if (!modal) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		document.body.style.position = "";
		document.body.style.top = "";
		document.body.style.left = "";
		document.body.style.right = "";
		document.body.style.width = "";
		document.body.style.overflow = "";
		window.scrollTo(0, lockedScrollY);
	};

	previewButtons.forEach((button) => {
		button.addEventListener("click", () => openModal(button));
	});

	closeButton?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target === modalImage) {
			closeModal();
			return;
		}
		if (modalFrame && !modalFrame.contains(target) && target !== closeButton) {
			closeModal();
		}
	});
	modalImage?.addEventListener("click", closeModal);
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeModal();
	});
</script>

