---
const { title, description } = Astro.props;
const metaTitle = title ? `${title} | OPDeckGuide` : 'OPDeckGuide | One Piece Card Game Deck Guides & Meta Analysis';
const metaDescription = description ?? 'Modern One Piece Card Game deck guides, matchup breakdowns, and meta analysis built for competitive players and new pirates alike.';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{metaTitle}</title>
		<meta name="description" content={metaDescription} />
		<meta name="theme-color" content="#0b0f1a" />
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<header class="site-header">
			<div class="container header-inner">
				<div class="header-top">
					<a class="logo" href="/">OPDeckGuide</a>
					<nav class="nav">
						<a href="/deck-guides">Deck Guides</a>
						<a href="/meta-analysis">Meta Analysis</a>
						<a href="/beginner-guides">Beginner Guides</a>
						<a href="/banlist">Banlist</a>
						<a href="/cards-list">Cards List</a>
					</nav>
				</div>
				<div class="header-search-row">
					<form class="nav-search" action="/cards-list" method="get" role="search">
						<input
							type="search"
							name="query"
							placeholder="Search card number or name"
							aria-label="Search card number or name"
							data-global-search
						/>
						<button type="submit">Search</button>
					</form>
				</div>
			</div>
		</header>

		<main id="content">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>© 2026 OPDeckGuide. All rights reserved.</p>
				<div class="footer-links">
					<a href="/deck-guides">Deck Guides</a>
					<a href="/meta-analysis">Meta Analysis</a>
					<a href="/beginner-guides">Beginner Guides</a>
					<a href="/banlist">Banlist</a>
					<a href="/cards-list">Cards List</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg-950: #070a12;
		--bg-900: #0b0f1a;
		--bg-800: #111827;
		--bg-700: #1a2336;
		--text-100: #eef2ff;
		--text-200: #cbd5f5;
		--text-300: #9aa4c7;
		--accent: #ff6b3d;
		--accent-2: #ff9f1a;
		--border: #1f2a3c;
		--shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
		--radius-lg: 20px;
		--radius-md: 14px;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		font-family: "Space Grotesk", "Segoe UI", system-ui, sans-serif;
		background: radial-gradient(1200px 600px at 80% -10%, rgba(255, 107, 61, 0.18), transparent 60%),
			radial-gradient(800px 500px at 10% 10%, rgba(255, 159, 26, 0.14), transparent 55%),
			var(--bg-900);
		color: var(--text-100);
		line-height: 1.6;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		display: block;
	}

	.container {
		width: min(1120px, 100% - 2rem);
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		left: -999px;
		top: 1rem;
		background: var(--accent);
		color: #000;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-weight: 600;
	}

	.skip-link:focus {
		left: 1rem;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(12px);
		background: rgba(11, 15, 26, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.header-inner {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		padding: 1rem 0;
	}

	.header-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
		width: 100%;
	}

	.header-search-row {
		display: flex;
		justify-content: center;
		width: 100%;
	}

	.logo {
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: 0.5px;
		color: var(--accent-2);
	}

	.nav {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: flex-end;
		font-size: 0.95rem;
		color: var(--text-200);
	}

	.nav a {
		padding: 0.4rem 0.6rem;
		border-radius: 999px;
		transition: all 0.2s ease;
	}

	.nav a:hover,
	.nav a:focus-visible {
		background: rgba(255, 107, 61, 0.15);
		color: var(--text-100);
		outline: none;
	}

	.nav-search {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(12, 17, 30, 0.9);
		border: 1px solid rgba(255, 107, 61, 0.35);
		border-radius: 999px;
		padding: 0.45rem 0.5rem 0.45rem 1rem;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
		max-width: 520px;
		width: 100%;
	}

	.nav-search input {
		background: transparent;
		border: none;
		color: var(--text-100);
		font-size: 0.9rem;
		min-width: 0;
		flex: 1;
	}

	.nav-search input:focus {
		outline: none;
	}

	.nav-search button {
		border: none;
		border-radius: 999px;
		padding: 0.4rem 0.9rem;
		background: linear-gradient(120deg, rgba(255, 107, 61, 0.95), rgba(255, 159, 26, 0.95));
		color: var(--text-100);
		font-weight: 600;
		cursor: pointer;
	}

	.site-footer {
		border-top: 1px solid var(--border);
		margin-top: 4rem;
		padding: 2rem 0 3rem;
		background: rgba(7, 10, 18, 0.8);
	}

	.footer-inner {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: space-between;
		align-items: center;
		color: var(--text-300);
		font-size: 0.95rem;
	}

	.footer-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.footer-links a {
		color: var(--text-200);
	}

	.hero {
		padding: 5rem 0 3rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
		align-items: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.9rem;
		border-radius: 999px;
		background: rgba(255, 107, 61, 0.15);
		color: var(--accent);
		font-weight: 600;
		font-size: 0.85rem;
	}

	.hero h1 {
		font-size: clamp(2.4rem, 4vw, 3.6rem);
		margin: 1rem 0;
		line-height: 1.1;
	}

	.hero p {
		color: var(--text-200);
		font-size: 1.05rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.4rem;
		border-radius: 999px;
		font-weight: 600;
		border: 1px solid transparent;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: linear-gradient(120deg, var(--accent), var(--accent-2));
		color: #0b0f1a;
		box-shadow: var(--shadow);
	}

	.btn-secondary {
		border-color: var(--border);
		color: var(--text-100);
		background: rgba(255, 255, 255, 0.02);
	}

	.btn:hover,
	.btn:focus-visible {
		transform: translateY(-2px);
		outline: none;
	}

	.section {
		padding: 1.75rem 0;
	}

	.section-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.section-header h2 {
		margin: 0;
		font-size: 2rem;
	}

	.section-header p {
		margin: 0.5rem 0 0;
		color: var(--text-200);
		max-width: 46ch;
	}

	.section-header a {
		white-space: nowrap;
		color: var(--accent);
		font-weight: 600;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		gap: 1.2rem;
	}

	.card-grid.grid-3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.card {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		padding: 1.4rem;
		border-radius: var(--radius-md);
		background: linear-gradient(160deg, rgba(17, 24, 39, 0.9), rgba(12, 17, 30, 0.9));
		border: 1px solid var(--border);
		min-height: 180px;
		transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		border-color: rgba(255, 107, 61, 0.4);
		box-shadow: var(--shadow);
		outline: none;
	}

	.card-eyebrow {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--accent);
		font-weight: 600;
	}

	.card-icon {
		width: 100%;
		display: flex;
		justify-content: center;
	}

	.card-icon img {
		width: min(100px, 60%);
		border-radius: 12px;
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
	}

	.card h3 {
		margin: 0;
		font-size: 1.15rem;
	}

	.card p {
		margin: 0;
		color: var(--text-200);
		font-size: 0.95rem;
	}

	.list-section {
		padding: 1rem 0 1.6rem;
	}

	.list-section h2 {
		margin-bottom: 0.8rem;
	}

	.meta-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.meta-item {
		background: rgba(17, 24, 39, 0.7);
		border-radius: var(--radius-md);
		padding: 1rem 1.2rem;
		border: 1px solid var(--border);
	}

	.meta-item h3 {
		margin-top: 0;
		font-size: 1rem;
	}

	.meta-item p {
		margin: 0.5rem 0 0;
		color: var(--text-300);
		font-size: 0.9rem;
	}

	.seo-block {
		padding: 1.4rem 0 2.4rem;
		border-top: 1px solid rgba(31, 42, 60, 0.6);
		margin-top: 2.5rem;
	}

	.seo-block h2 {
		margin: 0 0 1rem;
	}

	.seo-block p {
		color: var(--text-200);
		max-width: 72ch;
	}

	.curve-row + .curve-row {
		border-top: 1px solid rgba(255, 107, 61, 0.45) !important;
		padding-top: 1rem !important;
	}

	@media (max-width: 800px) {
		.header-top {
			width: 100%;
		}

		.section-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.nav-search {
			max-width: none;
		}

		.header-search-row {
			justify-content: stretch;
		}
		.card-grid.grid-3 {
			grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		}
	}

	@media (max-width: 600px) {
		.container {
			width: min(100% - 1.2rem, 1120px);
		}

		.header-inner {
			gap: 0.45rem;
			padding: 0.7rem 0;
		}

		.header-top {
			gap: 0.55rem;
			justify-content: center;
		}

		.logo {
			width: 100%;
			text-align: center;
			font-size: 1.05rem;
			line-height: 1.1;
		}

		.hero {
			padding-top: 3.5rem;
		}

		.nav {
			width: 100%;
			display: grid;
			grid-template-columns: repeat(5, minmax(0, 1fr));
			gap: 0.2rem;
			font-size: 0.72rem;
			line-height: 1.15;
			justify-content: stretch;
			text-align: center;
		}

		.nav a {
			padding: 0.35rem 0.15rem;
			border-radius: 10px;
			white-space: normal;
		}

		.nav-search {
			gap: 0.35rem;
			padding: 0.35rem 0.4rem 0.35rem 0.75rem;
		}

		.nav-search input {
			font-size: 0.82rem;
		}

		.nav-search button {
			padding: 0.35rem 0.7rem;
			font-size: 0.78rem;
		}

		.hero-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.btn {
			width: 100%;
		}
	}

	@media (max-width: 640px) {
		.deck-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
			gap: 0.18rem !important;
		}

		.deck-card {
			padding: 0.22rem !important;
			gap: 0.28rem !important;
			border-radius: 10px !important;
			text-align: center !important;
		}

		.deck-card img {
			width: 100% !important;
			max-width: 108px !important;
			border-radius: 8px !important;
		}

		.deck-info {
			grid-template-columns: 1fr !important;
			justify-items: center !important;
			gap: 0.22rem !important;
		}

		.deck-count {
			padding: 0.18rem 0.45rem !important;
			font-size: 0.68rem !important;
			line-height: 1 !important;
		}

		.deck-name {
			font-size: 0.68rem !important;
			line-height: 1.15 !important;
			display: -webkit-box !important;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden !important;
		}

		.deck-code {
			font-size: 0.66rem !important;
			line-height: 1.1 !important;
		}

		.deck-role {
			display: none !important;
		}

		.options-grid,
		.options-paired-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
			gap: 0.65rem !important;
			align-items: start !important;
		}

		.options-stack {
			gap: 1rem !important;
		}

		.option-group {
			padding: 0.65rem !important;
		}

		.option-card {
			width: 100% !important;
			padding: 0.45rem !important;
			gap: 0.4rem !important;
			border-radius: 12px !important;
		}

		.option-card img {
			width: 100% !important;
			max-width: 136px !important;
			border-radius: 8px !important;
		}

		.option-info .deck-name,
		.option-card .deck-name {
			font-size: 0.78rem !important;
			line-height: 1.15 !important;
		}

		.option-info .deck-code,
		.option-card .deck-code {
			font-size: 0.72rem !important;
			line-height: 1.1 !important;
		}

		.section-note,
		.option-note,
		.option-note-inline {
			font-size: 0.86rem !important;
			line-height: 1.45 !important;
			text-align: center !important;
			max-width: 100% !important;
		}

		.curve-row {
			grid-template-columns: 4.6rem minmax(0, 1fr) !important;
			gap: 0.65rem !important;
			align-items: start !important;
		}

		.curve-row + .curve-row {
			padding-top: 0.85rem !important;
		}

		.curve-label {
			font-size: 0.88rem !important;
			line-height: 1.1 !important;
		}

		.curve-cards {
			gap: 0.45rem !important;
		}

		.curve-note {
			grid-column: 1 / -1 !important;
			font-size: 0.9rem !important;
			line-height: 1.45 !important;
			padding-left: 0.65rem !important;
			border-left: 2px solid rgba(255, 107, 61, 0.55) !important;
		}
	}
</style>
