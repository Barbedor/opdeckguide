---
import { tournamentFormats, getTournamentLeaderStats } from "../lib/tournamentDecklists";

const { currentFormat, entries, heroTitle, heroIntro, showSeoContent = false } = Astro.props;

const formatConfig = tournamentFormats.find((format) => format.slug === currentFormat);
const leaderStats = getTournamentLeaderStats(currentFormat);
const totalDecklists = entries.length;

const eventTypeMeta = {
	"Shop Event": { short: "SE", color: "#ff7a2f", soft: "rgba(255, 122, 47, 0.18)" },
	"Standard Battle": { short: "SB", color: "#5db7ff", soft: "rgba(93, 183, 255, 0.18)" },
	"Flagship Battle": { short: "FS", color: "#ff6b6b", soft: "rgba(255, 107, 107, 0.18)" },
	"Treasure Cup": { short: "TB", color: "#a06eff", soft: "rgba(160, 110, 255, 0.18)" },
	Championship: { short: "CS", color: "#ffd257", soft: "rgba(255, 210, 87, 0.18)" },
};

const eventOptions = Object.keys(eventTypeMeta)
	.filter((eventType) => entries.some((entry) => entry.eventType === eventType))
	.map((eventType) => ({
		name: eventType,
		...(eventTypeMeta[eventType] ?? {
			short: eventType.slice(0, 2).toUpperCase(),
			color: "#9aa4c7",
			soft: "rgba(154, 164, 199, 0.18)",
		}),
	}));

const leaderColorMap = {
	Red: "#ff5959",
	Green: "#62d67a",
	Blue: "#4fbaff",
	Purple: "#a47aff",
	Yellow: "#ffd54f",
	Black: "#5f6679",
};

const getLeaderColors = (colorLabel) => {
	const colors = colorLabel
		.split("/")
		.map((part) => part.trim())
		.map((part) => leaderColorMap[part] ?? "#9aa4c7");

	return colors.length > 1 ? colors : [colors[0], colors[0]];
};

const allLeaderStats = leaderStats.map((item) => {
	const [startColor, endColor] = getLeaderColors(item.leader.color);
	return {
		...item,
		startColor,
		endColor,
		barStyle:
			startColor === endColor
				? `--bar-fill:${startColor};`
				: `--bar-fill:linear-gradient(135deg, ${startColor} 0%, ${endColor} 100%);`,
	};
});
const topLeaderStats = allLeaderStats.slice(0, 10);
const extraLeaderStats = allLeaderStats.slice(10);
const hasExtraLeaders = extraLeaderStats.length > 0;
const getFormatHref = (slug) => (slug === "op16-east" ? "/tournaments-decklists/" : `/tournaments-decklists/${slug}/`);
---

<section class="hero tournament-hero">
	<div class="container">
		<h1>{heroTitle ?? formatConfig?.title ?? "Tournament Decklists"}</h1>
		{
			heroIntro && (
				<p class="tournament-hero-intro">{heroIntro}</p>
			)
		}
		<div class="format-tabs" role="tablist" aria-label="Tournament formats">
			{tournamentFormats.map((format) => (
				<a
					href={getFormatHref(format.slug)}
					class:list={["format-tab", { active: format.slug === currentFormat }]}
					aria-current={format.slug === currentFormat ? "page" : undefined}
				>
					{format.label}
				</a>
			))}
		</div>
	</div>
</section>

<section class="tournament-stats">
	<div class="container">
		<div class="stats-card">
			<div class="stats-header">
				<div>
					<h2>Top Leaders</h2>
					<p>{totalDecklists} decks</p>
				</div>
			</div>

			<div class="stats-main">
				<div class="leader-board" aria-label="Top 10 leader share">
					{topLeaderStats.map((segment, index) => (
						<div class="leader-bar-row" data-leader-row>
							<div class="leader-bar-head">
								<button
									class="leader-bar-name"
									type="button"
									data-leader-name-toggle
									aria-expanded="false"
								>
									<img src={segment.leader.imageSrc} alt={`${segment.leader.name} icon`} loading="lazy" />
									<span class="leader-bar-name-text">
										{segment.leader.name} <span class="leader-bar-name-set">{segment.leader.code.split("-")[0]}</span>
									</span>
								</button>
								<div class="leader-bar-track">
									<div
										class="leader-bar-fill"
										style={`${segment.barStyle} width:${segment.share}%;`}
									></div>
								</div>
								<span class="leader-bar-meta">
									<strong>{segment.share}%</strong>
									<span>{segment.count}</span>
								</span>
							</div>
						</div>
					))}
					{
						hasExtraLeaders && (
							<details class="extra-leaders-details">
								<summary class="leader-toggle">Show more</summary>
								<div class="extra-leaders-wrap">
									{extraLeaderStats.map((segment) => (
										<div class="leader-bar-row" data-leader-row>
											<div class="leader-bar-head">
												<button
													class="leader-bar-name"
													type="button"
													data-leader-name-toggle
													aria-expanded="false"
												>
													<img src={segment.leader.imageSrc} alt={`${segment.leader.name} icon`} loading="lazy" />
													<span class="leader-bar-name-text">
														{segment.leader.name} <span class="leader-bar-name-set">{segment.leader.code.split("-")[0]}</span>
													</span>
												</button>
												<div class="leader-bar-track">
													<div
														class="leader-bar-fill"
														style={`${segment.barStyle} width:${segment.share}%;`}
													></div>
												</div>
												<span class="leader-bar-meta">
													<strong>{segment.share}%</strong>
													<span>{segment.count}</span>
												</span>
											</div>
										</div>
									))}
									<button type="button" class="leader-toggle leader-toggle-close" data-close-extra>Show less</button>
								</div>
							</details>
						)
					}
					{
						!topLeaderStats.length && (
							<div class="leader-board-empty">No tournament decklists yet for this format.</div>
						)
					}
				</div>

				<div class="results-toolbar">
					<div class="leader-search-wrap">
						<input
							type="search"
							placeholder="Search leader"
							aria-label="Search leader"
							data-tournament-filter="leader-search"
						/>
					</div>

					<div class="event-filter" data-event-filter>
						<button class="event-filter-button" type="button" data-event-filter-button aria-expanded="false">
							<span class="event-filter-button-copy" data-event-filter-label>All tournaments</span>
						</button>
						<div class="event-filter-menu" data-event-filter-menu hidden>
							<button type="button" class="event-filter-option active" data-event-option-value="">
								<span class="event-option-name">All tournaments</span>
							</button>
							{
								eventOptions.map((event) => (
									<button
										type="button"
										class="event-filter-option"
										data-event-option-value={event.name}
										data-event-short={event.short}
										data-event-color={event.color}
										data-event-soft={event.soft}
									>
										<span class="event-pill" style={`--pill:${event.color}; --pill-soft:${event.soft};`}>{event.short}</span>
										<span class="event-option-name">{event.name}</span>
									</button>
								))
							}
						</div>
					</div>

					<div class="deck-count-badge"><span data-visible-count>{totalDecklists}</span><span>&nbsp;Decks</span></div>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="tournament-results">
	<div class="container">
		<div class="results-table">
			<div class="results-head">
				<span>Date</span>
				<span>Leader</span>
				<span>Tournament</span>
				<span class="desktop-only">Place</span>
			</div>
			<div class="results-body">
				{entries.map((entry) => {
					const eventMeta = eventTypeMeta[entry.eventType] ?? {
						short: entry.eventType.slice(0, 2).toUpperCase(),
						color: "#9aa4c7",
						soft: "rgba(154, 164, 199, 0.18)",
					};
					return (
						<a
							class="results-row"
							href={entry.href}
							data-entry
							data-leader={entry.leader.slug}
							data-event={entry.eventType}
							data-leader-name={entry.leader.name.toLowerCase()}
							data-event-name={entry.eventName.toLowerCase()}
						>
							<span class="row-date">{entry.formattedDate}</span>
							<span class="row-leader">
								<img src={entry.leader.imageSrc} alt={`${entry.leader.name} icon`} loading="lazy" />
								<span class="row-leader-name">
									{entry.leader.name} <span class="row-leader-set">{entry.leader.code.split("-")[0]}</span>
								</span>
							</span>
							<span class="row-type">
								<span class="event-pill mobile-only" style={`--pill:${eventMeta.color}; --pill-soft:${eventMeta.soft};`}>{eventMeta.short}</span>
								<span class="event-pill event-pill-full desktop-only" style={`--pill:${eventMeta.color}; --pill-soft:${eventMeta.soft};`}>{entry.eventType}</span>
							</span>
							<span class="row-place desktop-only">{entry.placement}</span>
						</a>
					);
				})}
				{
					!entries.length && (
						<div class="results-empty">
							No tournament decklists for this format yet, but they are coming very soon.
						</div>
					)
				}
			</div>
		</div>
	</div>
</section>

{
	showSeoContent && (
		<section class="tournament-seo">
			<div class="container">
				<div class="tournament-seo-grid">
					<article class="seo-card">
						<h2>How to use these tournament decklists</h2>
						<p>
							Use this page as the main hub for One Piece TCG tournament results. Start with the
							format tabs, check the top leader share, then open the winning decklists that match the
							meta you want to study.
						</p>
					</article>

					<article class="seo-card">
						<h2>What counts as a winning decklist on OPDeckGuide</h2>
						<p>
							OPDeckGuide tracks real tournament results and featured winning lists from supported
							event types. The goal is to show the decks that actually performed, not theory-only test
							lists or recycled sample builds.
						</p>
					</article>

					<article class="seo-card">
						<h2>How East and West formats differ</h2>
						<p>
							East and West formats can diverge in release timing, legal card pool, and leader
							popularity. Splitting the data by region makes it easier to compare the active meta
							without mixing tournament environments that do not behave the same way.
						</p>
					</article>

					<article class="seo-card">
						<h2>Find top-performing leaders and recent winners</h2>
						<p>
							The leader ranking highlights which decks are winning the most events in the selected
							format, while the results table helps you track the most recent finishes. This makes the
							page useful both for quick meta checks and deeper deck research.
						</p>
					</article>

					<article class="seo-card">
						<h2>Tournament types tracked</h2>
						<p>
							This section currently tracks Shop Events, Standard Battles, Flagship Battles, Treasure
							Cups, and Championships. Each tournament type gives a different signal, from local
							consistency to stronger large-event performance.
						</p>
					</article>
				</div>
			</div>
		</section>
	)
}

<script is:inline>
	const setupTournamentView = () => {
		const rows = [...document.querySelectorAll("[data-entry]")];
		const leaderSearch = document.querySelector('[data-tournament-filter="leader-search"]');
		const visibleCount = document.querySelector("[data-visible-count]");
		const eventFilter = document.querySelector("[data-event-filter]");
		const eventFilterButton = document.querySelector("[data-event-filter-button]");
		const eventFilterMenu = document.querySelector("[data-event-filter-menu]");
		const eventFilterLabel = document.querySelector("[data-event-filter-label]");
		const eventOptions = [...document.querySelectorAll("[data-event-option-value]")];
		const leaderNameToggles = [...document.querySelectorAll("[data-leader-name-toggle]")];
		const extraLeadersDetails = document.querySelector(".extra-leaders-details");
		const closeExtraButton = document.querySelector("[data-close-extra]");

		if (!leaderSearch || !visibleCount || !eventFilter || !eventFilterButton || !eventFilterMenu || !eventFilterLabel) return;

		let selectedEvent = "";

		const syncEventLabel = (option) => {
			if (!option || !selectedEvent) {
				eventFilterLabel.textContent = "All tournaments";
				return;
			}

			const short = option.dataset.eventShort;
			const color = option.dataset.eventColor;
			const soft = option.dataset.eventSoft;
			const name = option.querySelector(".event-option-name")?.textContent ?? option.dataset.eventOptionValue ?? "";
			eventFilterLabel.innerHTML = `<span class="event-pill" style="--pill:${color}; --pill-soft:${soft};">${short}</span><span>${name}</span>`;
		};

		const applyFilters = () => {
			const leaderValue = leaderSearch.value.trim().toLowerCase();
			let count = 0;

			for (const row of rows) {
				const matchLeader = !leaderValue || (row.dataset.leaderName || "").includes(leaderValue);
				const matchEvent = !selectedEvent || row.dataset.event === selectedEvent;
				const visible = matchLeader && matchEvent;
				row.style.display = visible ? "" : "none";
				if (visible) count += 1;
			}

			visibleCount.textContent = String(count);
		};

		eventFilterButton.addEventListener("click", () => {
			const expanded = eventFilterButton.getAttribute("aria-expanded") === "true";
			eventFilterButton.setAttribute("aria-expanded", expanded ? "false" : "true");
			eventFilterMenu.hidden = expanded;
		});

		document.addEventListener("click", (event) => {
			if (!eventFilter.contains(event.target)) {
				eventFilterButton.setAttribute("aria-expanded", "false");
				eventFilterMenu.hidden = true;
			}
		});

		for (const option of eventOptions) {
			option.addEventListener("click", () => {
				selectedEvent = option.dataset.eventOptionValue || "";
				for (const item of eventOptions) item.classList.toggle("active", item === option);
				syncEventLabel(option);
				eventFilterButton.setAttribute("aria-expanded", "false");
				eventFilterMenu.hidden = true;
				applyFilters();
			});
		}

		leaderSearch.addEventListener("input", applyFilters);

		for (const toggle of leaderNameToggles) {
			toggle.onclick = () => {
				const expanded = toggle.getAttribute("aria-expanded") === "true";
				for (const item of leaderNameToggles) item.setAttribute("aria-expanded", "false");
				toggle.setAttribute("aria-expanded", expanded ? "false" : "true");
			};
		}

		if (closeExtraButton && extraLeadersDetails) {
			closeExtraButton.onclick = () => {
				extraLeadersDetails.open = false;
			};
		}
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", setupTournamentView, { once: true });
	} else {
		setupTournamentView();
	}
</script>

<style>
	.tournament-hero,
	.tournament-stats,
	.tournament-results {
		padding: 0 0 20px;
	}

	.tournament-hero h1 {
		margin-bottom: 0.55rem;
		font-size: clamp(2.1rem, 4.2vw, 3.3rem);
		line-height: 1.08;
	}

	.tournament-hero-intro {
		max-width: 760px;
		margin: 0;
		color: var(--text-200);
		line-height: 1.65;
	}

	.format-tabs {
		display: flex;
		gap: 0.65rem;
		margin-top: 1rem;
		flex-wrap: wrap;
	}

	.format-tab {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 86px;
		padding: 0.72rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(17, 21, 34, 0.95);
		color: var(--text-200);
		font-weight: 700;
	}

	.format-tab.active {
		background: linear-gradient(135deg, rgba(255, 147, 60, 0.24), rgba(255, 113, 33, 0.18));
		border-color: rgba(255, 147, 60, 0.45);
		color: var(--white);
	}

	.stats-card,
	.results-table,
	.results-toolbar input,
	.event-filter-button,
	.event-filter-menu,
	.deck-count-badge {
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(10, 14, 24, 0.88);
	}

	.stats-card {
		padding: 0.9rem;
		display: grid;
		gap: 0.85rem;
	}

	.stats-header {
		display: grid;
		gap: 0.65rem;
	}

	.stats-header h2 {
		margin-bottom: 0.3rem;
	}

	.stats-header p {
		margin: 0;
		color: var(--text-300);
	}

	.event-filter-button,
	.event-filter-option,
	.event-filter-button-copy,
	.row-type,
	.row-leader,
	.leader-bar-head,
	.leader-bar-name,
	.leader-bar-meta {
		display: flex;
		align-items: center;
	}

	.event-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 42px;
		height: 24px;
		padding: 0 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--pill);
		background: var(--pill-soft);
		color: var(--pill);
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		line-height: 1;
		flex: 0 0 auto;
	}

	.stats-main {
		display: grid;
		gap: 1rem;
	}

	.leader-board {
		display: grid;
		gap: 0.45rem;
	}

	.leader-bar-row {
		display: grid;
		gap: 0.18rem;
	}

	.leader-bar-head {
		display: grid;
		grid-template-columns: minmax(0, auto) minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.55rem;
	}

	.leader-bar-name {
		gap: 0.45rem;
		min-width: 0;
		font-weight: 800;
		font-size: 0.92rem;
		line-height: 1.1;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--text-100);
		cursor: pointer;
		text-align: left;
	}

	.leader-bar-name img {
		width: 26px;
		height: 26px;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		object-fit: cover;
		flex: 0 0 auto;
	}

	.leader-bar-name-text {
		display: none;
	}

	.leader-bar-name[aria-expanded="true"] .leader-bar-name-text {
		display: inline;
	}

	.leader-bar-name-set {
		color: var(--text-300);
		font-size: 0.82em;
		font-weight: 700;
	}

	.leader-bar-meta {
		gap: 0.55rem;
		flex: 0 0 auto;
	}

	.leader-bar-meta strong {
		font-size: 0.88rem;
	}

	.leader-bar-meta span {
		color: var(--text-300);
		font-size: 0.78rem;
		font-weight: 700;
	}

	.leader-bar-track {
		height: 8px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		overflow: hidden;
		min-width: 0;
	}

	.leader-bar-fill {
		height: 100%;
		border-radius: inherit;
		background: var(--bar-fill);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
	}

	.leader-board-empty {
		color: var(--text-300);
		font-size: 0.95rem;
	}

	.leader-toggle {
		display: inline-flex;
		align-items: center;
		justify-self: start;
		padding: 0.5rem 0.85rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 147, 60, 0.25);
		background: rgba(255, 147, 60, 0.08);
		color: var(--accent-300);
		font-size: 0.76rem;
		font-weight: 700;
		cursor: pointer;
		list-style: none;
		font-size: 0.86rem;
		font-weight: 800;
	}

	.leader-toggle::-webkit-details-marker {
		display: none;
	}

	.leader-toggle:hover {
		border-color: rgba(255, 147, 60, 0.4);
		background: rgba(255, 147, 60, 0.14);
	}

	.extra-leaders-details {
		display: grid;
		gap: 0.45rem;
	}

	.extra-leaders-details[open] > .leader-toggle {
		display: none;
	}

	.extra-leaders-wrap {
		display: grid;
		gap: 0.45rem;
	}

	.leader-toggle-close {
		margin-top: 0.1rem;
	}

	.results-toolbar {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 0.65rem;
		grid-column: 1 / -1;
	}

	.leader-search-wrap input,
	.event-filter-button,
	.deck-count-badge {
		min-height: 48px;
		width: 100%;
		padding: 0 0.9rem;
		color: var(--text-100);
	}

	.leader-search-wrap input {
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(10, 14, 24, 0.88);
	}

	.event-filter {
		position: relative;
	}

	.event-filter-button {
		justify-content: space-between;
		gap: 0.7rem;
		cursor: pointer;
	}

	.event-filter-button::after {
		content: "▾";
		color: var(--text-300);
		font-size: 0.82rem;
	}

	.event-filter-button-copy {
		gap: 0.55rem;
		min-width: 0;
	}

	.event-filter-menu {
		position: static;
		margin-top: 0.45rem;
		padding: 0.45rem;
		display: grid;
		gap: 0.3rem;
	}

	.event-filter-menu[hidden] {
		display: none !important;
	}

	.event-filter-option {
		width: 100%;
		border: 0;
		background: transparent;
		padding: 0.65rem 0.7rem;
		border-radius: 14px;
		gap: 0.55rem;
		color: var(--text-100);
		cursor: pointer;
		text-align: left;
	}

	.event-filter-option.active,
	.event-filter-option:hover {
		background: rgba(255, 255, 255, 0.06);
	}

	.event-option-name {
		font-weight: 700;
	}

	.deck-count-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		color: var(--text-200);
		grid-column: 1 / -1;
	}

	.results-table {
		overflow: hidden;
	}

	.results-head,
	.results-row {
		display: grid;
		grid-template-columns: 72px minmax(0, 1fr) 76px;
		gap: 0.35rem;
		align-items: center;
		padding: 0.9rem 0.75rem;
