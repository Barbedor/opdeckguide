---
const { title, description, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---

	<section class="hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">OPTCG Strategy Hub</span>
				<h1>{title}</h1>
				<p>{description}</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>
					<a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>
				</div>
			</div>
		</div>
	</section>
