---
const { title, description, linkHref, linkLabel, gridClass } = Astro.props;
---

<section class="section">
	<div class="container">
		<div class="section-header">
			<div>
				<h2>{title}</h2>
				<p>{description}</p>
			</div>
			{linkHref && linkLabel && (
				<a href={linkHref}>{linkLabel}</a>
			)}
		</div>
		<div class={`card-grid ${gridClass ?? ""}`.trim()}>
			<slot />
		</div>
	</div>
</section>
